@page "/trainer/rooms"
@attribute [Authorize(Roles = "Trainer")]
@layout TrainerLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using System.Text
@using FitPlay.Blazor.Services
@inject ApiClient Api
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Rooms - FitPlay</PageTitle>

<div class="page-wrap">
    <h1>Rooms Availability</h1>

    <div class="toolbar">
        <input type="date" @bind="_selectedDate" @bind:after="Load" />
        <button @onclick="Load">Refresh</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="success-message">@_successMessage</div>
    }

    @if (_loading)
    {
        <p>Loading...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="error">@_error</p>
    }
    else
    {
        @foreach (var group in _roomsByLocation)
        {
            <h3>@group.Key</h3>
            <div class="grid">
                @foreach (var room in group.Value)
                {
                    var isFullyBooked = IsFullyBooked(room.Id);
                    var availableHours = GetAvailableHoursCount(room.Id);
                    
                    <article class="card @(isFullyBooked ? "fully-booked" : "room-clickable")" 
                             @onclick="() => TryOpenModal(room, group.Key)">
                        <h4>@room.Name</h4>
                        <p>Capacity: @room.Capacity | @room.PricePerHour.ToString("C")/h</p>
                        
                        @if (isFullyBooked)
                        {
                            <div class="fully-booked-badge">
                                <span class="icon">🔒</span>
                                <span class="text">FULLY BOOKED</span>
                            </div>
                        }
                        else
                        {
                            <div class="availability-summary">
                                <span class="icon">✓</span>
                                <span class="text">@availableHours hours available today</span>
                            </div>
                            <div class="card-action-hint">Click to book room →</div>
                        }
                    </article>
                }
            </div>
        }
    }
</div>

@if (_showScheduleModal && _selectedRoom is not null)
{
    <div class="create-modal-backdrop" @onclick="CloseScheduleModal">
        <div class="create-modal" @onclick:stopPropagation="true">
            <div class="create-modal-header">
                <h3>Book Room & Schedule Class</h3>
                <button class="create-modal-close" @onclick="CloseScheduleModal">×</button>
            </div>
            
            <div class="room-info-header">
                <div class="room-info-title">📍 @_selectedRoom.Name</div>
                <div class="room-info-meta">@_selectedRoomLocation</div>
                <div class="room-info-details">
                    <span>Capacity: @_selectedRoom.Capacity</span>
                    <span>•</span>
                    <span>@_selectedRoom.PricePerHour.ToString("C")/hour</span>
                </div>
            </div>

            <div class="create-modal-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Purpose</label>
                        <select @bind="_bookingForm.Purpose">
                            <option value="GroupClass">Group Class</option>
                            <option value="PersonalTraining">Personal Training</option>
                            <option value="Rehabilitation">Rehabilitation</option>
                            <option value="Assessment">Assessment</option>
                            <option value="Yoga">Yoga</option>
                            <option value="Pilates">Pilates</option>
                            <option value="Crossfit">Crossfit</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Class Modality</label>
                        <select class="neon-dropdown" @bind="_bookingForm.Modality">
                            <option value="">Select a modality</option>
                            <option value="Boxing">Boxing</option>
                            <option value="Muay Thai">Muay Thai</option>
                            <option value="Martial Arts">Martial Arts</option>
                            <option value="CrossFit">CrossFit</option>
                            <option value="Functional Train">Functional Train</option>
                            <option value="Weight Training">Weight Training</option>
                            <option value="Circuit Training">Circuit Training</option>
                            <option value="HIIT">HIIT</option>
                            <option value="Pilates">Pilates</option>
                            <option value="Yoga">Yoga</option>
                            <option value="Stretching/Mobility">Stretching/Mobility</option>
                            <option value="Zumba/Dance Fit">Zumba/Dance Fit</option>
                            <option value="Spinning/Cycling">Spinning/Cycling</option>
                            <option value="Step Class">Step Class</option>
                            <option value="Running Club">Running Club</option>
                            <option value="Cycling">Cycling</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Purpose Description (optional)</label>
                    <textarea @bind="_bookingForm.PurposeDescription" 
                              placeholder="Additional details about the booking..."></textarea>
                </div>

                <div class="time-blocks-section">
                    <h4>Select Time Blocks</h4>
                    
                    @foreach (var block in _timeBlocks)
                    {
                        <div class="time-block-row">
                            <div class="time-block-header">
                                <span class="block-label">Time Block #@block.Id</span>
                                @if (_timeBlocks.Count > 1)
                                {
                                    <button type="button" class="btn-remove" @onclick="() => RemoveTimeBlock(block.Id)">
                                        × Remove
                                    </button>
                                }
                            </div>
                            
                            <div class="time-block-inputs">
                                <div class="form-group">
                                    <label>Start Time</label>
                                    <select @bind="block.StartTime" @bind:after="OnTimeBlockChanged">
                                        <option value="">Select start</option>
                                        @foreach (var time in GetAvailableStartTimes())
                                        {
                                            <option value="@time">@time.ToString("HH:mm")</option>
                                        }
                                    </select>
                                </div>
                                
                                <span class="time-separator">→</span>
                                
                                <div class="form-group">
                                    <label>End Time</label>
                                    <select @bind="block.EndTime" @bind:after="OnTimeBlockChanged" 
                                            disabled="@(!block.StartTime.HasValue)">
                                        <option value="">Select end</option>
                                        @foreach (var time in GetAvailableEndTimes(block.StartTime))
                                        {
                                            <option value="@time">@time.ToString("HH:mm")</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            
                            @if (_blockPrices.TryGetValue(block.Id, out var price) && price > 0)
                            {
                                <div class="block-price-summary">
                                    @CalculateHours(block.StartTime!.Value, block.EndTime!.Value).ToString("F1") hours 
                                    × @_selectedRoom!.PricePerHour.ToString("C")/hr 
                                    = @price.ToString("C")
                                </div>
                            }
                        </div>
                    }

                    <button type="button" class="btn-add-block" @onclick="AddTimeBlock">
                        + Add Another Time Block
                    </button>
                </div>

                @if (_totalPrice > 0)
                {
                    <div class="total-price-display">
                        <div class="total-label">TOTAL BOOKING COST</div>
                        <div class="total-amount">@_totalPrice.ToString("C")</div>
                        <div class="total-hours">for @CalculateTotalHours().ToString("F1") hours</div>
                    </div>
                }

                <div class="form-group">
                    <label>Additional Notes (optional)</label>
                    <textarea @bind="_bookingForm.Notes" placeholder="Any additional information..."></textarea>
                </div>

                @if (!string.IsNullOrEmpty(_scheduleError))
                {
                    <div class="inline-error">@_scheduleError</div>
                }
            </div>

            <div class="create-modal-actions">
                <button class="btn-secondary" @onclick="CloseScheduleModal" disabled="@_scheduling">Cancel</button>
                <button class="btn-primary" @onclick="CreateBookingAndSchedule" disabled="@_scheduling">
                    @if (_scheduling)
                    {
                        <span>Booking...</span>
                    }
                    else
                    {
                        <span>Book Room & Schedule Class</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<style>
    .page-wrap { 
        max-width: 1200px; 
        margin: 0 auto; 
        padding: 24px; 
    }
    
    .toolbar { 
        display: flex; 
        gap: 8px; 
        margin-bottom: 12px; 
    }
    
    .toolbar input,
    .toolbar button {
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid var(--glass-border);
        background: rgba(255,255,255,.06);
        color: var(--text-primary);
        font-size: 14px;
    }

    .toolbar button {
        background: linear-gradient(135deg, var(--accent-teal), var(--accent-magenta));
        border: none;
        color: #fff;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .toolbar button:hover {
        opacity: 0.9;
    }
    
    .grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); 
        gap: 14px; 
        margin-bottom: 24px;
    }
    
    .card { 
        background: var(--glass-bg); 
        border: 1px solid var(--glass-border); 
        border-radius: 14px; 
        padding: 14px; 
        position: relative;
    }

    .card h4 {
        margin: 0 0 8px 0;
        font-size: 16px;
        color: var(--text-primary);
    }

    .card p {
        margin: 0 0 12px 0;
        font-size: 13px;
        color: var(--text-muted);
    }

    /* Interactive room cards */
    .room-clickable {
        cursor: pointer;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }

    .room-clickable:hover {
        transform: translateY(-4px);
        border-color: var(--accent-teal);
        box-shadow: 0 8px 24px rgba(14,240,255,0.2);
    }

    /* Fully booked cards */
    .card.fully-booked {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .card.fully-booked:hover {
        transform: none;
        border-color: var(--glass-border);
        box-shadow: none;
    }

    .fully-booked-badge {
        background: rgba(255, 77, 109, 0.2);
        color: #ff9aa2;
        padding: 12px;
        border-radius: 8px;
        text-align: center;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: 1px solid rgba(255, 77, 109, 0.4);
    }

    .fully-booked-badge .icon {
        font-size: 18px;
    }

    /* Availability summary */
    .availability-summary {
        background: rgba(14,240,255,0.12);
        color: var(--accent-teal);
        padding: 10px;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
        margin: 12px 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border: 1px solid rgba(14,240,255,0.3);
    }

    .availability-summary .icon {
        font-size: 16px;
    }

    .card-action-hint {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--glass-border);
        font-size: 12px;
        color: var(--accent-teal);
        font-weight: 600;
        text-align: center;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .room-clickable:hover .card-action-hint {
        opacity: 1;
    }
    
    .error { 
        color: #ff9aa2; 
        background: rgba(255, 77, 109, 0.15);
        padding: 12px;
        border-radius: 8px;
        margin: 12px 0;
    }

    .success-message {
        background: rgba(14,240,255,0.12);
        color: var(--accent-teal);
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 16px;
        font-weight: 600;
        border: 1px solid rgba(14,240,255,0.3);
        animation: slideDown 0.3s ease-out;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Modal Styles */
    .create-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(5, 8, 15, 0.75);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        padding: 20px;
        animation: fadeIn 0.2s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .create-modal {
        background: var(--bg-dark, #0b0b11);
        border-radius: 18px;
        width: min(720px, 96vw);
        max-height: 90vh;
        overflow: auto;
        box-shadow: 0 12px 40px rgba(0,0,0,0.5);
        padding: 24px;
        border: 1px solid var(--glass-border);
        animation: slideUp 0.3s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .create-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

    .create-modal-header h3 {
        margin: 0;
        font-size: 22px;
        color: var(--text-primary);
        font-weight: 700;
    }

    .create-modal-close {
        background: rgba(255,255,255,0.08);
        border: none;
        border-radius: 8px;
        width: 36px;
        height: 36px;
        cursor: pointer;
        font-size: 20px;
        font-weight: 700;
        color: var(--text-primary);
        transition: background 0.2s;
    }

    .create-modal-close:hover {
        background: rgba(255,255,255,0.12);
    }

    /* Room Info Header */
    .room-info-header {
        background: linear-gradient(135deg, rgba(14,240,255,0.08), rgba(255,47,180,0.08));
        border: 1px solid rgba(14,240,255,0.2);
        padding: 14px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .room-info-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .room-info-meta {
        font-size: 13px;
        color: var(--text-muted);
        margin-bottom: 8px;
    }

    .room-info-details {
        display: flex;
        gap: 8px;
        font-size: 12px;
        color: var(--accent-teal);
        font-weight: 600;
    }

    .create-modal-body {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .create-modal-body h4 {
        margin: 0 0 12px 0;
        font-size: 16px;
        color: var(--text-primary);
        font-weight: 700;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .form-group label {
        font-size: 13px;
        color: var(--text-muted);
        font-weight: 600;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        padding: 11px 13px;
        border: 1px solid var(--glass-border);
        border-radius: 9px;
        font-size: 14px;
        background: rgba(255,255,255,0.04);
        color: var(--text-primary);
        transition: border-color 0.2s, background 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--accent-teal);
        background: rgba(255,255,255,0.06);
    }

    .form-group input:disabled,
    .form-group select:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        background: rgba(255,255,255,0.02);
    }

    .form-group textarea {
        min-height: 70px;
        resize: vertical;
        font-family: inherit;
    }

    .neon-dropdown {
        background: rgba(57, 255, 20, 0.55);
        color: #000;
        font-weight: 700;
        border: 1px solid rgba(182, 255, 0, 0.9);
        box-shadow: 0 0 12px rgba(57, 255, 20, 0.45);
    }

    .neon-dropdown:focus {
        outline: none;
        border-color: rgba(234, 255, 106, 1);
        box-shadow: 0 0 16px rgba(57, 255, 20, 0.65);
    }

    .neon-dropdown option {
        background: rgba(11, 11, 17, 0.95);
        color: #fff;
    }

    /* Time Blocks Section */
    .time-blocks-section {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 18px;
    }

    .time-block-row {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--glass-border);
