        padding: 16px;
        margin-bottom: 14px;
    }

    .time-block-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }

    .block-label {
        font-weight: 700;
        color: var(--text-primary);
        font-size: 14px;
    }

    .btn-remove {
        background: rgba(255, 77, 109, 0.2);
        color: #ff9aa2;
        border: 1px solid rgba(255, 77, 109, 0.4);
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
        transition: background 0.2s;
    }

    .btn-remove:hover {
        background: rgba(255, 77, 109, 0.3);
    }

    .time-block-inputs {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 12px;
        align-items: end;
        margin-bottom: 12px;
    }

    .time-separator {
        font-size: 24px;
        color: var(--accent-teal);
        padding-bottom: 8px;
        font-weight: 700;
    }

    .block-price-summary {
        padding: 10px;
        background: rgba(14,240,255,0.08);
        border-radius: 8px;
        text-align: center;
        font-size: 13px;
        color: var(--text-primary);
        font-weight: 600;
    }

    /* Add Time Block Button */
    .btn-add-block {
        width: 100%;
        background: rgba(14,240,255,0.12);
        color: var(--accent-teal);
        border: 1px dashed var(--accent-teal);
        padding: 12px;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s;
        font-size: 14px;
    }

    .btn-add-block:hover {
        background: rgba(14,240,255,0.2);
        border-style: solid;
    }

    /* Total Price Display */
    .total-price-display {
        background: linear-gradient(135deg, rgba(14,240,255,0.15), rgba(255,47,180,0.15));
        border: 2px solid var(--accent-teal);
        border-radius: 14px;
        padding: 20px;
        text-align: center;
        animation: priceUpdate 0.3s ease-out;
    }

    @@keyframes priceUpdate {
        from {
            transform: scale(0.98);
            opacity: 0.8;
        }
        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .total-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 600;
        letter-spacing: 1px;
    }

    .total-amount {
        font-size: 36px;
        font-weight: 700;
        color: var(--accent-teal);
        margin: 8px 0;
        text-shadow: 0 0 20px rgba(14,240,255,0.3);
    }

    .total-hours {
        font-size: 14px;
        color: var(--text-muted);
    }

    .create-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid var(--glass-border);
    }

    .btn-secondary {
        background: rgba(255,255,255,0.08);
        color: var(--text-primary);
        border: 1px solid var(--glass-border);
        padding: 10px 18px;
        border-radius: 9px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: background 0.2s;
    }

    .btn-secondary:hover:not(:disabled) {
        background: rgba(255,255,255,0.12);
    }

    .btn-secondary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--accent-teal) 0%, var(--accent-magenta) 100%);
        color: #fff;
        border: none;
        padding: 10px 20px;
        border-radius: 9px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 700;
        transition: opacity 0.2s, transform 0.1s;
    }

    .btn-primary:hover:not(:disabled) {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .inline-error {
        color: #fecaca;
        background: rgba(127, 29, 29, 0.4);
        border-radius: 9px;
        padding: 11px 13px;
        font-size: 13px;
        border: 1px solid rgba(127, 29, 29, 0.6);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
        
        .grid {
            grid-template-columns: 1fr;
        }

        .time-block-inputs {
            grid-template-columns: 1fr;
            gap: 8px;
        }

        .time-separator {
            display: none;
        }
    }
</style>

@code {
    private readonly Dictionary<string, List<ApiClient.RoomRead>> _roomsByLocation = new();
    private readonly Dictionary<int, ApiClient.RoomAvailability> _availability = new();
    private bool _loading = true;
    private string? _error;
    private DateTime _selectedDate = DateTime.UtcNow.Date;

    // Modal state
    private bool _showScheduleModal;
    private bool _scheduling;
    private string? _scheduleError;
    private string? _successMessage;

    // Selected room context
    private ApiClient.RoomRead? _selectedRoom;
    private string? _selectedRoomLocation;
    private ApiClient.RoomAvailability? _selectedRoomAvailability;

    // Time block management
    private List<TimeBlock> _timeBlocks = new() { new TimeBlock { Id = 1 } };
    private int _nextBlockId = 2;

    // Price tracking
    private decimal _totalPrice = 0m;
    private Dictionary<int, decimal> _blockPrices = new();

    // Form data
    private BookingForm _bookingForm = new();

    // Availability cache
    private Dictionary<int, int> _availableHoursCache = new();

    // Trainer context
    private int? _currentTrainerId;

    protected override async Task OnInitializedAsync()
    {
        _currentTrainerId = await ResolveCurrentTrainerIdAsync();
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        _error = null;
        _successMessage = null;
        _roomsByLocation.Clear();
        _availability.Clear();
        _availableHoursCache.Clear();

        try
        {
            var gyms = await Api.GetGyms(true);
            var date = DateOnly.FromDateTime(_selectedDate);

            foreach (var gym in gyms)
            {
                var locations = await Api.GetGymLocations(gym.Id, true);
                foreach (var location in locations)
                {
                    var rooms = await Api.GetRoomsByLocation(location.Id, true);
                    if (!rooms.Any()) continue;

                    var key = $"{gym.Name} - {location.Name}";
                    _roomsByLocation[key] = rooms;

                    foreach (var room in rooms)
                    {
                        var av = await Api.GetRoomAvailability(room.Id, date);
                        if (av is not null)
                        {
                            _availability[room.Id] = av;
                            _availableHoursCache[room.Id] = av.Slots.Count(s => s.IsAvailable);
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Room Card Helpers ──────────────────────────────────────────────────
    private bool IsFullyBooked(int roomId)
    {
        return _availableHoursCache.TryGetValue(roomId, out var count) && count == 0;
    }

    private int GetAvailableHoursCount(int roomId)
    {
        return _availableHoursCache.TryGetValue(roomId, out var count) ? count : 0;
    }

    private void TryOpenModal(ApiClient.RoomRead room, string location)
    {
        if (IsFullyBooked(room.Id))
        {
            return; // Don't open modal for fully booked rooms
        }
        OpenScheduleModalForRoom(room, location);
    }

    // ── Modal Management ───────────────────────────────────────────────────
    private void OpenScheduleModalForRoom(ApiClient.RoomRead room, string location)
    {
        _selectedRoom = room;
        _selectedRoomLocation = location;
        _availability.TryGetValue(room.Id, out _selectedRoomAvailability);

        // Reset form
        _bookingForm = new BookingForm();
        _timeBlocks = new List<TimeBlock> { new TimeBlock { Id = 1 } };
        _nextBlockId = 2;
        _totalPrice = 0m;
        _blockPrices.Clear();

        _scheduleError = null;
        _showScheduleModal = true;
    }

    private void CloseScheduleModal()
    {
        _showScheduleModal = false;
        _scheduleError = null;
    }

    // ── Time Block Management ──────────────────────────────────────────────
    private void AddTimeBlock()
    {
        _timeBlocks.Add(new TimeBlock { Id = _nextBlockId++ });
    }

    private void RemoveTimeBlock(int blockId)
    {
        var block = _timeBlocks.FirstOrDefault(b => b.Id == blockId);
        if (block is not null && _timeBlocks.Count > 1)
        {
            _timeBlocks.Remove(block);
            _blockPrices.Remove(blockId);
            RecalculateTotalPrice();
        }
    }

    private void OnTimeBlockChanged()
    {
        RecalculateTotalPrice();
    }

    // ── Available Times Filtering ──────────────────────────────────────────
    private List<TimeOnly> GetAvailableStartTimes()
    {
        if (_selectedRoomAvailability is null) return new();

        return _selectedRoomAvailability.Slots
            .Where(s => s.IsAvailable)
            .Select(s => TimeOnly.FromDateTime(s.StartTime.ToLocalTime()))
            .Distinct()
            .OrderBy(t => t)
            .ToList();
    }

    private List<TimeOnly> GetAvailableEndTimes(TimeOnly? startTime)
    {
        if (_selectedRoomAvailability is null || !startTime.HasValue)
            return new();

        return _selectedRoomAvailability.Slots
            .Where(s => s.IsAvailable)
            .Select(s => TimeOnly.FromDateTime(s.EndTime.ToLocalTime()))
            .Where(t => t > startTime.Value)
            .Distinct()
            .OrderBy(t => t)
            .ToList();
    }

    // ── Price Calculation ──────────────────────────────────────────────────
    private void RecalculateTotalPrice()
    {
        if (_selectedRoom is null) return;

        _totalPrice = 0m;
        _blockPrices.Clear();

        foreach (var block in _timeBlocks.Where(b => b.IsValid()))
        {
            var hours = CalculateHours(block.StartTime!.Value, block.EndTime!.Value);
            var blockPrice = hours * _selectedRoom.PricePerHour;

            _blockPrices[block.Id] = blockPrice;
            _totalPrice += blockPrice;
        }
    }

    private decimal CalculateHours(TimeOnly start, TimeOnly end)
    {
        var duration = end - start;
        return (decimal)duration.TotalMinutes / 60m;
    }

    private decimal CalculateTotalHours()
    {
        decimal total = 0m;
        foreach (var block in _timeBlocks.Where(b => b.IsValid()))
        {
            total += CalculateHours(block.StartTime!.Value, block.EndTime!.Value);
        }
        return total;
    }

    // ── Booking Creation ───────────────────────────────────────────────────
    private async Task CreateBookingAndSchedule()
    {
        _scheduleError = ValidateBookingForm();
        if (!string.IsNullOrEmpty(_scheduleError)) return;

        _scheduling = true;
        var createdBookingIds = new List<int>();

        try
        {
            // Step 1: Create room booking(s) for each time block
            foreach (var block in _timeBlocks.Where(b => b.IsValid()))
            {
                var startUtc = CombineDateAndTime(_selectedDate, block.StartTime!.Value);
                var endUtc = CombineDateAndTime(_selectedDate, block.EndTime!.Value);

                var bookingRequest = new ApiClient.CreateRoomBookingBody(
                    Purpose: _bookingForm.Purpose,
                    PurposeDescription: _bookingForm.PurposeDescription,
                    StartTime: startUtc,
                    EndTime: endUtc,
                    Notes: _bookingForm.Notes
                );

                var booking = await Api.CreateRoomBooking(_selectedRoom!.Id, bookingRequest);
                if (booking is null)
                {
                    throw new Exception($"Failed to create booking for time block {block.Id}");
                }

                createdBookingIds.Add(booking.Id);
            }

            // Step 2: Create class schedule linked to bookings
            var primaryBlock = _timeBlocks.First(b => b.IsValid());
            var scheduledAt = CombineDateAndTime(_selectedDate, primaryBlock.StartTime!.Value);
            var notes = BuildNotesWithMultipleBookings(createdBookingIds);

            await Api.CreateTrainerClassSchedule(
                _currentTrainerId!.Value,
                _bookingForm.Modality,
                scheduledAt,
                notes
            );

            // Success!
            _successMessage = $"✓ Room booked and class scheduled! Total cost: {_totalPrice:C}";
            _showScheduleModal = false;
            ResetForm();

            // Refresh availability
            await Load();
        }
        catch (Exception ex)
        {
            // Rollback: Try to delete created bookings
            foreach (var bookingId in createdBookingIds)
            {
                try
                {
                    await Api.CancelRoomBooking(bookingId);
                }
                catch
                {
                    // Log but don't throw - best effort cleanup
                }
            }

            _scheduleError = $"Error creating booking: {ex.Message}";
        }
        finally
        {
            _scheduling = false;
        }
    }

    private DateTime CombineDateAndTime(DateTime date, TimeOnly time)
    {
        var localDateTime = new DateTime(date.Year, date.Month, date.Day, time.Hour, time.Minute, 0, DateTimeKind.Local);
        return localDateTime.ToUniversalTime();
    }

    private string BuildNotesWithMultipleBookings(List<int> bookingIds)
    {
        var sb = new StringBuilder();

        sb.AppendLine($"Room: {_selectedRoom!.Name} ({_selectedRoomLocation})");
        sb.AppendLine($"Capacity: {_selectedRoom.Capacity}");
        sb.AppendLine($"Total Cost: {_totalPrice:C} for {CalculateTotalHours():F1} hours");
        sb.AppendLine($"Booking IDs: {string.Join(", ", bookingIds)}");
        sb.AppendLine("Time Blocks:");

        foreach (var block in _timeBlocks.Where(b => b.IsValid()))
        {
            var hours = CalculateHours(block.StartTime!.Value, block.EndTime!.Value);
            sb.AppendLine($"  • {block.StartTime:HH:mm}-{block.EndTime:HH:mm} ({hours:F1}h)");
        }

        if (!string.IsNullOrWhiteSpace(_bookingForm.Notes))
        {
            sb.AppendLine($"Additional Notes: {_bookingForm.Notes}");
        }

        return sb.ToString();
    }

    // ── Validation ─────────────────────────────────────────────────────────
    private string? ValidateBookingForm()
    {
        if (_currentTrainerId is null)
            return "Trainer profile not found. Please sign in with a trainer account.";

        if (string.IsNullOrWhiteSpace(_bookingForm.Purpose))
            return "Select a purpose for the booking.";

        if (string.IsNullOrWhiteSpace(_bookingForm.Modality))
            return "Select a class modality.";

        var validBlocks = _timeBlocks.Where(b => b.IsValid()).ToList();
        if (!validBlocks.Any())
            return "Add at least one time block with start and end times.";

        // Individual block validation
        foreach (var block in validBlocks)
        {
            if (block.EndTime <= block.StartTime)
                return "End time must be after start time.";

            var startUtc = CombineDateAndTime(_selectedDate, block.StartTime!.Value);
            if (startUtc <= DateTime.UtcNow)
                return "Booking time must be in the future.";
        }

        // Check for overlapping blocks
        for (int i = 0; i < validBlocks.Count; i++)
        {
            for (int j = i + 1; j < validBlocks.Count; j++)
            {
                if (BlocksOverlap(validBlocks[i], validBlocks[j]))
                    return $"Time blocks #{validBlocks[i].Id} and #{validBlocks[j].Id} overlap. Please adjust the times.";
            }
        }

        return null;
    }

    private bool BlocksOverlap(TimeBlock a, TimeBlock b)
    {
        return a.StartTime < b.EndTime && a.EndTime > b.StartTime;
    }

    private void ResetForm()
    {
        _bookingForm = new BookingForm();
        _timeBlocks = new List<TimeBlock> { new TimeBlock { Id = 1 } };
        _nextBlockId = 2;
        _totalPrice = 0m;
        _blockPrices.Clear();
        _scheduleError = null;
    }

    // ── Helper Methods ─────────────────────────────────────────────────────
    private async Task<int?> ResolveCurrentTrainerIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true)
            return null;

        var identityId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrWhiteSpace(identityId))
            return null;

        var trainer = await Api.GetTrainerByIdentity(identityId);
        return trainer?.Id;
    }

    // ── Inner Types ────────────────────────────────────────────────────────
    private class BookingForm
    {
        public string Purpose { get; set; } = "GroupClass";
        public string? PurposeDescription { get; set; }
        public string Modality { get; set; } = string.Empty;
        public string? Notes { get; set; }
    }

    private class TimeBlock
    {
        public int Id { get; set; }
        public TimeOnly? StartTime { get; set; }
        public TimeOnly? EndTime { get; set; }

        public bool IsValid() => StartTime.HasValue && EndTime.HasValue && EndTime > StartTime;
    }
}
