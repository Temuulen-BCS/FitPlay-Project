@code {
    // ── Page state ─────────────────────────────────────────────────────────
    private readonly Dictionary<string, List<ApiClient.RoomRead>> _roomsByLocation = new();
    private readonly Dictionary<int, ApiClient.RoomAvailability> _availability = new();
    private bool _loading = true;
    private string? _error;
    private DateTime _selectedDate = DateTime.UtcNow.Date;

    // ── Modal state ─────────────────────────────────────────────────────────
    private bool _showModal;
    private ApiClient.RoomRead? _modalRoom;
    private string? _modalLocation;
    private bool _scheduling;
    private string? _scheduleError;
    private string? _scheduleSuccess;
    private BookingForm _bookingForm = new();
    private List<TimeBlock> _timeBlocks = new();
    private decimal _totalPrice;
    private readonly Dictionary<int, decimal> _blockPrices = new();

    // ── Trainer context ─────────────────────────────────────────────────────
    private int? _currentTrainerId;

    // ── Lifecycle ───────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _currentTrainerId = await ResolveCurrentTrainerIdAsync();
        await Load();
    }

    // ── Data loading ────────────────────────────────────────────────────────
    private async Task Load()
    {
        _loading = true;
        _error = null;
        _roomsByLocation.Clear();
        _availability.Clear();

        try
        {
            var gyms = await Api.GetGyms(true);
            var date = DateOnly.FromDateTime(_selectedDate);

            foreach (var gym in gyms)
            {
                var locations = await Api.GetGymLocations(gym.Id, true);
                foreach (var location in locations)
                {
                    var rooms = await Api.GetRoomsByLocation(location.Id, true);
                    if (!rooms.Any()) continue;

                    var key = $"{gym.Name} - {location.Name}";
                    _roomsByLocation[key] = rooms;

                    foreach (var room in rooms)
                    {
                        var av = await Api.GetRoomAvailability(room.Id, date);
                        if (av is not null)
                            _availability[room.Id] = av;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Operating hours helpers ─────────────────────────────────────────────
    private ApiClient.RoomOperatingHoursDto? GetOperatingHoursForSelectedDay(ApiClient.RoomRead room)
    {
        var day = _selectedDate.DayOfWeek;
        return room.OperatingHours?.FirstOrDefault(h => h.DayOfWeek == day);
    }

    private bool IsClosedToday(ApiClient.RoomRead room)
    {
        var oh = GetOperatingHoursForSelectedDay(room);
        return oh is null || oh.IsClosed;
    }

    // ── Availability clipping (UTC slots → operating-hours window) ──────────
    private List<ApiClient.AvailabilitySlot> GetClippedSlots(ApiClient.RoomRead room)
    {
        if (!_availability.TryGetValue(room.Id, out var av)) return new();

        var oh = GetOperatingHoursForSelectedDay(room);
        if (oh is null || oh.IsClosed || oh.OpenTime is null || oh.CloseTime is null)
            return new();

        // Convert operating hours to UTC for comparison
        var openLocal  = new DateTime(_selectedDate.Year, _selectedDate.Month, _selectedDate.Day,
                                      oh.OpenTime.Value.Hour, oh.OpenTime.Value.Minute, 0, DateTimeKind.Local);
        var closeLocal = new DateTime(_selectedDate.Year, _selectedDate.Month, _selectedDate.Day,
                                      oh.CloseTime.Value.Hour, oh.CloseTime.Value.Minute, 0, DateTimeKind.Local);
        var windowStart = openLocal.ToUniversalTime();
        var windowEnd   = closeLocal.ToUniversalTime();

        var result = new List<ApiClient.AvailabilitySlot>();
        foreach (var slot in av.Slots)
        {
            if (slot.EndTime <= windowStart || slot.StartTime >= windowEnd) continue;
            var clippedStart = slot.StartTime < windowStart ? windowStart : slot.StartTime;
            var clippedEnd   = slot.EndTime   > windowEnd   ? windowEnd   : slot.EndTime;
            if (clippedEnd > clippedStart)
                result.Add(slot with { StartTime = clippedStart, EndTime = clippedEnd });
        }
        return result;
    }

    // ── Card helpers ────────────────────────────────────────────────────────
    private double GetAvailableHoursInWindow(ApiClient.RoomRead room)
    {
        return GetClippedSlots(room)
            .Where(s => s.IsAvailable)
            .Sum(s => (s.EndTime - s.StartTime).TotalHours);
    }

    private bool IsFullyBookedWithinHours(ApiClient.RoomRead room)
        => GetAvailableHoursInWindow(room) <= 0;

    // ── Modal open / close ──────────────────────────────────────────────────
    private void TryOpenModal(ApiClient.RoomRead room, string location)
    {
        _modalRoom     = room;
        _modalLocation = location;
        _scheduleError   = null;
        _scheduleSuccess = null;
        _bookingForm    = new BookingForm();
        _timeBlocks     = new List<TimeBlock> { new TimeBlock() };
        _totalPrice     = 0;
        _blockPrices.Clear();

        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal        = false;
        _scheduleError    = null;
        _scheduleSuccess  = null;
    }

    // ── Time Block Management ───────────────────────────────────────────────
    private void AddTimeBlock()
    {
        _timeBlocks.Add(new TimeBlock());
        StateHasChanged();
    }

    private void RemoveTimeBlock(int id)
    {
        var block = _timeBlocks.FirstOrDefault(b => b.Id == id);
        if (block != null)
        {
            _timeBlocks.Remove(block);
            _blockPrices.Remove(id);
            RecalculateTotalPrice();
        }
    }

    // ── Available Times (Hour-by-Hour) ──────────────────────────────────────
    private List<string> GetAvailableStartTimes()
    {
        if (_modalRoom is null) return new();
        
        var clipped = GetClippedSlots(_modalRoom);
        var availableSlots = clipped.Where(s => s.IsAvailable).ToList();
        if (!availableSlots.Any()) return new();

        var hours = new HashSet<string>();
        foreach (var slot in availableSlots)
        {
            var start = slot.StartTime.ToLocalTime();
            var end = slot.EndTime.ToLocalTime();
            
            // Add hourly increments within the slot
            var current = new DateTime(start.Year, start.Month, start.Day, start.Hour, 0, 0);
            while (current < end)
            {
                if (current >= start)
                    hours.Add(current.ToString("HH:mm"));
                current = current.AddHours(1);
            }
        }

        return hours.OrderBy(h => h).ToList();
    }

    private List<string> GetAvailableEndTimes(string? startTime)
    {
        if (_modalRoom is null || string.IsNullOrEmpty(startTime)) return new();
        
        if (!TimeOnly.TryParse(startTime, out var startTimeOnly)) return new();

        var clipped = GetClippedSlots(_modalRoom);
        var availableSlots = clipped.Where(s => s.IsAvailable).ToList();
        if (!availableSlots.Any()) return new();

        var hours = new HashSet<string>();
        
        // Find which slot contains this start time
        var startLocal = new DateTime(_selectedDate.Year, _selectedDate.Month, _selectedDate.Day, 
                                      startTimeOnly.Hour, startTimeOnly.Minute, 0, DateTimeKind.Local);
        var startUtc = startLocal.ToUniversalTime();

        foreach (var slot in availableSlots)
        {
            if (startUtc >= slot.StartTime && startUtc < slot.EndTime)
            {
                // Add hourly increments from start+1 to slot end
                var current = startLocal.AddHours(1);
                var endLocal = slot.EndTime.ToLocalTime();
                
                while (current <= endLocal)
                {
                    hours.Add(current.ToString("HH:mm"));
                    current = current.AddHours(1);
                }
            }
        }

        return hours.OrderBy(h => h).ToList();
    }

    // ── Price Calculation ───────────────────────────────────────────────────
    private void RecalculateTotalPrice()
    {
        if (_modalRoom is null)
        {
            _totalPrice = 0;
            return;
        }

        _totalPrice = 0;
        _blockPrices.Clear();

        foreach (var block in _timeBlocks)
        {
            if (!block.IsValid()) continue;

            var hours = CalculateHours(block.StartTime, block.EndTime);
            var price = hours * _modalRoom.PricePerHour;
            _blockPrices[block.Id] = price;
            _totalPrice += price;
        }

        StateHasChanged();
    }

    private decimal CalculateHours(string? startTime, string? endTime)
    {
        if (string.IsNullOrEmpty(startTime) || string.IsNullOrEmpty(endTime)) return 0;
        if (!TimeOnly.TryParse(startTime, out var start) || !TimeOnly.TryParse(endTime, out var end)) return 0;
        
        var startMinutes = start.Hour * 60 + start.Minute;
        var endMinutes = end.Hour * 60 + end.Minute;
        var durationMinutes = endMinutes - startMinutes;
        
        return durationMinutes > 0 ? (decimal)durationMinutes / 60m : 0;
    }

    // ── Validation ──────────────────────────────────────────────────────────
    private bool BlocksOverlap(TimeBlock a, TimeBlock b)
    {
        if (!a.IsValid() || !b.IsValid()) return false;
        if (!TimeOnly.TryParse(a.StartTime, out var aStart) || !TimeOnly.TryParse(a.EndTime, out var aEnd)) return false;
        if (!TimeOnly.TryParse(b.StartTime, out var bStart) || !TimeOnly.TryParse(b.EndTime, out var bEnd)) return false;

        return aStart < bEnd && aEnd > bStart;
    }

    private string? ValidateBookingForm()
    {

        if (string.IsNullOrWhiteSpace(_bookingForm.Modality))
            return "Please select a class modality.";

        if (!_bookingForm.PricePerStudent.HasValue || _bookingForm.PricePerStudent.Value <= 0)
            return "Please enter a valid price per student.";

        if (!_timeBlocks.Any(b => b.IsValid()))
            return "Please add at least one valid time block.";

        // Check for overlaps
        for (int i = 0; i < _timeBlocks.Count; i++)
        {
            for (int j = i + 1; j < _timeBlocks.Count; j++)
            {
                if (BlocksOverlap(_timeBlocks[i], _timeBlocks[j]))
                    return "Time blocks cannot overlap.";
            }
        }

        // Validate times are in the future
        foreach (var block in _timeBlocks.Where(b => b.IsValid()))
        {
            var startUtc = CombineDateAndTime(_selectedDate, block.StartTime!);
            if (startUtc <= DateTime.UtcNow)
                return "All booking times must be in the future.";
        }

        if (_currentTrainerId is null)
            return "Trainer profile not found. Please sign in again.";

        return null;
    }

    // ── Booking & Schedule Creation ─────────────────────────────────────────
    private async Task CreateBookingAndSchedule()
    {
        _scheduleError = null;

        var validationError = ValidateBookingForm();
        if (validationError != null)
        {
            _scheduleError = validationError;
            return;
        }

        if (_modalRoom is null || _currentTrainerId is null) return;

        _scheduling = true;
        var createdBookingIds = new List<int>();

        try
        {
            // Step 1: Create room bookings for each time block
            foreach (var block in _timeBlocks.Where(b => b.IsValid()))
            {
                var startUtc = CombineDateAndTime(_selectedDate, block.StartTime!);
                var endUtc = CombineDateAndTime(_selectedDate, block.EndTime!);

                var bookingBody = new ApiClient.CreateRoomBookingBody(
                   
                    StartTime: startUtc,
                    EndTime: endUtc,
                    Notes: $"Class: {_bookingForm.Modality}"
                );

                var booking = await Api.CreateRoomBooking(_modalRoom.Id, bookingBody);
                if (booking?.Id != null)
                    createdBookingIds.Add(booking.Id);
            }

            if (!createdBookingIds.Any())
            {
                _scheduleError = "Failed to create room bookings.";
                return;
            }

            // Step 2: Create class schedule linked to the first booking
            var firstBlock = _timeBlocks.First(b => b.IsValid());
            var scheduledAt = CombineDateAndTime(_selectedDate, firstBlock.StartTime!);
            var notes = BuildNotesWithMultipleBookings(
                createdBookingIds,
                _bookingForm.PricePerStudent!.Value,
                _bookingForm.Notes);

            await Api.CreateTrainerClassSchedule(
                _currentTrainerId.Value,
                _bookingForm.Modality!.Trim(),
                scheduledAt,
                notes
            );

            var totalHours = _timeBlocks.Where(b => b.IsValid()).Sum(b => (double)CalculateHours(b.StartTime, b.EndTime));
            _scheduleSuccess = $"✓ Room booked for {totalHours:F1}h and class scheduled at {scheduledAt.ToLocalTime():dd MMM yyyy HH:mm}. Price per student: {_bookingForm.PricePerStudent.Value.ToString("C")}";
        }
        catch (Exception ex)
        {
            _scheduleError = $"Error: {ex.Message}";
            
            // Rollback: Cancel all created bookings
            foreach (var bookingId in createdBookingIds)
            {
                try
                {
                    await Api.CancelRoomBooking(bookingId);
                }
                catch
                {
                    // Ignore rollback errors
                }
            }
        }
        finally
        {
            _scheduling = false;
        }
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    private DateTime CombineDateAndTime(DateTime date, string time)
    {
        if (!TimeOnly.TryParse(time, out var timeOnly))
            throw new ArgumentException("Invalid time format");

        var local = new DateTime(date.Year, date.Month, date.Day, timeOnly.Hour, timeOnly.Minute, 0, DateTimeKind.Local);
        return local.ToUniversalTime();
    }

    private string BuildNotesWithMultipleBookings(List<int> bookingIds, decimal pricePerStudent, string? additionalNotes)
    {
        var parts = new List<string>();
        
        parts.Add($"Room Bookings: {string.Join(", ", bookingIds.Select(id => $"#{id}"))}");
        parts.Add($"PricePerStudent={pricePerStudent.ToString("0.00", CultureInfo.InvariantCulture)}");
        
        var totalBlocks = _timeBlocks.Count(b => b.IsValid());
        parts.Add($"{totalBlocks} time block{(totalBlocks != 1 ? "s" : "")}");

        if (!string.IsNullOrWhiteSpace(additionalNotes))
            parts.Add(additionalNotes.Trim());

        return string.Join(" | ", parts);
    }

    // ── Trainer identity ────────────────────────────────────────────────────
    private async Task<int?> ResolveCurrentTrainerIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true) return null;

        var identityId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrWhiteSpace(identityId)) return null;

        var trainer = await Api.GetTrainerByIdentity(identityId);
        return trainer?.Id;
    }

    // ── Inner types ─────────────────────────────────────────────────────────
    private class TimeBlock
    {
        private static int _nextId = 1;
        
        public int Id { get; }
        public string? StartTime { get; set; }
        public string? EndTime { get; set; }

        public TimeBlock()
        {
            Id = _nextId++;
        }

        public bool IsValid() => !string.IsNullOrEmpty(StartTime) && !string.IsNullOrEmpty(EndTime);
    }

    private class BookingForm
    {
  
        public string? Modality { get; set; }
        public decimal? PricePerStudent { get; set; }
        public string? Notes { get; set; }
    }
}
