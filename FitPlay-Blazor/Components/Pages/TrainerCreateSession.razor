@page "/trainer/sessions/create"
@attribute [Authorize(Roles = "Trainer")]
@layout TrainerLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using FitPlay.Blazor.Services
@inject ApiClient Api

<PageTitle>Create Session - FitPlay</PageTitle>

<div class="page-wrap">
    <h1>Create Class Session</h1>

    <div class="form-grid">
        <input type="number" min="1" @bind="_bookingId" placeholder="Room Booking ID" />
        <input @bind="_title" placeholder="Session title" />
        <textarea @bind="_description" placeholder="Description"></textarea>
        <input type="number" min="1" @bind="_maxStudents" placeholder="Max students" />
        <input type="number" min="1" step="0.01" @bind="_pricePerStudent" placeholder="Price per student" />
        <input type="datetime-local" @bind="_start" />
        <input type="datetime-local" @bind="_end" />
        <button @onclick="Submit" disabled="@_loading">@(_loading ? "Saving..." : "Create Session")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <p class="ok">@_message</p>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="error">@_error</p>
    }
</div>

@code {
    private int _bookingId;
    private string _title = string.Empty;
    private string? _description;
    private int _maxStudents = 10;
    private decimal _pricePerStudent = 20m;
    private DateTime _start = DateTime.Now.AddHours(2);
    private DateTime _end = DateTime.Now.AddHours(3);

    private bool _loading;
    private string? _message;
    private string? _error;

    private async Task Submit()
    {
        _loading = true;
        _message = null;
        _error = null;

        try
        {
            var body = new ApiClient.CreateClassSessionBody(
                _title,
                _description,
                _maxStudents,
                _pricePerStudent,
                _start.ToUniversalTime(),
                _end.ToUniversalTime());

            var result = await Api.CreateSessionFromBooking(_bookingId, body);
            _message = result is null ? "Session created." : $"Session #{result.Id} created.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}

<style>
    .page-wrap { max-width: 860px; margin: 0 auto; padding: 24px; }
    .form-grid { display: grid; gap: 10px; }
    input,textarea,button { padding: 10px; border-radius: 10px; border: 1px solid var(--glass-border); background: rgba(255,255,255,.06); color: var(--text-primary); }
    textarea { min-height: 90px; }
    button { background: linear-gradient(135deg, var(--accent-teal), var(--accent-magenta)); border: none; color: #fff; font-weight: 700; }
    .ok { color: #7dff8e; }
    .error { color: #ff9aa2; }
</style>

