@page "/gym/dashboard"
@attribute [Authorize(Roles = "GymAdmin")]
@layout GymAdminLayout

@using Microsoft.AspNetCore.Authorization
@using FitPlay_Blazor.Components.Layout
@using FitPlay.Blazor.Services

@implements IDisposable
@inject ApiClient Api
@inject IJSRuntime JS

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<PageTitle>Dashboard - FitPlay Gym</PageTitle>

<div class="gym-page">
    @if (_loading)
    {
        <div class="gym-loading">
            <div class="loading-spinner"></div>
            <p>Loading your gym operations...</p>
        </div>
    }
    else
    {
        <div class="page-header">
            <div>
                <p class="page-eyebrow">Gym Partner</p>
                <h1 class="page-title">@(_gym?.Name ?? "My Gym")</h1>
                <p class="page-sub">@DateTime.Now.ToString("dddd, dd MMM yyyy")</p>
            </div>
        </div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-label">Active Trainers</span>
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3B6FE8" stroke-width="2"><circle cx="9" cy="7" r="3"/><path d="M2 20v-2a5 5 0 0110 0v2"/><path d="M20 20v-2a4 4 0 00-5-3.87"/><path d="M15 5a3 3 0 010 6"/></svg>
                    </div>
                </div>
                <div class="stat-value">@_trainerCount</div>
                <div class="stat-sub">@_pendingTrainerCount pending approval</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-label">Available Rooms</span>
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3B6FE8" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M3 9h6M3 15h6"/></svg>
                    </div>
                </div>
                <div class="stat-value">@_roomCount</div>
                <div class="stat-sub">across @_locationCount locations</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-label">Total Revenue</span>
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    </div>
                </div>
                <div class="stat-value">@_estRevenue.ToString("C0")</div>
                <div class="stat-sub">From @_sessionCount sessions this month</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-label">Active Locations</span>
                    <div class="stat-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#A855F7" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                </div>
                <div class="stat-value">@_locations.Count(l => l.IsActive)</div>
                <div class="stat-sub">@_locationCount total locations</div>
            </div>
        </div>

        <div class="charts-row">
            <div class="card">
                <div class="card-title">Revenue Trend (Last 7 Days)</div>
                <div class="chart-wrap">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
            <div class="card">
                <div class="card-title">Sessions by Status</div>
                <div class="chart-wrap">
                    <canvas id="bookingsChart"></canvas>
                </div>
            </div>
        </div>

        <div class="bottom-row">
            <div class="card">
                <div class="card-title">Today's Sessions</div>
                @if (_bookingRows.Count == 0)
                {
                    <p class="muted">No sessions scheduled today.</p>
                }
                else
                {
                    <div class="booking-list">
                        @foreach (var row in _bookingRows)
                        {
                            <div class="booking-item">
                                <div class="booking-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                </div>
                                <div class="booking-info">
                                    <div class="booking-name">@row.Name</div>
                                    <div class="booking-meta">@row.Trainer &bull; @row.TimeRange</div>
                                </div>
                                <div class="booking-stats">
                                                    <div class="booking-students">@row.Students / @row.MaxStudents enrolled</div>
                                    <div class="booking-revenue">@row.Revenue.ToString("C0")</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card">
                <div class="card-title">Room Occupancy</div>
                <div class="donut-wrap">
                    <div class="donut-chart-wrap">
                        <canvas id="occupancyChart"></canvas>
                    </div>
                    <div class="donut-legend">
                        <div class="legend-item">
                            <div class="legend-dot" style="background:#3B6FE8"></div>
                            <span class="legend-label">In Use</span>
                            <span class="legend-val">@_occupiedPct%</span>
                        </div>
                        <div class="legend-item">
                            <div class="legend-dot" style="background:#E2E8F0"></div>
                            <span class="legend-label">Available</span>
                            <span class="legend-val">@_availablePct%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (_pendingTrainerCount > 0)
        {
            <div class="alert-banner">
                <div class="alert-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div>
                    <div class="alert-title">You have @_pendingTrainerCount trainers pending approval</div>
                    <div class="alert-sub">Review and approve new trainer applications</div>
                </div>
                <a href="/gym/trainers" class="alert-action">Review &rarr;</a>
            </div>
        }
    }
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="gym-toast error">@_error</div>
}

@code {
    private bool _loading = true;
    private bool _chartsInitialized;
    private string? _error;

    private ApiClient.GymRead? _gym;
    private List<ApiClient.GymLocationRead> _locations = new();
    private List<ApiClient.TrainerLinkRead> _trainerLinks = new();
    private List<ApiClient.ClassSessionRead> _sessions = new();
    private List<BookingRow> _bookingRows = new();
    private Dictionary<string, string> _trainerNameById = new();
    private int _locationCount;
    private int _roomCount;
    private int _trainerCount;
    private int _pendingTrainerCount;
    private int _sessionCount;
    private decimal _estRevenue;
    private double _occupiedPct;
    private double _availablePct;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _gym = await Api.GetMyGym();

            if (_gym != null)
            {
                _locations = await Api.GetGymLocations(_gym.Id);
                _locationCount = _locations.Count;

                _trainerLinks = await Api.GetGymTrainerLinks(_gym.Id);
                _trainerCount = _trainerLinks.Count(t => t.Status == "Approved");
                _pendingTrainerCount = _trainerLinks.Count(t => t.Status == "Pending");

                // Build trainer name lookup: TrainerId string → display name
                _trainerNameById = _trainerLinks
                    .Where(t => !string.IsNullOrEmpty(t.TrainerId))
                    .ToDictionary(t => t.TrainerId, t => t.TrainerName, StringComparer.OrdinalIgnoreCase);

                var roomTotal = 0;
                foreach (var loc in _locations)
                {
                    var rooms = await Api.GetRoomsByLocation(loc.Id);
                    roomTotal += rooms.Count;
                }
                _roomCount = roomTotal;

                // Load sessions: from the earlier of (month start, 6 days ago) to end of month
                // so we cover both the 7-day revenue trend and the full month stats in one call.
                var now = DateTime.UtcNow;
                var monthStart = new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc);
                var trendStart = now.Date.AddDays(-6);
                var loadFrom = monthStart < trendStart ? monthStart : trendStart;
                var loadTo = monthStart.AddMonths(1);
                _sessions = await Api.GetGymSessions(_gym.Id, loadFrom, loadTo);

                // Session count for this month only
                _sessionCount = _sessions.Count(s => s.StartTime >= monthStart);

                // Real revenue: PricePerStudent × EnrolledStudents, non-cancelled, this month
                _estRevenue = _sessions
                    .Where(s => s.StartTime >= monthStart && s.Status != "Cancelled")
                    .Sum(s => s.PricePerStudent * s.EnrolledStudents);

                BuildBookingsList();

                // Occupancy: sessions active RIGHT NOW vs total rooms
                var activeNow = _sessions.Count(s => s.StartTime <= now && s.EndTime >= now);
                _occupiedPct = _roomCount > 0
                    ? Math.Min(100.0, Math.Round((double)activeNow / _roomCount * 100.0, 1))
                    : 0;
                _availablePct = Math.Max(0.0, Math.Round(100.0 - _occupiedPct, 1));
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartsInitialized || _loading || _gym == null) return;

        _chartsInitialized = true;

        var chartData = new
        {
            Revenue = BuildRevenueSeries(),
            Bookings = BuildStatusSeries(),
            Occupancy = BuildOccupancySeries()
        };

        try
        {
            await JS.InvokeVoidAsync("gymDash.init", chartData);
        }
        catch
        {
            // ignore chart init failures; UI still works without charts
        }
    }

    // Real 7-day revenue: group sessions by date, sum price × enrolled
    private object BuildRevenueSeries()
    {
        var labels = Enumerable.Range(0, 7)
            .Select(i => DateTime.UtcNow.Date.AddDays(-6 + i).ToString("MMM d"))
            .ToArray();

        var data = Enumerable.Range(0, 7)
            .Select(i =>
            {
                var day = DateTime.UtcNow.Date.AddDays(-6 + i);
                return (double)_sessions
                    .Where(s => s.StartTime.Date == day && s.Status != "Cancelled")
                    .Sum(s => s.PricePerStudent * s.EnrolledStudents);
            })
            .ToArray();

        return new { Labels = labels, Data = data };
    }

    // Real sessions grouped by status (replaces fake "Bookings by Room Type")
    private object BuildStatusSeries()
    {
        var statuses = new[] { "Scheduled", "Ongoing", "Completed", "Cancelled" };
        var data = statuses
            .Select(st => _sessions.Count(s => string.Equals(s.Status, st, StringComparison.OrdinalIgnoreCase)))
            .ToArray();
        return new { Labels = statuses, Data = data };
    }

    private object BuildOccupancySeries()
    {
        return new { Labels = new[] { "In Use", "Available" }, Data = new[] { _occupiedPct, _availablePct } };
    }

    // Real today's sessions instead of hardcoded fake rows
    private void BuildBookingsList()
    {
        _bookingRows.Clear();
        var today = DateTime.UtcNow.Date;
        var todaySessions = _sessions
            .Where(s => s.StartTime.Date == today)
            .OrderBy(s => s.StartTime)
            .Take(6)
            .ToList();

        foreach (var s in todaySessions)
        {
            // Prefer the TrainerName already returned by the API;
            // fall back to the trainer-link dictionary, then to a truncated ID.
            var trainerName = s.TrainerName;
            if (string.IsNullOrWhiteSpace(trainerName))
                _trainerNameById.TryGetValue(s.TrainerId, out trainerName);

            _bookingRows.Add(new BookingRow
            {
                Name = s.Title,
                Trainer = trainerName ?? TruncateId(s.TrainerId),
                TimeRange = $"{s.StartTime:HH:mm} – {s.EndTime:HH:mm}",
                Students = s.EnrolledStudents,
                MaxStudents = s.MaxStudents,
                Revenue = s.PricePerStudent * s.EnrolledStudents
            });
        }
    }

    private static string TruncateId(string? id)
    {
        if (string.IsNullOrWhiteSpace(id)) return "Unknown";
        return id.Length > 8 ? id[..8] + "…" : id;
    }

    private class BookingRow
    {
        public string Name { get; set; } = string.Empty;
        public string Trainer { get; set; } = string.Empty;
        public string TimeRange { get; set; } = string.Empty;
        public int Students { get; set; }
        public int MaxStudents { get; set; }
        public decimal Revenue { get; set; }
    }

    public void Dispose()
    {
        try
        {
            _ = JS.InvokeVoidAsync("gymDash.dispose");
        }
        catch
        {
            // JS interop may fail if the circuit is already gone
        }
    }
}

<style>
    .gym-page {
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
        background: #F4F7FB;
        color: #0F172A;
        width: 100%;
        box-sizing: border-box;
        padding: 2.5rem 1.5rem 4rem;
    }

    /* ── PAGE HEADER ── */
    .page-header { margin-bottom: 28px; }
    .page-eyebrow { margin: 0 0 4px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.18em; color: #3B6FE8; font-weight: 600; }
    .page-title { font-size: 30px; font-weight: 700; letter-spacing: -0.5px; margin: 0; }
    .page-sub { margin-top: 4px; color: #64748B; font-size: 14px; }

    /* ── STAT CARDS ── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 22px 24px;
    }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
    }

    .stat-label { font-size: 13px; font-weight: 500; color: #64748B; }
    .stat-icon { width: 32px; height: 32px; display: grid; place-items: center; }
    .stat-value { font-size: 32px; font-weight: 700; letter-spacing: -1px; line-height: 1; margin-bottom: 6px; }
    .stat-sub { font-size: 12px; color: #64748B; }

    /* ── CHARTS ROW ── */
    .charts-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 24px;
    }

    .card {
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 24px;
    }

    .card-title { font-size: 15px; font-weight: 600; margin-bottom: 20px; }

    .chart-wrap { position: relative; height: 220px; }

    /* ── BOTTOM ROW ── */
    .bottom-row {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 16px;
        margin-bottom: 24px;
    }

    .booking-list { display: flex; flex-direction: column; gap: 10px; }

    .booking-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        background: #F8FAFC;
        border-radius: 10px;
    }

    .booking-icon {
        width: 36px; height: 36px;
        background: #EEF3FD;
        border-radius: 8px;
        display: grid; place-items: center;
        flex-shrink: 0;
        color: #3B6FE8;
    }

    .booking-icon svg { width: 16px; height: 16px; }
    .booking-info { flex: 1; }
    .booking-name { font-weight: 600; font-size: 13.5px; }
    .booking-meta { font-size: 12px; color: #64748B; margin-top: 2px; }
    .booking-stats { text-align: right; }
    .booking-students { font-weight: 600; font-size: 13.5px; }
    .booking-revenue { font-size: 12px; color: #64748B; margin-top: 2px; }

    /* ── DONUT / OCCUPANCY ── */
    .donut-wrap { display: flex; flex-direction: column; align-items: center; gap: 20px; }
    .donut-chart-wrap { position: relative; width: 160px; height: 160px; }
    .donut-legend { display: flex; flex-direction: column; gap: 8px; width: 100%; }
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 13px; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .legend-label { flex: 1; color: #64748B; }
    .legend-val { font-weight: 600; }

    /* ── ALERT BANNER ── */
    .alert-banner {
        background: #EEF3FD;
        border: 1px solid #C7D9F8;
        border-radius: 12px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .alert-icon {
        width: 36px; height: 36px;
        background: #D5E5FF;
        border-radius: 50%;
        display: grid; place-items: center;
        flex-shrink: 0;
        color: #3B6FE8;
    }

    .alert-icon svg { width: 18px; height: 18px; }
    .alert-title { font-weight: 600; font-size: 14px; }
    .alert-sub { font-size: 12px; color: #64748B; margin-top: 2px; }
    .alert-action { margin-left: auto; color: #3B6FE8; font-weight: 600; font-size: 13px; text-decoration: none; white-space: nowrap; }

    /* ── MISC ── */
    .muted { color: #94A3B8; font-size: 14px; margin: 0; }

    .gym-toast { position: fixed; right: 1.2rem; bottom: 1.2rem; background: #fff0f0; border: 1px solid #f2b8b8; color: #8f1d1d; border-radius: 12px; padding: 0.75rem 1rem; font-size: 0.85rem; box-shadow: 0 8px 24px rgba(120,18,18,0.16); z-index: 1000; }

    .gym-loading { min-height: 46vh; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 0.65rem; color: #64748B; }
    .loading-spinner { width: 38px; height: 38px; border-radius: 50%; border: 3px solid rgba(59,111,232,0.2); border-top-color: #3B6FE8; animation: spin 0.9s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ── RESPONSIVE ── */
    @@media (max-width: 640px) {
        .stat-grid { grid-template-columns: 1fr; }
    }
    @@media (min-width: 641px) and (max-width: 1200px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 900px) { .charts-row { grid-template-columns: 1fr; } .bottom-row { grid-template-columns: 1fr; } }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script src="js/gym-dashboard.js"></script>
