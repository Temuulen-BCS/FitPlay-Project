@page "/membership/success"
@rendermode InteractiveServer
@attribute [Authorize]
@layout EmptyLayout
@using FitPlay_Blazor.Components.Layout
@inject NavigationManager Navigation

<PageTitle>Membership Active - FitPlay</PageTitle>

<section class="success-shell">
    <div class="success-glow"></div>

    <div class="success-card">
        <div class="success-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5" />
            </svg>
        </div>

        <h1>You're all set!</h1>
        <p class="success-sub">Your FitPlay membership is now <strong>active</strong>. Unlock all trainings, track your progress, and start earning XP.</p>

        <div class="success-features">
            <div class="feat-item">
                <span class="pill">XP</span>
                <span>Earn XP with every workout</span>
            </div>
            <div class="feat-item">
                <span class="pill">PRO</span>
                <span>Access all premium trainings</span>
            </div>
            <div class="feat-item">
                <span class="pill">24/7</span>
                <span>Train any time, anywhere</span>
            </div>
        </div>

        <div class="success-actions">
            <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/user/trainings")'>
                Explore Trainings
            </button>
            <button class="btn-secondary" @onclick='() => Navigation.NavigateTo("/dashboard")'>
                Go to Dashboard
            </button>
        </div>
    </div>
</section>

<style>
    .success-shell {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
        background: radial-gradient(circle at 30% 20%, rgba(76, 175, 80, 0.15), transparent 50%),
            radial-gradient(circle at 70% 80%, rgba(255, 196, 86, 0.12), transparent 50%),
            #0b0b0f;
        position: relative;
        overflow: hidden;
    }

    .success-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(76, 175, 80, 0.18), transparent 65%);
        filter: blur(80px);
        pointer-events: none;
    }

    .success-card {
        position: relative;
        z-index: 1;
        background: rgba(17, 19, 27, 0.92);
        border: 1px solid rgba(76, 175, 80, 0.3);
        border-radius: 28px;
        padding: 48px 40px;
        max-width: 520px;
        width: 100%;
        text-align: center;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(76, 175, 80, 0.1);
        color: #f5f7ff;
    }

    .success-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(76, 175, 80, 0.2);
        border: 2px solid rgba(76, 175, 80, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 28px;
        color: #4caf50;
    }

    .success-icon svg {
        width: 36px;
        height: 36px;
    }

    .success-card h1 {
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        margin: 0 0 14px;
        background: linear-gradient(135deg, #a8e6ab, #4caf50);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .success-sub {
        font-size: 1rem;
        color: rgba(245, 247, 255, 0.7);
        line-height: 1.6;
        margin: 0 0 32px;
    }

    .success-sub strong {
        color: #a8e6ab;
        -webkit-text-fill-color: #a8e6ab;
    }

    .success-features {
        display: grid;
        gap: 12px;
        margin-bottom: 36px;
        text-align: left;
    }

    .feat-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: rgba(245, 247, 255, 0.75);
        font-size: 0.95rem;
    }

    .pill {
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        color: #ffb703;
        font-weight: 600;
        font-size: 0.72rem;
        white-space: nowrap;
    }

    .success-actions {
        display: grid;
        gap: 12px;
    }

    .btn-primary {
        width: 100%;
        padding: 14px 16px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #4caf50, #66bb6a);
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(76, 175, 80, 0.35);
    }

    .btn-secondary {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 12px;
        background: transparent;
        color: rgba(245, 247, 255, 0.7);
        font-weight: 500;
        font-size: 1rem;
        cursor: pointer;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .btn-secondary:hover {
        border-color: rgba(255, 255, 255, 0.3);
        color: #f5f7ff;
    }

    @@media (max-width: 600px) {
        .success-card {
            padding: 36px 24px;
        }
    }
</style>
