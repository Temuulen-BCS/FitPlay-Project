@page "/gym/sessions"
@attribute [Authorize(Roles = "GymAdmin")]
@layout GymAdminLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using FitPlay_Blazor.Components.Layout
@using FitPlay.Blazor.Services

@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Sessions - FitPlay Gym</PageTitle>

<div class="gym-page">

    <div class="page-header">
        <div>
            <p class="page-eyebrow">Gym Admin</p>
            <h1 class="page-title">Class Sessions</h1>
        </div>
        <div class="header-actions">
            <div class="filter-tabs">
                <button class="filter-tab @(_rangeMode == "week" ? "active" : "")" @onclick='() => SetRange("week")'>This Week</button>
                <button class="filter-tab @(_rangeMode == "month" ? "active" : "")" @onclick='() => SetRange("month")'>This Month</button>
                <button class="filter-tab @(_rangeMode == "all" ? "active" : "")" @onclick='() => SetRange("all")'>All</button>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="gym-loading">
            <div class="loading-spinner"></div>
            <p>Loading sessions...</p>
        </div>
    }
    else if (_gymId == null)
    {
        <div class="setup-prompt">
            <div class="setup-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h2>No Gym Registered</h2>
            <p>Register your gym first to manage sessions.</p>
            <a href="/gym/setup" class="btn-gym-primary btn-large">Register My Gym</a>
        </div>
    }
    else if (_sessions.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4M16 2v4"/><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18"/></svg>
            </div>
            <p>No sessions found for the selected period.</p>
        </div>
    }
    else
    {
        <!-- Summary chips -->
        <div class="summary-row">
            <div class="summary-chip">
                <span class="summary-num">@_sessions.Count</span>
                <span class="summary-label">Total</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num teal">@_sessions.Count(s => s.Status == "Active" || s.Status == "Scheduled")</span>
                <span class="summary-label">Active</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num amber">@_sessions.Count(s => s.Status == "Completed")</span>
                <span class="summary-label">Completed</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num muted">@_sessions.Count(s => s.Status == "Cancelled")</span>
                <span class="summary-label">Cancelled</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num magenta">@_sessions.Sum(s => s.EnrolledStudents)</span>
                <span class="summary-label">Enrollments</span>
            </div>
        </div>

        <!-- Sessions table -->
        <div class="panel">
            <div class="sessions-table-wrap">
                <table class="sessions-table">
                    <thead>
                        <tr>
                            <th>Session</th>
                            <th>Trainer</th>
                            <th>Date &amp; Time</th>
                            <th>Duration</th>
                            <th>Students</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _sessions.OrderBy(x => x.StartTime))
                        {
                            var duration = s.EndTime - s.StartTime;
                            <tr>
                                <td>
                                    <div class="session-title">@s.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(s.Description))
                                    {
                                        <div class="session-desc">@s.Description</div>
                                    }
                                </td>
                                <td>
                                    <div class="trainer-cell">
                                        <div class="trainer-avatar">@GetInitials(s.TrainerId)</div>
                                        <span class="trainer-id">@s.TrainerId</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="date-primary">@s.StartTime.ToString("MMM dd, yyyy")</div>
                                    <div class="date-time">@s.StartTime.ToString("HH:mm") – @s.EndTime.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    <span class="duration-chip">@FormatDuration(duration)</span>
                                </td>
                                <td>
                                    <div class="enrollment-bar-wrap">
                                        <div class="enrollment-text">
                                            <span class="enrollment-current @(s.EnrolledStudents >= s.MaxStudents ? "full" : "")">@s.EnrolledStudents</span>
                                            <span class="enrollment-sep">/</span>
                                            <span class="enrollment-max">@s.MaxStudents</span>
                                        </div>
                                        <div class="enrollment-bar">
                                            <div class="enrollment-fill @(s.EnrolledStudents >= s.MaxStudents ? "full" : "")"
                                                 style="width: @Math.Min(100, s.MaxStudents > 0 ? (int)((double)s.EnrolledStudents / s.MaxStudents * 100) : 0)%">
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="price-value">@s.PricePerStudent.ToString("C")</span>
                                </td>
                                <td>
                                    <span class="status-badge @GetStatusClass(s.Status)">@s.Status</span>
                                </td>
                                <td>
                                    @if (s.Status != "Cancelled" && s.Status != "Completed")
                                    {
                                        <button class="btn-cancel-session"
                                                @onclick="() => ConfirmCancel(s)"
                                                disabled="@(_cancellingId == s.Id)">
                                            @(_cancellingId == s.Id ? "..." : "Cancel")
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="gym-toast error">@_error</div>
}

@if (_confirmSession != null)
{
    <div class="modal-overlay" @onclick="CloseConfirm">
        <div class="modal-box" @onclick:stopPropagation>
            <h3 class="modal-title">Cancel Session</h3>
            <p class="modal-body">Are you sure you want to cancel <strong>@_confirmSession.Title</strong>?<br />Enrolled students will be notified.</p>
            <div class="modal-actions">
                <button class="btn-modal-ghost" @onclick="CloseConfirm">Keep</button>
                <button class="btn-modal-danger" @onclick="ExecuteCancel" disabled="@(_cancellingId.HasValue)">
                    @(_cancellingId.HasValue ? "Cancelling..." : "Yes, Cancel")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int? _gymId;
    private string _rangeMode = "month";
    private List<ApiClient.ClassSessionRead> _sessions = new();

    private ApiClient.ClassSessionRead? _confirmSession;
    private int? _cancellingId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var gym = await Api.GetMyGym();
            if (gym != null)
            {
                _gymId = gym.Id;
                await LoadSessions();
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not load data: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SetRange(string mode)
    {
        _rangeMode = mode;
        _loading = true;
        try { await LoadSessions(); }
        catch (Exception ex) { _error = $"Could not load sessions: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task LoadSessions()
    {
        if (_gymId == null) return;

        DateTime? from = null;
        DateTime? to = null;
        var now = DateTime.UtcNow;

        if (_rangeMode == "week")
        {
            from = now.Date.AddDays(-(int)now.DayOfWeek);
            to = from.Value.AddDays(7);
        }
        else if (_rangeMode == "month")
        {
            from = new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc);
            to = from.Value.AddMonths(1);
        }

        _sessions = await Api.GetGymSessions(_gymId.Value, from, to);
    }

    private static string GetInitials(string trainerId)
    {
        if (string.IsNullOrWhiteSpace(trainerId)) return "?";
        // If it looks like a GUID, just show first 2 chars uppercase
        return trainerId.Length >= 2 ? trainerId[..2].ToUpper() : trainerId.ToUpper();
    }

    private static string FormatDuration(TimeSpan span)
    {
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m";
        var h = (int)span.TotalHours;
        var m = span.Minutes;
        return m > 0 ? $"{h}h {m}m" : $"{h}h";
    }

    private static string GetStatusClass(string status) => status?.ToLower() switch
    {
        "active"    => "status-active",
        "scheduled" => "status-scheduled",
        "completed" => "status-completed",
        "cancelled" => "status-cancelled",
        _           => "status-unknown"
    };

    private void ConfirmCancel(ApiClient.ClassSessionRead session)
    {
        _confirmSession = session;
        _error = null;
    }

    private void CloseConfirm() => _confirmSession = null;

    private async Task ExecuteCancel()
    {
        if (_confirmSession is null) return;
        _cancellingId = _confirmSession.Id;
        try
        {
            await Api.CancelSession(_confirmSession.Id);
            // optimistically update local list
            var idx = _sessions.FindIndex(s => s.Id == _confirmSession.Id);
            if (idx >= 0)
            {
                var s = _sessions[idx];
                _sessions[idx] = s with { Status = "Cancelled" };
            }
            _confirmSession = null;
        }
        catch (Exception ex)
        {
            _error = $"Could not cancel session: {ex.Message}";
        }
        finally
        {
            _cancellingId = null;
        }
    }
}

<style>
    .gym-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
        color: var(--text-primary, #f8f9fb);
    }

    /* Loading */
    .gym-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 40vh;
        gap: 1rem;
        color: var(--text-muted, #9aa0b5);
    }
    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(14, 240, 255, 0.2);
        border-top-color: #0ef0ff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Setup prompt */
    .setup-prompt {
        max-width: 520px;
        margin: 6rem auto;
        text-align: center;
        padding: 3rem 2rem;
        background: rgba(14, 240, 255, 0.04);
        border: 1px solid rgba(14, 240, 255, 0.14);
        border-radius: 20px;
    }
    .setup-icon {
        width: 80px; height: 80px;
        background: rgba(14, 240, 255, 0.08);
        border: 1px solid rgba(14, 240, 255, 0.2);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        color: #0ef0ff;
    }
    .setup-prompt h2 { margin: 0 0 0.75rem; font-size: 1.6rem; }
    .setup-prompt p { color: var(--text-muted, #9aa0b5); margin-bottom: 2rem; }

    /* Empty */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 30vh;
        gap: 1rem;
        color: var(--text-muted, #9aa0b5);
        text-align: center;
    }
    .empty-icon {
        width: 70px; height: 70px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }

    /* Page header */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .page-eyebrow {
        margin: 0 0 4px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #0ef0ff;
    }
    .page-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
    }
    .header-actions { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }

    /* Filter tabs */
    .filter-tabs {
        display: flex;
        gap: 0.25rem;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 30px;
        padding: 3px;
    }
    .filter-tab {
        background: transparent;
        border: none;
        color: var(--text-muted, #9aa0b5);
        font-size: 0.82rem;
        font-weight: 500;
        font-family: inherit;
        padding: 0.4rem 1rem;
        border-radius: 26px;
        cursor: pointer;
        transition: background 0.18s, color 0.18s;
    }
    .filter-tab:hover { color: #f8f9fb; }
    .filter-tab.active { background: rgba(14,240,255,0.15); color: #0ef0ff; font-weight: 600; }

    /* Summary chips */
    .summary-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }
    .summary-chip {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 0.75rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        min-width: 80px;
    }
    .summary-num { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .summary-num.teal    { color: #0ef0ff; }
    .summary-num.amber   { color: #ffb400; }
    .summary-num.magenta { color: #ff2fb4; }
    .summary-num.muted   { color: var(--text-muted, #9aa0b5); }
    .summary-label { font-size: 0.75rem; color: var(--text-muted, #9aa0b5); }

    /* Panel */
    .panel {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        padding: 0;
        overflow: hidden;
    }

    /* Table */
    .sessions-table-wrap { overflow-x: auto; }
    .sessions-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }
    .sessions-table thead tr {
        background: rgba(255,255,255,0.03);
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .sessions-table th {
        padding: 0.875rem 1.25rem;
        text-align: left;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted, #9aa0b5);
        white-space: nowrap;
    }
    .sessions-table tbody tr {
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: background 0.15s;
    }
    .sessions-table tbody tr:last-child { border-bottom: none; }
    .sessions-table tbody tr:hover { background: rgba(14,240,255,0.04); }
    .sessions-table td {
        padding: 1rem 1.25rem;
        vertical-align: middle;
    }

    /* Session cell */
    .session-title { font-weight: 600; color: #f8f9fb; }
    .session-desc  { font-size: 0.78rem; color: var(--text-muted, #9aa0b5); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 220px; }

    /* Trainer cell */
    .trainer-cell { display: flex; align-items: center; gap: 0.625rem; }
    .trainer-avatar {
        width: 32px; height: 32px;
        background: rgba(14,240,255,0.1);
        border: 1px solid rgba(14,240,255,0.25);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        color: #0ef0ff;
        flex-shrink: 0;
    }
    .trainer-id { font-size: 0.8rem; color: var(--text-muted, #9aa0b5); font-family: monospace; }

    /* Date cell */
    .date-primary { font-weight: 500; }
    .date-time    { font-size: 0.8rem; color: var(--text-muted, #9aa0b5); margin-top: 1px; }

    /* Duration chip */
    .duration-chip {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    /* Enrollment */
    .enrollment-bar-wrap { min-width: 80px; }
    .enrollment-text { display: flex; align-items: baseline; gap: 1px; margin-bottom: 4px; font-size: 0.875rem; }
    .enrollment-current { font-weight: 700; }
    .enrollment-current.full { color: #ff2fb4; }
    .enrollment-sep { color: var(--text-muted, #9aa0b5); font-size: 0.78rem; }
    .enrollment-max { color: var(--text-muted, #9aa0b5); font-size: 0.78rem; }
    .enrollment-bar {
        height: 4px;
        background: rgba(255,255,255,0.08);
        border-radius: 4px;
        overflow: hidden;
    }
    .enrollment-fill {
        height: 100%;
        background: linear-gradient(90deg, #0ef0ff, #09c8d4);
        border-radius: 4px;
        transition: width 0.3s;
    }
    .enrollment-fill.full { background: linear-gradient(90deg, #ff2fb4, #c0106a); }

    /* Price */
    .price-value { font-weight: 600; color: #f8f9fb; }

    /* Status badges */
    .status-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 3px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }
    .status-active    { background: rgba(14,240,255,0.12); color: #0ef0ff; border: 1px solid rgba(14,240,255,0.3); }
    .status-scheduled { background: rgba(0,180,255,0.12);  color: #00b4ff; border: 1px solid rgba(0,180,255,0.3); }
    .status-completed { background: rgba(255,180,0,0.12);  color: #ffb400; border: 1px solid rgba(255,180,0,0.3); }
    .status-cancelled { background: rgba(255,255,255,0.06); color: var(--text-muted,#9aa0b5); border: 1px solid rgba(255,255,255,0.1); }
    .status-unknown   { background: rgba(255,255,255,0.06); color: var(--text-muted,#9aa0b5); border: 1px solid rgba(255,255,255,0.1); }

    /* Buttons */
    .btn-gym-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #0ef0ff, #09c8d4);
        color: #001e24;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.95rem;
        font-family: inherit;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 18px rgba(14,240,255,0.4);
    }
    .btn-gym-primary:hover { transform: scale(1.03); box-shadow: 0 6px 28px rgba(14,240,255,0.6); }
    .btn-gym-primary.btn-large { padding: 0.9rem 2rem; font-size: 1.05rem; }

    /* Toast */
    .gym-toast {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        padding: 0.875rem 1.5rem;
        border-radius: 12px;
        font-size: 0.9rem;
        z-index: 9000;
        backdrop-filter: blur(10px);
    }
    .gym-toast.error { background: rgba(255,47,180,0.15); border: 1px solid rgba(255,47,180,0.35); color: #ff2fb4; }

    /* Cancel button */
    .btn-cancel-session {
        background: transparent;
        border: 1px solid rgba(255,47,180,0.35);
        color: #ff2fb4;
        font-size: 0.75rem;
        font-weight: 600;
        font-family: inherit;
        padding: 4px 12px;
        border-radius: 20px;
        cursor: pointer;
        transition: background 0.18s, border-color 0.18s;
        white-space: nowrap;
    }
    .btn-cancel-session:hover { background: rgba(255,47,180,0.1); border-color: rgba(255,47,180,0.6); }
    .btn-cancel-session:disabled { opacity: 0.5; cursor: default; }

    /* Modal */
    .modal-overlay {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(4px);
        z-index: 9500;
        display: flex; align-items: center; justify-content: center;
    }
    .modal-box {
        background: #0d1117;
        border: 1px solid rgba(255,47,180,0.3);
        border-radius: 18px;
        padding: 2rem;
        max-width: 420px;
        width: 90%;
        box-shadow: 0 8px 40px rgba(255,47,180,0.15);
    }
    .modal-title { margin: 0 0 0.75rem; font-size: 1.3rem; font-weight: 700; color: #f8f9fb; }
    .modal-body  { margin: 0 0 1.75rem; color: var(--text-muted, #9aa0b5); line-height: 1.6; }
    .modal-body strong { color: #f8f9fb; }
    .modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; }
    .btn-modal-ghost {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.15);
        color: var(--text-muted, #9aa0b5);
        font-size: 0.9rem; font-weight: 600; font-family: inherit;
        padding: 0.6rem 1.4rem; border-radius: 30px; cursor: pointer;
        transition: border-color 0.18s, color 0.18s;
    }
    .btn-modal-ghost:hover { border-color: rgba(255,255,255,0.35); color: #f8f9fb; }
    .btn-modal-danger {
        background: linear-gradient(135deg, #ff2fb4, #c0106a);
        border: none;
        color: #fff;
        font-size: 0.9rem; font-weight: 700; font-family: inherit;
        padding: 0.6rem 1.4rem; border-radius: 30px; cursor: pointer;
        transition: transform 0.18s, box-shadow 0.18s;
        box-shadow: 0 4px 16px rgba(255,47,180,0.35);
    }
    .btn-modal-danger:hover { transform: scale(1.03); box-shadow: 0 6px 24px rgba(255,47,180,0.55); }
    .btn-modal-danger:disabled { opacity: 0.6; cursor: default; transform: none; }

    @@media (max-width: 768px) {
        .summary-row { gap: 0.5rem; }
        .summary-chip { min-width: 64px; padding: 0.625rem 0.875rem; }
        .sessions-table th, .sessions-table td { padding: 0.75rem 0.875rem; }
    }
</style>
