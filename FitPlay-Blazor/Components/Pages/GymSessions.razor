@page "/gym/sessions"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "GymAdmin")]
@layout GymAdminLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using FitPlay_Blazor.Components.Layout
@using FitPlay.Blazor.Services

@inject ApiClient Api
@inject NavigationManager Nav

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<PageTitle>Sessions - FitPlay Gym</PageTitle>

<div class="gym-page">

    <div class="page-header">
        <div>
            <p class="page-eyebrow">Gym Admin</p>
            <h1 class="page-title">Room Bookings</h1>
        </div>
        <div class="header-actions">
            <div class="filter-tabs">
                <button class="filter-tab @(_rangeMode == "week" ? "active" : "")" @onclick='() => SetRange("week")'>This Week</button>
                <button class="filter-tab @(_rangeMode == "month" ? "active" : "")" @onclick='() => SetRange("month")'>This Month</button>
                <button class="filter-tab @(_rangeMode == "all" ? "active" : "")" @onclick='() => SetRange("all")'>All</button>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="gym-loading">
            <div class="loading-spinner"></div>
            <p>Loading bookings...</p>
        </div>
    }
    else if (_gymId == null)
    {
        <div class="setup-prompt">
            <div class="setup-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h2>No Gym Registered</h2>
            <p>Register your gym first to manage bookings.</p>
            <a href="/gym/setup" class="btn-gym-primary btn-large">Register My Gym</a>
        </div>
    }
    else if (_bookings.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4M16 2v4"/><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18"/></svg>
            </div>
            <p>No bookings found for the selected period.</p>
        </div>
    }
    else
    {
        <!-- Summary chips -->
        <div class="summary-row">
            <div class="summary-chip">
                <span class="summary-num">@_bookings.Count</span>
                <span class="summary-label">Total</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num teal">@_bookings.Count(b => b.Status == "Confirmed")</span>
                <span class="summary-label">Confirmed</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num amber">@_bookings.Count(b => b.Status == "Pending")</span>
                <span class="summary-label">Pending</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num muted">@_bookings.Count(b => b.Status == "Cancelled")</span>
                <span class="summary-label">Cancelled</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num magenta">@_bookings.Where(b => b.Status != "Cancelled").Sum(b => b.TotalCost).ToString("C")</span>
                <span class="summary-label">Revenue</span>
            </div>
        </div>

        <!-- Bookings table -->
        <div class="panel">
            <div class="sessions-table-wrap">
                <table class="sessions-table">
                    <thead>
                        <tr>
                            <th>Modality</th>
                            <th>Trainer</th>
                            <th>Room</th>
                            <th>Date &amp; Time</th>
                            <th>Duration</th>
                            <th>Cost</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _bookings.OrderBy(x => x.StartTime))
                        {
                            var duration = b.EndTime - b.StartTime;
                            <tr>
                                <td>
                                    <span class="booking-modality-badge">@b.Modality</span>
                                    @if (!string.IsNullOrWhiteSpace(b.Notes))
                                    {
                                        <div class="session-desc">@b.Notes</div>
                                    }
                                </td>
                                <td>
                                    <div class="trainer-cell">
                                        <div class="trainer-avatar">@GetInitials(b.TrainerId)</div>
                                        <span class="trainer-id">@GetShortId(b.TrainerId)</span>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(b.RoomName))
                                    {
                                        <div class="room-name">@b.RoomName</div>
                                        @if (!string.IsNullOrEmpty(b.LocationName))
                                        {
                                            <div class="room-location">@b.LocationName</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="muted-text">—</span>
                                    }
                                </td>
                                <td>
                                    <div class="date-primary">@b.StartTime.ToString("MMM dd, yyyy")</div>
                                    <div class="date-time">@b.StartTime.ToString("HH:mm") – @b.EndTime.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    <span class="duration-chip">@FormatDuration(duration)</span>
                                </td>
                                <td>
                                    <span class="price-value">@b.TotalCost.ToString("C")</span>
                                </td>
                                <td>
                                    <span class="status-badge @GetStatusClass(b.Status)">@b.Status</span>
                                </td>
                                <td>
                                    @if (b.Status != "Cancelled" && b.Status != "Completed")
                                    {
                                        <button class="btn-cancel-session"
                                                @onclick="() => ConfirmCancel(b)"
                                                disabled="@(_cancellingId == b.Id)">
                                            @(_cancellingId == b.Id ? "..." : "Cancel")
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="gym-toast error">@_error</div>
}

@if (_confirmBooking != null)
{
    <div class="modal-overlay" @onclick="CloseConfirm">
        <div class="modal-box" @onclick:stopPropagation>
            <h3 class="modal-title">Cancel Booking</h3>
            <p class="modal-body">Are you sure you want to cancel the <strong>@_confirmBooking.Modality</strong> booking for <strong>@(_confirmBooking.RoomName ?? "this room")</strong>?</p>
            <div class="modal-actions">
                <button class="btn-modal-ghost" @onclick="CloseConfirm">Keep</button>
                <button class="btn-modal-danger" @onclick="ExecuteCancel" disabled="@(_cancellingId.HasValue)">
                    @(_cancellingId.HasValue ? "Cancelling..." : "Yes, Cancel")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int? _gymId;
    private string _rangeMode = "month";
    private List<ApiClient.RoomBookingRead> _bookings = new();

    private ApiClient.RoomBookingRead? _confirmBooking;
    private int? _cancellingId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var gym = await Api.GetMyGym();
            if (gym != null)
            {
                _gymId = gym.Id;
                await LoadBookings();
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not load data: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SetRange(string mode)
    {
        _rangeMode = mode;
        _loading = true;
        try { await LoadBookings(); }
        catch (Exception ex) { _error = $"Could not load bookings: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task LoadBookings()
    {
        if (_gymId == null) return;

        DateTime? from = null;
        DateTime? to = null;
        var now = DateTime.UtcNow;

        if (_rangeMode == "week")
        {
            from = now.Date.AddDays(-(int)now.DayOfWeek);
            to = from.Value.AddDays(7);
        }
        else if (_rangeMode == "month")
        {
            from = new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc);
            to = from.Value.AddMonths(1);
        }

        _bookings = await Api.GetGymBookings(_gymId.Value, from, to);
    }

    private static string GetInitials(string trainerId)
    {
        if (string.IsNullOrWhiteSpace(trainerId)) return "?";
        return trainerId.Length >= 2 ? trainerId[..2].ToUpper() : trainerId.ToUpper();
    }

    private static string FormatDuration(TimeSpan span)
    {
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m";
        var h = (int)span.TotalHours;
        var m = span.Minutes;
        return m > 0 ? $"{h}h {m}m" : $"{h}h";
    }

    private static string GetStatusClass(string status) => status?.ToLower() switch
    {
        "confirmed" => "status-confirmed",
        "pending"   => "status-pending",
        "cancelled" => "status-cancelled",
        "completed" => "status-completed",
        _           => "status-unknown"
    };

    private static string GetShortId(string trainerId)
    {
        if (string.IsNullOrWhiteSpace(trainerId)) return "?";
        return trainerId.Length >= 8 ? trainerId[..8] : trainerId;
    }

    private void ConfirmCancel(ApiClient.RoomBookingRead booking)
    {
        _confirmBooking = booking;
        _error = null;
    }

    private void CloseConfirm() => _confirmBooking = null;

    private async Task ExecuteCancel()
    {
        if (_confirmBooking is null) return;
        _cancellingId = _confirmBooking.Id;
        try
        {
            await Api.CancelRoomBooking(_confirmBooking.Id);
            var idx = _bookings.FindIndex(b => b.Id == _confirmBooking.Id);
            if (idx >= 0)
            {
                var b = _bookings[idx];
                _bookings[idx] = b with { Status = "Cancelled" };
            }
            _confirmBooking = null;
        }
        catch (Exception ex)
        {
            _error = $"Could not cancel booking: {ex.Message}";
        }
        finally
        {
            _cancellingId = null;
        }
    }
}

<style>
    .gym-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
        color: #0F172A;
        background: #F4F7FB;
        border-radius: 16px;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    /* Loading */
    .gym-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 40vh;
        gap: 1rem;
        color: #64748B;
    }
    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(59,111,232,0.2);
        border-top-color: #3B6FE8;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Setup prompt */
    .setup-prompt {
        max-width: 520px;
        margin: 6rem auto;
        text-align: center;
        padding: 3rem 2rem;
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
    }
    .setup-icon {
        width: 80px; height: 80px;
        background: #EEF3FD;
        border: 1px solid #C7D9F8;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        color: #3B6FE8;
    }
    .setup-prompt h2 { margin: 0 0 0.75rem; font-size: 1.6rem; }
    .setup-prompt p { color: #64748B; margin-bottom: 2rem; }

    /* Empty */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 30vh;
        gap: 1rem;
        color: #64748B;
        text-align: center;
    }
    .empty-icon {
        width: 70px; height: 70px;
        background: #EEF3FD;
        border: 1px solid #C7D9F8;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }

    /* Page header */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .page-eyebrow {
        margin: 0 0 4px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #3B6FE8;
    }
    .page-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
    }
    .header-actions { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }

    /* Filter tabs */
    .filter-tabs {
        display: flex;
        gap: 0.25rem;
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 30px;
        padding: 3px;
    }
    .filter-tab {
        background: transparent;
        border: none;
        color: #64748B;
        font-size: 0.82rem;
        font-weight: 500;
        font-family: inherit;
        padding: 0.4rem 1rem;
        border-radius: 26px;
        cursor: pointer;
        transition: background 0.18s, color 0.18s;
    }
    .filter-tab:hover { color: #0F172A; }
    .filter-tab.active { background: #EEF3FD; color: #3B6FE8; font-weight: 600; }

    /* Summary chips */
    .summary-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }
    .summary-chip {
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 12px;
        padding: 0.75rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        min-width: 80px;
    }
    .summary-num { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .summary-num.teal    { color: #3B6FE8; }
    .summary-num.amber   { color: #ffb400; }
    .summary-num.magenta { color: #EF4444; }
    .summary-num.muted   { color: #64748B; }
    .summary-label { font-size: 0.75rem; color: #64748B; }

    /* Panel */
    .panel {
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 0;
        overflow: hidden;
    }

    /* Table */
    .sessions-table-wrap { overflow-x: auto; }
    .sessions-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }
    .sessions-table thead tr {
        background: #F8FAFC;
        border-bottom: 1px solid #E8EDF5;
    }
    .sessions-table th {
        padding: 0.875rem 1.25rem;
        text-align: left;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #64748B;
        white-space: nowrap;
    }
    .sessions-table tbody tr {
        border-bottom: 1px solid #E8EDF5;
        transition: background 0.15s;
    }
    .sessions-table tbody tr:last-child { border-bottom: none; }
    .sessions-table tbody tr:hover { background: #F8FAFC; }
    .sessions-table td {
        padding: 1rem 1.25rem;
        vertical-align: middle;
    }

    /* Modality badge */
    .booking-modality-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        background: #E0ECFF;
        color: #1D4ED8;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: capitalize;
        width: fit-content;
    }

    /* Session desc / notes */
    .session-desc {
        font-size: 0.78rem;
        color: #64748B;
        margin-top: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 220px;
    }

    /* Trainer cell */
    .trainer-cell { display: flex; align-items: center; gap: 0.625rem; }
    .trainer-avatar {
        width: 32px; height: 32px;
        background: #EEF3FD;
        border: 1px solid #C7D9F8;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        color: #3B6FE8;
        flex-shrink: 0;
    }
    .trainer-id { font-size: 0.8rem; color: #64748B; font-family: monospace; }

    /* Date cell */
    .date-primary { font-weight: 500; }
    .date-time    { font-size: 0.8rem; color: #64748B; margin-top: 1px; }

    /* Duration chip */
    .duration-chip {
        background: #F8FAFC;
        border: 1px solid #E8EDF5;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    /* Price */
    .price-value { font-weight: 600; color: #0F172A; }

    /* Room cell */
    .room-name {
        font-weight: 600;
        color: #0F172A;
        font-size: 0.875rem;
    }
    .room-location {
        font-size: 0.78rem;
        color: #64748B;
        margin-top: 2px;
    }
    .muted-text {
        color: #94A3B8;
        font-style: italic;
    }

    /* Status badges */
    .status-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 3px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }
    .status-confirmed { background: #D1FAE5; color: #059669; border: 1px solid #A7F3D0; }
    .status-pending   { background: #FEF3C7; color: #D97706; border: 1px solid #FDE68A; }
    .status-cancelled { background: #F1F5F9; color: #64748B; border: 1px solid #CBD5E1; }
    .status-completed { background: #E0E7FF; color: #6366F1; border: 1px solid #C7D2FE; }
    .status-unknown   { background: #F1F5F9; color: #64748B; border: 1px solid #CBD5E1; }

    /* Buttons */
    .btn-gym-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #3B6FE8;
        color: #ffffff;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.95rem;
        font-family: inherit;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 2px 10px rgba(59,111,232,0.25);
    }
    .btn-gym-primary:hover { transform: translateY(-1px); background: #2952CC; box-shadow: 0 4px 16px rgba(59,111,232,0.35); }
    .btn-gym-primary.btn-large { padding: 0.9rem 2rem; font-size: 1.05rem; }

    /* Toast */
    .gym-toast {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        padding: 0.875rem 1.5rem;
        border-radius: 12px;
        font-size: 0.9rem;
        z-index: 9000;
        backdrop-filter: blur(10px);
    }
    .gym-toast.error { background: #FEF2F2; border: 1px solid #FECACA; color: #EF4444; }

    /* Cancel button */
    .btn-cancel-session {
        background: transparent;
        border: 1px solid #FECACA;
        color: #EF4444;
        font-size: 0.75rem;
        font-weight: 600;
        font-family: inherit;
        padding: 4px 12px;
        border-radius: 20px;
        cursor: pointer;
        transition: background 0.18s, border-color 0.18s;
        white-space: nowrap;
    }
    .btn-cancel-session:hover { background: #FEF2F2; border-color: #FCA5A5; }
    .btn-cancel-session:disabled { opacity: 0.5; cursor: default; }

    /* Modal */
    .modal-overlay {
        position: fixed; inset: 0;
        background: rgba(15,23,42,0.35);
        backdrop-filter: blur(4px);
        z-index: 9500;
        display: flex; align-items: center; justify-content: center;
    }
    .modal-box {
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
        padding: 2rem;
        max-width: 420px;
        width: 90%;
        box-shadow: 0 16px 40px rgba(15,23,42,0.18);
    }
    .modal-title { margin: 0 0 0.75rem; font-size: 1.3rem; font-weight: 700; color: #0F172A; }
    .modal-body  { margin: 0 0 1.75rem; color: #64748B; line-height: 1.6; }
    .modal-body strong { color: #0F172A; }
    .modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; }
    .btn-modal-ghost {
        background: transparent;
        border: 1px solid #CBD5E1;
        color: #64748B;
        font-size: 0.9rem; font-weight: 600; font-family: inherit;
        padding: 0.6rem 1.4rem; border-radius: 30px; cursor: pointer;
        transition: border-color 0.18s, color 0.18s;
    }
    .btn-modal-ghost:hover { border-color: #94A3B8; color: #0F172A; }
    .btn-modal-danger {
        background: #EF4444;
        border: none;
        color: #fff;
        font-size: 0.9rem; font-weight: 700; font-family: inherit;
        padding: 0.6rem 1.4rem; border-radius: 30px; cursor: pointer;
        transition: transform 0.18s, box-shadow 0.18s;
        box-shadow: 0 4px 16px rgba(239,68,68,0.28);
    }
    .btn-modal-danger:hover { transform: scale(1.03); background: #DC2626; box-shadow: 0 6px 24px rgba(239,68,68,0.38); }
    .btn-modal-danger:disabled { opacity: 0.6; cursor: default; transform: none; }

    @@media (max-width: 768px) {
        .summary-row { gap: 0.5rem; }
        .summary-chip { min-width: 64px; padding: 0.625rem 0.875rem; }
        .sessions-table th, .sessions-table td { padding: 0.75rem 0.875rem; }
    }
</style>
