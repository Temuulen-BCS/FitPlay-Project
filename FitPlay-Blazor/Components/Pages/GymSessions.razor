@page "/gym/sessions"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "GymAdmin")]
@layout GymAdminLayout

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using FitPlay_Blazor.Components.Layout
@using FitPlay.Blazor.Services

@inject ApiClient Api
@inject NavigationManager Nav
@implements IDisposable

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<PageTitle>Sessions - FitPlay Gym</PageTitle>

<div class="gym-page">

    <div class="page-header">
        <div>
            <p class="page-eyebrow">Gym Admin</p>
            <h1 class="page-title">Room Bookings</h1>
        </div>
        <div class="header-actions">
            <div class="filter-tabs">
                <button class="filter-tab @(_rangeMode == "week" ? "active" : "")" @onclick='() => SetRange("week")'>This Week</button>
                <button class="filter-tab @(_rangeMode == "month" ? "active" : "")" @onclick='() => SetRange("month")'>This Month</button>
                <button class="filter-tab @(_rangeMode == "all" ? "active" : "")" @onclick='() => SetRange("all")'>All</button>
            </div>
        </div>
    </div>

    @* ── LIVE Presence Section ── *@
    @if (_gymId != null && _presenceCounts.Count > 0)
    {
        <div class="presence-section">
            <div class="presence-header">
                <span class="pulse-dot"></span>
                <span class="live-label">LIVE</span>
                <span class="presence-title">Clients at Gym</span>
            </div>
            <div class="presence-chips">
                @foreach (var loc in _presenceCounts)
                {
                    <button class="presence-chip clickable" @onclick="() => OnPresenceChipClick(loc.GymLocationId, loc.LocationName)">
                        <span class="presence-chip-name">@loc.LocationName</span>
                        <span class="presence-chip-count">@loc.ActiveCount</span>
                    </button>
                }
            </div>
        </div>
    }
    else if (_gymId != null && !_loading)
    {
        <div class="presence-section presence-empty">
            <div class="presence-header">
                <span class="pulse-dot off"></span>
                <span class="presence-title" style="color:#94A3B8;">No clients checked in right now</span>
            </div>
        </div>
    }

    @if (_loading)
    {
        <div class="gym-loading">
            <div class="loading-spinner"></div>
            <p>Loading bookings...</p>
        </div>
    }
    else if (_gymId == null)
    {
        <div class="setup-prompt">
            <div class="setup-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h2>No Gym Registered</h2>
            <p>Register your gym first to manage bookings.</p>
            <a href="/gym/setup" class="btn-gym-primary btn-large">Register My Gym</a>
        </div>
    }
    else if (_bookings.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4M16 2v4"/><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18"/></svg>
            </div>
            <p>No bookings found for the selected period.</p>
        </div>
    }
    else
    {
        <!-- Summary chips -->
        <div class="summary-row">
            <div class="summary-chip">
                <span class="summary-num">@_bookings.Count</span>
                <span class="summary-label">Total</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num teal">@_bookings.Count(b => b.Status == "Confirmed")</span>
                <span class="summary-label">Confirmed</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num amber">@_bookings.Count(b => b.Status == "Pending")</span>
                <span class="summary-label">Pending</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num muted">@_bookings.Count(b => b.Status == "Cancelled")</span>
                <span class="summary-label">Cancelled</span>
            </div>
            <div class="summary-chip">
                <span class="summary-num magenta">@_bookings.Where(b => b.Status != "Cancelled").Sum(b => b.TotalCost).ToString("C")</span>
                <span class="summary-label">Revenue</span>
            </div>
        </div>

        <!-- Bookings table -->
        <div class="panel">
            <div class="sessions-table-wrap">
                <table class="sessions-table">
                    <thead>
                        <tr>
                            <th>Modality</th>
                            <th>Trainer</th>
                            <th>Room</th>
                            <th>Date &amp; Time</th>
                            <th>Duration</th>
                            <th>Cost</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _bookings.OrderBy(x => x.StartTime))
                        {
                            var duration = b.EndTime - b.StartTime;
                            <tr>
                                <td>
                                    <span class="booking-modality-badge">@b.Modality</span>
                                    @if (!string.IsNullOrWhiteSpace(b.Notes))
                                    {
                                        <div class="session-desc">@b.Notes</div>
                                    }
                                </td>
                                <td>
                                    <div class="trainer-cell">
                                        <div class="trainer-avatar">@GetInitials(b.TrainerId)</div>
                                        <span class="trainer-id">@GetShortId(b.TrainerId)</span>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(b.RoomName))
                                    {
                                        <div class="room-name">@b.RoomName</div>
                                        @if (!string.IsNullOrEmpty(b.LocationName))
                                        {
                                            <div class="room-location">@b.LocationName</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="muted-text">---</span>
                                    }
                                </td>
                                <td>
                                    <div class="date-primary">@b.StartTime.ToString("MMM dd, yyyy")</div>
                                    <div class="date-time">@b.StartTime.ToString("HH:mm") - @b.EndTime.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    <span class="duration-chip">@FormatDuration(duration)</span>
                                </td>
                                <td>
                                    <span class="price-value">@b.TotalCost.ToString("C")</span>
                                </td>
                                <td>
                                    <span class="status-badge @GetStatusClass(b.Status)">@b.Status</span>
                                </td>
                                <td>
                                    @if (b.Status != "Cancelled" && b.Status != "Completed")
                                    {
                                        <button class="btn-cancel-session"
                                                @onclick="() => ConfirmCancel(b)"
                                                disabled="@(_cancellingId == b.Id)">
                                            @(_cancellingId == b.Id ? "..." : "Cancel")
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="gym-toast error">@_error</div>
}

@if (_confirmBooking != null)
{
    <div class="modal-overlay" @onclick="CloseConfirm">
        <div class="modal-box" @onclick:stopPropagation>
            <h3 class="modal-title">Cancel Booking</h3>
            <p class="modal-body">Are you sure you want to cancel the <strong>@_confirmBooking.Modality</strong> booking for <strong>@(_confirmBooking.RoomName ?? "this room")</strong>?</p>
            <div class="modal-actions">
                <button class="btn-modal-ghost" @onclick="CloseConfirm">Keep</button>
                <button class="btn-modal-danger" @onclick="ExecuteCancel" disabled="@(_cancellingId.HasValue)">
                    @(_cancellingId.HasValue ? "Cancelling..." : "Yes, Cancel")
                </button>
            </div>
        </div>
    </div>
}

@* ── Visit Details Modal ── *@
@if (_showVisitModal)
{
    <div class="modal-overlay" @onclick="CloseVisitModal">
        <div class="modal-box modal-wide" @onclick:stopPropagation>
            <div class="visit-modal-header">
                <div>
                    <h3 class="modal-title">Clients at @_selectedLocationName</h3>
                    <p class="modal-subtitle">Currently checked-in clients</p>
                </div>
                <button class="btn-close-modal" @onclick="CloseVisitModal">&times;</button>
            </div>

            @if (_loadingVisitDetails)
            {
                <div class="visit-loading">
                    <div class="loading-spinner"></div>
                    <p>Loading client details...</p>
                </div>
            }
            else if (_activeVisitDetails.Count == 0)
            {
                <p class="modal-body" style="text-align:center;">No clients currently checked in at this location.</p>
            }
            else
            {
                <div class="visit-cards">
                    @foreach (var visit in _activeVisitDetails)
                    {
                        <div class="visit-card">
                            <div class="visit-card-header">
                                <div class="visit-user-avatar">@GetNameInitials(visit.UserName)</div>
                                <div class="visit-user-info">
                                    <div class="visit-user-name">@visit.UserName</div>
                                    <div class="visit-user-email">@visit.UserEmail</div>
                                    @if (!string.IsNullOrWhiteSpace(visit.UserPhone))
                                    {
                                        <div class="visit-user-phone">@visit.UserPhone</div>
                                    }
                                </div>
                                <div class="visit-checkin-time">
                                    <span class="visit-time-label">Checked in</span>
                                    <span class="visit-time-value">@visit.CheckInTime.ToString("HH:mm")</span>
                                    <span class="visit-duration-label">@FormatElapsed(visit.CheckInTime) ago</span>
                                </div>
                            </div>

                            <div class="visit-session-info">
                                <div class="session-info-row">
                                    <span class="session-info-label">Class</span>
                                    <span class="session-info-value">
                                        @if (!string.IsNullOrWhiteSpace(visit.ClassTitle))
                                        {
                                            @visit.ClassTitle
                                        }
                                        else
                                        {
                                            <span class="muted-text">General visit</span>
                                        }
                                    </span>
                                </div>
                                <div class="session-info-row">
                                    <span class="session-info-label">Time</span>
                                    <span class="session-info-value">
                                        @if (visit.SessionStartTime != null && visit.SessionEndTime != null)
                                        {
                                            @visit.SessionStartTime.Value.ToString("HH:mm") @:- @visit.SessionEndTime.Value.ToString("HH:mm")
                                        }
                                        else
                                        {
                                            <span class="muted-text">@visit.CheckInTime.ToString("HH:mm") (check-in)</span>
                                        }
                                    </span>
                                </div>
                                <div class="session-info-row">
                                    <span class="session-info-label">Room</span>
                                    <span class="session-info-value">
                                        @if (!string.IsNullOrWhiteSpace(visit.RoomName))
                                        {
                                            @visit.RoomName
                                        }
                                        else
                                        {
                                            <span class="muted-text">---</span>
                                        }
                                    </span>
                                </div>
                                <div class="session-info-row">
                                    <span class="session-info-label">Trainer / Teacher</span>
                                    <span class="session-info-value">
                                        @if (!string.IsNullOrWhiteSpace(visit.TrainerName))
                                        {
                                            @visit.TrainerName
                                            @if (!string.IsNullOrWhiteSpace(visit.TrainerEmail))
                                            {
                                                <span class="trainer-email-hint">(@visit.TrainerEmail)</span>
                                            }
                                        }
                                        else if (!string.IsNullOrWhiteSpace(visit.TrainerId))
                                        {
                                            <span class="trainer-id-fallback">@GetShortId(visit.TrainerId)</span>
                                        }
                                        else
                                        {
                                            <span class="muted-text">Not assigned</span>
                                        }
                                    </span>
                                </div>
                                @if (visit.PaidAmount != null)
                                {
                                    <div class="session-info-row">
                                        <span class="session-info-label">Paid</span>
                                        <span class="session-info-value">@visit.PaidAmount.Value.ToString("C")</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(visit.EnrollmentStatus))
                                {
                                    <div class="session-info-row">
                                        <span class="session-info-label">Status</span>
                                        <span class="status-badge @GetStatusClass(visit.EnrollmentStatus)">@visit.EnrollmentStatus</span>
                                    </div>
                                }
                            </div>

                            <div class="visit-card-actions">
                                @if (!string.IsNullOrWhiteSpace(visit.TrainerId))
                                {
                                    <button class="btn-report-problem" @onclick="() => ShowNotifyTrainerForm(visit)">
                                        Report Problem to Trainer
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@* ── Trainer Notification Form Modal ── *@
@if (_showNotificationForm && _selectedVisit != null)
{
    <div class="modal-overlay" @onclick="CloseNotificationForm">
        <div class="modal-box" @onclick:stopPropagation>
            <h3 class="modal-title">Report Problem to Trainer</h3>
            <p class="modal-body">
                Send a message to <strong>@_selectedVisit.TrainerName</strong> about
                <strong>@_selectedVisit.UserName</strong>.
            </p>

            <div class="notification-form">
                <textarea class="notification-textarea"
                          @bind="_notificationMessage"
                          placeholder="Describe the problem..."
                          rows="4"
                          maxlength="1000"
                          disabled="@_sendingNotification"></textarea>

                @if (!string.IsNullOrWhiteSpace(_notificationError))
                {
                    <div class="notification-error">@_notificationError</div>
                }

                @if (_notificationSent)
                {
                    <div class="notification-success">Notification sent successfully!</div>
                }

                <div class="modal-actions">
                    <button class="btn-modal-ghost" @onclick="CloseNotificationForm" disabled="@_sendingNotification">Cancel</button>
                    <button class="btn-modal-primary" @onclick="SendTrainerNotification" disabled="@(_sendingNotification || string.IsNullOrWhiteSpace(_notificationMessage))">
                        @(_sendingNotification ? "Sending..." : "Send Notification")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _error;
    private int? _gymId;
    private string _rangeMode = "month";
    private List<ApiClient.RoomBookingRead> _bookings = new();

    private ApiClient.RoomBookingRead? _confirmBooking;
    private int? _cancellingId;

    // Presence state
    private List<ApiClient.LocationPresenceRead> _presenceCounts = new();
    private System.Threading.Timer? _presenceTimer;

    // Visit details modal state
    private bool _showVisitModal;
    private int _selectedLocationId;
    private string _selectedLocationName = "";
    private List<ApiClient.ActiveVisitDetailRead> _activeVisitDetails = new();
    private bool _loadingVisitDetails;

    // Trainer notification form state
    private bool _showNotificationForm;
    private ApiClient.ActiveVisitDetailRead? _selectedVisit;
    private string _notificationMessage = "";
    private bool _sendingNotification;
    private string? _notificationError;
    private bool _notificationSent;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var gym = await Api.GetMyGym();
            if (gym != null)
            {
                _gymId = gym.Id;
                await LoadBookings();
                await LoadPresenceCounts();
                StartPresencePolling();
            }
        }
        catch (Exception ex)
        {
            _error = $"Could not load data: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartPresencePolling()
    {
        _presenceTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await LoadPresenceCounts();
                await InvokeAsync(StateHasChanged);
            }
            catch
            {
                // Silently ignore polling errors
            }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadPresenceCounts()
    {
        if (_gymId == null) return;
        try
        {
            _presenceCounts = await Api.GetActiveCountsAsync(_gymId.Value);
        }
        catch
        {
            // Don't break the page if presence fails
        }
    }

    private async Task SetRange(string mode)
    {
        _rangeMode = mode;
        _loading = true;
        try { await LoadBookings(); }
        catch (Exception ex) { _error = $"Could not load bookings: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task LoadBookings()
    {
        if (_gymId == null) return;

        DateTime? from = null;
        DateTime? to = null;
        var now = DateTime.UtcNow;

        if (_rangeMode == "week")
        {
            from = now.Date.AddDays(-(int)now.DayOfWeek);
            to = from.Value.AddDays(7);
        }
        else if (_rangeMode == "month")
        {
            from = new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc);
            to = from.Value.AddMonths(1);
        }

        _bookings = await Api.GetGymBookings(_gymId.Value, from, to);
    }

    // ── Presence chip click ──
    private async Task OnPresenceChipClick(int locationId, string locationName)
    {
        _selectedLocationId = locationId;
        _selectedLocationName = locationName;
        _showVisitModal = true;
        _loadingVisitDetails = true;
        _activeVisitDetails = new();
        StateHasChanged();

        try
        {
            _activeVisitDetails = await Api.GetActiveVisitDetailsAsync(locationId);
        }
        catch (Exception ex)
        {
            _error = $"Could not load visit details: {ex.Message}";
        }
        finally
        {
            _loadingVisitDetails = false;
        }
    }

    private void CloseVisitModal()
    {
        _showVisitModal = false;
        _activeVisitDetails = new();
        _selectedLocationId = 0;
        _selectedLocationName = "";
    }

    // ── Trainer notification ──
    private void ShowNotifyTrainerForm(ApiClient.ActiveVisitDetailRead visit)
    {
        _selectedVisit = visit;
        _notificationMessage = "";
        _notificationError = null;
        _notificationSent = false;
        _showNotificationForm = true;
    }

    private void CloseNotificationForm()
    {
        _showNotificationForm = false;
        _selectedVisit = null;
        _notificationMessage = "";
        _notificationError = null;
        _notificationSent = false;
    }

    private async Task SendTrainerNotification()
    {
        if (_selectedVisit == null || string.IsNullOrWhiteSpace(_notificationMessage) || string.IsNullOrWhiteSpace(_selectedVisit.TrainerId))
            return;

        _sendingNotification = true;
        _notificationError = null;
        _notificationSent = false;

        try
        {
            var request = new ApiClient.CreateTrainerNotificationRequest(
                TrainerId: _selectedVisit.TrainerId,
                GymLocationId: _selectedLocationId,
                SubjectUserId: _selectedVisit.UserId,
                Message: _notificationMessage
            );

            await Api.SendTrainerNotificationAsync(request);
            _notificationSent = true;
            _notificationMessage = "";
        }
        catch (Exception ex)
        {
            _notificationError = $"Failed to send: {ex.Message}";
        }
        finally
        {
            _sendingNotification = false;
        }
    }

    // ── Helpers ──
    private static string GetInitials(string trainerId)
    {
        if (string.IsNullOrWhiteSpace(trainerId)) return "?";
        return trainerId.Length >= 2 ? trainerId[..2].ToUpper() : trainerId.ToUpper();
    }

    private static string GetNameInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string FormatDuration(TimeSpan span)
    {
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m";
        var h = (int)span.TotalHours;
        var m = span.Minutes;
        return m > 0 ? $"{h}h {m}m" : $"{h}h";
    }

    private static string FormatElapsed(DateTime checkInTime)
    {
        var elapsed = DateTime.UtcNow - checkInTime;
        if (elapsed.TotalMinutes < 1) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m";
        var h = (int)elapsed.TotalHours;
        var m = elapsed.Minutes;
        return m > 0 ? $"{h}h {m}m" : $"{h}h";
    }

    private static string GetStatusClass(string status) => status?.ToLower() switch
    {
        "confirmed" => "status-confirmed",
        "pending"   => "status-pending",
        "cancelled" => "status-cancelled",
        "completed" => "status-completed",
        _           => "status-unknown"
    };

    private static string GetShortId(string trainerId)
    {
        if (string.IsNullOrWhiteSpace(trainerId)) return "?";
        return trainerId.Length >= 8 ? trainerId[..8] : trainerId;
    }

    private void ConfirmCancel(ApiClient.RoomBookingRead booking)
    {
        _confirmBooking = booking;
        _error = null;
    }

    private void CloseConfirm() => _confirmBooking = null;

    private async Task ExecuteCancel()
    {
        if (_confirmBooking is null) return;
        _cancellingId = _confirmBooking.Id;
        try
        {
            await Api.CancelRoomBooking(_confirmBooking.Id);
            var idx = _bookings.FindIndex(b => b.Id == _confirmBooking.Id);
            if (idx >= 0)
            {
                var b = _bookings[idx];
                _bookings[idx] = b with { Status = "Cancelled" };
            }
            _confirmBooking = null;
        }
        catch (Exception ex)
        {
            _error = $"Could not cancel booking: {ex.Message}";
        }
        finally
        {
            _cancellingId = null;
        }
    }

    public void Dispose()
    {
        _presenceTimer?.Dispose();
    }
}

<style>
    .gym-page {
        width: 100%;
        box-sizing: border-box;
        padding: 2.5rem 1.5rem 4rem;
        color: #0F172A;
        background: #F4F7FB;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
    }

    /* Loading */
    .gym-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 40vh;
        gap: 1rem;
        color: #64748B;
    }
    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(59,111,232,0.2);
        border-top-color: #3B6FE8;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Setup prompt */
    .setup-prompt {
        max-width: 520px;
        margin: 6rem auto;
        text-align: center;
        padding: 3rem 2rem;
        background: #ffffff;
        border: 1px solid #E8EDF5;
        border-radius: 14px;
    }
    .setup-icon {
        width: 80px; height: 80px;
        background: #EEF3FD;
        border: 1px solid #C7D9F8;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        color: #3B6FE8;
    }
    .setup-prompt h2 { margin: 0 0 0.75rem; font-size: 1.6rem; }
    .setup-prompt p { color: #64748B; margin-bottom: 2rem; }

    /* Empty */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 30vh;
        gap: 1rem;
        color: #64748B;
        text-align: center;
    }
    .empty-icon {
        width: 70px; height: 70px;
        background: #EEF3FD;
        border: 1px solid #C7D9F8;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
    }

    /* Page header */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .page-eyebrow {
