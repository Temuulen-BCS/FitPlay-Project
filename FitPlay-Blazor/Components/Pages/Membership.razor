@page "/membership"
@rendermode InteractiveServer
@attribute [Authorize]
@layout EmptyLayout
@using FitPlay.Blazor.Services
@inject ApiClient Api
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Membership - FitPlay</PageTitle>

<section class="membership-shell">
    <button class="back-btn" @onclick="GoBack">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M5 12l7 7M5 12l7-7" />
        </svg>
        Back
    </button>
    <div class="membership-hero">
        <div class="hero-glow"></div>
        <p class="eyebrow">Membership</p>
        <h1>Access the full FitPlay experience</h1>
        <p class="subhead">Unlock all trainings, progress tracking, and achievements for one monthly plan.</p>
    </div>

    <div class="membership-grid">
        <div class="plan-card">
            <div class="plan-header">
                <div>
                    <p class="plan-label">Monthly plan</p>
                    <p class="plan-price">€10 <span>/ month</span></p>
                </div>
                <div class="plan-badge">Most popular</div>
            </div>
            <ul class="plan-features">
                <li>Unlimited trainings</li>
                <li>XP, levels, and achievements</li>
                <li>Class bookings and schedules</li>
                <li>Trainer validation workflow</li>
            </ul>

            @if (_isLoading)
            {
                <div class="status-card">Checking membership status...</div>
            }
            else if (_isActive)
            {
                <div class="active-card">
                    <div class="active-header">
                        <div class="active-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 6L9 17l-5-5" />
                            </svg>
                        </div>
                        <div>
                            <p class="active-label">Status</p>
                            <h3 class="active-title">You are active</h3>
                        </div>
                    </div>

                    <ul class="active-benefits">
                        <li><span class="benefit-dot"></span>Unlimited trainings</li>
                        <li><span class="benefit-dot"></span>XP, levels, and achievements</li>
                        <li><span class="benefit-dot"></span>Class bookings and schedules</li>
                        <li><span class="benefit-dot"></span>Trainer validation workflow</li>
                    </ul>

                    <div class="active-renewal">
                        <span class="renewal-label">Next payment</span>
                        <span class="renewal-date">@NextPaymentDate</span>
                    </div>
                </div>
            }
            else if (_clientSecret is not null)
            {
                <div class="checkout-card">
                    <h3>Start your membership</h3>
                    <p>Enter your payment details to activate instantly.</p>

                    <div id="payment-element"></div>
                    <button class="btn-primary" @onclick="ConfirmPayment" disabled="@_isSubmitting">
                        @(_isSubmitting ? "Processing..." : "Activate Membership")
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="status-card error">@_errorMessage</div>
                    }
                </div>
            }
            else
            {
                <div class="checkout-card">
                    <h3>Start your membership</h3>
                    <p>Enter your payment details to activate instantly.</p>

                    <button class="btn-primary" @onclick="InitializePayment" disabled="@_isSubmitting">
                        @(_isSubmitting ? "Preparing..." : "Activate Membership")
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="status-card error">@_errorMessage</div>
                    }
                </div>
            }
        </div>

        <div class="info-card">
            <h3>What you get</h3>
            <div class="info-item">
                <span class="pill">24/7</span>
                <div>
                    <h4>Always on</h4>
                    <p>Stream workouts any time, track progress, and stay on top of your goals.</p>
                </div>
            </div>
            <div class="info-item">
                <span class="pill">PRO</span>
                <div>
                    <h4>Coach feedback</h4>
                    <p>Get validation on your training completions and unlock achievements faster.</p>
                </div>
            </div>
            <div class="info-item">
                <span class="pill">XP</span>
                <div>
                    <h4>Gamified journey</h4>
                    <p>Earn XP, level up, and keep the momentum going with rewards.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    :root {
        --membership-bg: radial-gradient(circle at 20% 20%, rgba(255, 196, 86, 0.15), transparent 45%), radial-gradient(circle at 80% 10%, rgba(255, 90, 154, 0.18), transparent 45%), radial-gradient(circle at 50% 80%, rgba(61, 193, 211, 0.12), transparent 55%), #0b0b0f;
        --membership-panel: rgba(17, 19, 27, 0.92);
        --membership-border: rgba(255, 255, 255, 0.08);
        --membership-highlight: linear-gradient(135deg, #ffd86f, #ff8ad1);
        --membership-text: #f5f7ff;
        --membership-muted: rgba(245, 247, 255, 0.65);
        --membership-accent: #ffb703;
    }

    .membership-shell {
        min-height: calc(100vh - 120px);
        padding: 48px 24px 72px;
        background: var(--membership-bg);
        color: var(--membership-text);
        position: relative;
    }

    .membership-hero {
        max-width: 900px;
        margin: 0 auto 48px;
        text-align: center;
        position: relative;
    }

    .hero-glow {
        position: absolute;
        inset: -20px 0 0;
        background: radial-gradient(circle at center, rgba(255, 186, 73, 0.25), transparent 60%);
        filter: blur(60px);
        z-index: 0;
    }

    .membership-hero h1 {
        font-size: clamp(2rem, 4vw, 3.4rem);
        margin: 0 0 12px;
        position: relative;
        z-index: 1;
    }

    .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 0.75rem;
        color: var(--membership-muted);
        margin-bottom: 12px;
        position: relative;
        z-index: 1;
    }

    .subhead {
        font-size: 1.1rem;
        color: var(--membership-muted);
        margin: 0 auto;
        max-width: 620px;
        position: relative;
        z-index: 1;
    }

    .membership-grid {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
    }

    .plan-card,
    .info-card {
        background: var(--membership-panel);
        border: 1px solid var(--membership-border);
        border-radius: 24px;
        padding: 28px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
    }

    .plan-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
    }

    .plan-label {
        color: var(--membership-muted);
        font-size: 0.9rem;
        margin: 0 0 8px;
    }

    .plan-price {
        font-size: 2rem;
        margin: 0;
        font-weight: 600;
    }

        .plan-price span {
            font-size: 0.9rem;
            color: var(--membership-muted);
        }

    .plan-badge {
        padding: 6px 12px;
        border-radius: 999px;
        background: var(--membership-highlight);
        color: #1a1a1a;
        font-weight: 600;
        font-size: 0.75rem;
    }

    .plan-features {
        list-style: none;
        padding: 16px 0 0;
        margin: 0 0 24px;
        display: grid;
        gap: 10px;
        color: var(--membership-muted);
    }

        .plan-features li::before {
            content: "•";
            margin-right: 10px;
            color: var(--membership-accent);
        }

    .checkout-card {
        display: grid;
        gap: 16px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

        .checkout-card h3 {
            margin: 0;
        }

        .checkout-card p {
            margin: 0;
            color: var(--membership-muted);
        }

    #payment-element {
        background: #fff;
        padding: 16px;
        border-radius: 12px;
    }

    .status-card {
        padding: 16px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.05);
        color: var(--membership-muted);
    }

        .status-card.success {
            background: rgba(76, 175, 80, 0.2);
            color: #dff6e3;
        }

        .status-card.error {
            background: rgba(255, 90, 90, 0.2);
            color: #ffe3e3;
        }

    /* Active membership card */
    .active-card {
        display: grid;
        gap: 20px;
        padding: 20px;
        background: rgba(76, 175, 80, 0.08);
        border: 1px solid rgba(76, 175, 80, 0.3);
        border-radius: 16px;
    }

    .active-header {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .active-icon {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(76, 175, 80, 0.2);
        border: 1.5px solid rgba(76, 175, 80, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4caf50;
        flex-shrink: 0;
    }

        .active-icon svg {
            width: 22px;
            height: 22px;
        }

    .active-label {
        margin: 0 0 2px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--membership-muted);
    }

    .active-title {
        margin: 0;
        font-size: 1.1rem;
        color: #a8e6ab;
    }

    .active-benefits {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 8px;
    }

        .active-benefits li {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
            color: var(--membership-muted);
        }

    .benefit-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4caf50;
        flex-shrink: 0;
    }

    .active-renewal {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 14px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .renewal-label {
        font-size: 0.85rem;
        color: var(--membership-muted);
    }

    .renewal-date {
        font-size: 0.9rem;
        font-weight: 600;
        color: #ffb703;
    }

    .info-card h3 {
        margin-top: 0;
    }

    .info-item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

        .info-item:last-child {
            border-bottom: none;
        }

    .pill {
        align-self: start;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        color: var(--membership-accent);
        font-weight: 600;
        font-size: 0.75rem;
    }

    .btn-primary {
        width: 100%;
        padding: 12px 16px;
        border: none;
        border-radius: 12px;
        background: var(--membership-highlight);
        color: #111;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-1px);
        }

    .back-btn {
        position: absolute;
        top: 48px;
        left: 24px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        border: 1.5px solid rgba(57, 255, 110, 0.45);
        border-radius: 999px;
        padding: 8px 18px 8px 12px;
        color: #39ff6e;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        letter-spacing: 0.03em;
        text-shadow: 0 0 8px #39ff6e, 0 0 18px rgba(57, 255, 110, 0.7);
        box-shadow: 0 0 10px rgba(57, 255, 110, 0.25), inset 0 0 10px rgba(57, 255, 110, 0.06);
        transition: box-shadow 0.25s ease, text-shadow 0.25s ease, border-color 0.25s ease;
        z-index: 2;
    }

        .back-btn svg {
            width: 18px;
            height: 18px;
            filter: drop-shadow(0 0 5px #39ff6e);
            transition: filter 0.25s ease, transform 0.25s ease;
        }

        .back-btn:hover {
            border-color: rgba(57, 255, 110, 0.9);
            text-shadow: 0 0 12px #39ff6e, 0 0 30px rgba(57, 255, 110, 0.9), 0 0 50px rgba(57, 255, 110, 0.5);
            box-shadow: 0 0 18px rgba(57, 255, 110, 0.55), 0 0 40px rgba(57, 255, 110, 0.25), inset 0 0 14px rgba(57, 255, 110, 0.1);
        }

        .back-btn:hover svg {
            filter: drop-shadow(0 0 8px #39ff6e);
            transform: translateX(-3px);
        }

        .back-btn:focus-visible {
            outline: 2px solid #39ff6e;
            outline-offset: 3px;
        }

    @@media (max-width: 768px) {
        .membership-shell {
            padding: 32px 16px 48px;
        }

        .plan-card,
        .info-card {
            padding: 22px;
        }
    }
</style>

@code {
    private async Task GoBack() => await Js.InvokeVoidAsync("history.back");

    private bool _isLoading = true;
    private bool _isActive;
    private bool _isSubmitting;
    private string? _errorMessage;
    private string? _clientSecret;
    private bool _elementMounted;
    private ApiClient.MembershipStatus? _membershipStatus;

    private string NextPaymentDate
    {
        get
        {
            if (_membershipStatus?.CurrentPeriodEnd is DateTime end)
                return end.ToString("MMMM dd, yyyy");
            return DateTime.UtcNow.AddDays(30).ToString("MMMM dd, yyyy");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("Account/Login", true);
            return;
        }

        await LoadStatusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isActive || _isLoading || _elementMounted)
            return;

        if (!string.IsNullOrWhiteSpace(_clientSecret))
        {
            _elementMounted = true;
            await Js.InvokeVoidAsync("fitplayStripe.mount", _clientSecret);
        }
    }

    private async Task LoadStatusAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            var status = await Api.GetMembershipStatus();
            _membershipStatus = status;
            _isActive = status?.IsActive == true;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // Passo 1: Usuário clica no botão → cria (ou reutiliza) assinatura e monta o elemento Stripe
    private async Task InitializePayment()
    {
        // ✅ CORREÇÃO: Se já foi inicializado, não cria nova assinatura
        if (!string.IsNullOrWhiteSpace(_clientSecret))
            return;

        _isSubmitting = true;
        _errorMessage = null;
        try
        {
            var response = await Api.CreateMembershipSubscription(new ApiClient.CreateSubscriptionRequest(Navigation.Uri));
            _clientSecret = response?.ClientSecret;

            if (string.IsNullOrWhiteSpace(_clientSecret))
            {
                _errorMessage = "Não foi possível inicializar o pagamento.";
                return;
            }

            // Dispara OnAfterRenderAsync para montar o elemento Stripe
            _elementMounted = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    // Passo 2: Usuário preenche o cartão e clica em confirmar → confirma o pagamento
    private async Task ConfirmPayment()
    {
        if (string.IsNullOrWhiteSpace(_clientSecret))
        {
            _errorMessage = "Não foi possível inicializar o pagamento.";
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var successUrl = Navigation.ToAbsoluteUri("/membership/success").ToString();
            var result = await Js.InvokeAsync<string?>("fitplayStripe.confirm", successUrl);
            if (!string.IsNullOrWhiteSpace(result))
            {
                _errorMessage = result;
            }
            else
            {
                Navigation.NavigateTo("/membership/success");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
