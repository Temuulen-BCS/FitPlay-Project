@page "/trainer/users"
@rendermode InteractiveServer
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ApiClient Api
@layout TrainerLayout

<PageTitle>My Students - FitPlay</PageTitle>

<div class="users-page">
    <div class="page-header">
        <div class="header-text">
            <h1>My Students</h1>
            <p class="subtitle">Users who booked your classes</p>
        </div>
        @if (!_isLoading && _enrolledUsers.Any())
        {
            <div class="student-count">
                <span class="count-badge">@_enrolledUsers.Count</span>
                <span class="count-label">student@(_enrolledUsers.Count != 1 ? "s" : "")</span>
            </div>
        }
    </div>

    @if (!_isLoading && _enrolledUsers.Any())
    {
        <div class="search-bar">
            <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text" @bind="_searchTerm" @bind:event="oninput" placeholder="Search by name or email..." />
        </div>
    }

    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>Loading your students...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <div class="error-state">
            <p>@_error</p>
        </div>
    }
    else if (!_enrolledUsers.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
            </div>
            <h3>No students yet</h3>
            <p>Students will appear here once they book your class sessions.</p>
        </div>
    }
    else
    {
        var filtered = FilteredUsers;
        @if (!filtered.Any())
        {
            <div class="empty-state">
                <p>No students match "<strong>@_searchTerm</strong>"</p>
            </div>
        }
        else
        {
            <div class="users-grid">
                @foreach (var user in filtered)
                {
                    <div class="user-card">
                        <div class="card-top">
                            <div class="user-avatar">@GetInitials(user.Name)</div>
                            <div class="user-info">
                                <h3 class="user-name">@user.Name</h3>
                                <p class="user-email">@user.Email</p>
                            </div>
                        </div>

                        <div class="card-stats">
                            <div class="stat">
                                <span class="stat-value">@user.SessionCount</span>
                                <span class="stat-label">Session@(user.SessionCount != 1 ? "s" : "")</span>
                            </div>
                            <div class="stat">
                                <span class="stat-value">@user.TotalPaid.ToString("C")</span>
                                <span class="stat-label">Total Paid</span>
                            </div>
                            <div class="stat">
                                <span class="stat-value status-@user.LatestStatus.ToLower()">@user.LatestStatus</span>
                                <span class="stat-label">Latest</span>
                            </div>
                        </div>

                        <div class="card-footer">
                            <span class="enrolled-date">Joined @user.FirstEnrolledAt.ToString("MMM d, yyyy")</span>
                            <a href="/trainer/users/@user.DomainUserId" class="btn-manage">
                                Manage
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6" />
                                </svg>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<style>
    .users-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .page-header h1 {
        margin: 0 0 4px 0;
        font-size: 28px;
        color: var(--text-primary);
    }

    .subtitle {
        margin: 0;
        color: var(--text-muted);
        font-size: 15px;
    }

    .student-count {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(14,240,255,0.12), rgba(255,47,180,0.12));
        border: 1px solid rgba(14,240,255,0.3);
        font-size: 18px;
        font-weight: 700;
        color: var(--accent-teal);
    }

    .count-label {
        font-size: 14px;
        color: var(--text-muted);
        font-weight: 500;
    }

    /* Search */
    .search-bar {
        position: relative;
        margin-bottom: 24px;
    }

    .search-bar .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        pointer-events: none;
    }

    .search-bar input {
        width: 100%;
        padding: 14px 16px 14px 48px;
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        background: var(--glass-bg);
        color: var(--text-primary);
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
    }

    .search-bar input::placeholder {
        color: var(--text-muted);
    }

    .search-bar input:focus {
        border-color: rgba(14,240,255,0.4);
        box-shadow: 0 0 16px rgba(14,240,255,0.1);
    }

    /* Grid */
    .users-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
    }

    /* Card */
    .user-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .user-card:hover {
        border-color: rgba(14,240,255,0.25);
        box-shadow: 0 8px 32px rgba(14,240,255,0.06), 0 8px 24px rgba(0,0,0,0.18);
    }

    .card-top {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
    }

    .user-avatar {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(14,240,255,0.15), rgba(255,47,180,0.15));
        border: 1px solid rgba(14,240,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
        color: var(--accent-teal);
        flex-shrink: 0;
        letter-spacing: 1px;
    }

    .user-info {
        overflow: hidden;
    }

    .user-name {
        margin: 0 0 2px 0;
        font-size: 16px;
        font-weight: 600;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-email {
        margin: 0;
        font-size: 13px;
        color: var(--text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Stats row */
    .card-stats {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        padding: 14px;
        background: rgba(0,0,0,0.2);
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.04);
    }

    .card-stats .stat {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .card-stats .stat-value {
        font-size: 15px;
        font-weight: 700;
        color: var(--text-primary);
    }

    .card-stats .stat-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        font-weight: 500;
    }

    .status-confirmed { color: var(--accent-green) !important; }
    .status-pending { color: var(--accent-gold) !important; }
    .status-cancelled { color: #ff9aa2 !important; }
    .status-completed { color: var(--accent-teal) !important; }

    /* Footer */
    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .enrolled-date {
        font-size: 12px;
        color: var(--text-muted);
    }

    .btn-manage {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        color: var(--accent-teal);
        background: rgba(14,240,255,0.08);
        border: 1px solid rgba(14,240,255,0.25);
        transition: all 0.2s;
    }

    .btn-manage:hover {
        background: rgba(14,240,255,0.14);
        border-color: rgba(14,240,255,0.5);
        box-shadow: 0 0 16px rgba(14,240,255,0.15);
    }

    /* States */
    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 80px 0;
        gap: 16px;
        color: var(--text-muted);
    }

    .loading-spinner {
        width: 36px;
        height: 36px;
        border: 3px solid var(--glass-border);
        border-top-color: var(--accent-teal);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-muted);
    }

    .empty-icon {
        margin-bottom: 16px;
        opacity: 0.4;
    }

    .empty-state h3 {
        margin: 0 0 8px 0;
        font-size: 20px;
        color: var(--text-primary);
    }

    .empty-state p {
        margin: 0;
        font-size: 14px;
    }

    .error-state {
        text-align: center;
        padding: 60px 20px;
        color: #ff9aa2;
    }

    @@media (max-width: 768px) {
        .users-grid {
            grid-template-columns: 1fr;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }
    }
</style>

@code {
    private bool _isLoading = true;
    private string? _error;
    private string _searchTerm = "";
    private List<EnrolledUserViewModel> _enrolledUsers = new();

    private List<EnrolledUserViewModel> FilteredUsers =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? _enrolledUsers
            : _enrolledUsers.Where(u =>
                u.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                u.Email.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
            ).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadEnrolledUsers();
    }

    private async Task LoadEnrolledUsers()
    {
        _isLoading = true;
        _error = null;

        try
        {
            // 1. Resolve the current trainer's identity ID
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user?.Identity?.IsAuthenticated != true)
            {
                _error = "You must be signed in as a trainer.";
                return;
            }

            var identityId = user.FindFirstValue(ClaimTypes.NameIdentifier);
            if (string.IsNullOrWhiteSpace(identityId))
            {
                _error = "Could not resolve your identity.";
                return;
            }

            // 2. Get all sessions for this trainer
            var sessions = await Api.GetTrainerSessionsV3(identityId);
            if (!sessions.Any())
            {
                _enrolledUsers = new();
                return;
            }

            // 3. For each session, get the enrollments
            var enrollmentTasks = sessions.Select(s => Api.GetSessionEnrollments(s.Id));
            var enrollmentResults = await Task.WhenAll(enrollmentTasks);

            // Build a map: identityUserId → aggregate data
            var userMap = new Dictionary<string, UserEnrollmentAggregate>();
            for (int i = 0; i < sessions.Count; i++)
            {
                var session = sessions[i];
                var enrollments = enrollmentResults[i];
                foreach (var enrollment in enrollments)
                {
                    if (!userMap.TryGetValue(enrollment.UserId, out var agg))
                    {
                        agg = new UserEnrollmentAggregate
                        {
                            IdentityUserId = enrollment.UserId,
                            SessionCount = 0,
                            TotalPaid = 0,
                            FirstEnrolledAt = enrollment.EnrolledAt,
                            LatestStatus = enrollment.Status
                        };
                        userMap[enrollment.UserId] = agg;
                    }

                    agg.SessionCount++;
                    agg.TotalPaid += enrollment.PaidAmount;
                    if (enrollment.EnrolledAt < agg.FirstEnrolledAt)
                        agg.FirstEnrolledAt = enrollment.EnrolledAt;
                    agg.LatestStatus = enrollment.Status;
                }
            }

            if (!userMap.Any())
            {
                _enrolledUsers = new();
                return;
            }

            // 4. Fetch all platform users and match by IdentityUserId
            var allUsers = await Api.GetUsers();
            var userLookup = allUsers
                .Where(u => u.IdentityUserId != null)
                .ToDictionary(u => u.IdentityUserId!, u => u);

            // 5. Join the data
            _enrolledUsers = userMap.Values
                .Select(agg =>
                {
                    userLookup.TryGetValue(agg.IdentityUserId, out var domainUser);
                    return new EnrolledUserViewModel
                    {
                        DomainUserId = domainUser?.Id ?? 0,
                        IdentityUserId = agg.IdentityUserId,
                        Name = domainUser?.Name ?? "Unknown User",
                        Email = domainUser?.Email ?? "-",
                        SessionCount = agg.SessionCount,
                        TotalPaid = agg.TotalPaid,
                        FirstEnrolledAt = agg.FirstEnrolledAt,
                        LatestStatus = agg.LatestStatus
                    };
                })
                .OrderByDescending(u => u.SessionCount)
                .ThenBy(u => u.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading enrolled users: {ex.Message}");
            _error = "Failed to load student data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name[0].ToString().ToUpperInvariant();
    }

    private class UserEnrollmentAggregate
    {
        public string IdentityUserId { get; set; } = "";
        public int SessionCount { get; set; }
        public decimal TotalPaid { get; set; }
        public DateTime FirstEnrolledAt { get; set; }
        public string LatestStatus { get; set; } = "";
    }

    private class EnrolledUserViewModel
    {
        public int DomainUserId { get; set; }
        public string IdentityUserId { get; set; } = "";
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public int SessionCount { get; set; }
        public decimal TotalPaid { get; set; }
        public DateTime FirstEnrolledAt { get; set; }
        public string LatestStatus { get; set; } = "";
    }
}
