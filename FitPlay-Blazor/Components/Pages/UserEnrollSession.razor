@page "/user/sessions/enroll"
@attribute [Authorize(Roles = "User")]
@layout UserLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using FitPlay.Blazor.Services
@inject ApiClient Api

<PageTitle>Enroll Session - FitPlay</PageTitle>

<div class="page-wrap">
    <h1>Enroll in a Session</h1>

    <div class="row">
        <input type="number" min="1" @bind="_sessionId" placeholder="Session ID" />
        <button @onclick="LoadSession">Load Session</button>
    </div>

    @if (_session is not null)
    {
        <article class="card">
            <h3>@_session.Title</h3>
            <p>@_session.Description</p>
            <p>@_session.StartTime.ToLocalTime().ToString("dd MMM yyyy HH:mm") - @_session.EndTime.ToLocalTime().ToString("HH:mm")</p>
            <p>Price: @_session.PricePerStudent.ToString("C") | Enrolled: @_session.EnrolledStudents / @_session.MaxStudents</p>
            <button @onclick="Enroll" disabled="@_loading">@(_loading ? "Enrolling..." : "Enroll")</button>
        </article>
    }

    @if (_enrollment is not null)
    {
        <div class="card">
            <p>Enrollment created: #@_enrollment.Id (status: @_enrollment.Status)</p>
            <RoomCheckInCard EnrollmentId="@_enrollment.Id" OnCheckedIn="OnCheckedIn" />
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_xpMessage))
    {
        <p class="ok">@_xpMessage</p>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="error">@_error</p>
    }
</div>

@code {
    private int _sessionId;
    private bool _loading;
    private string? _error;
    private string? _xpMessage;

    private ApiClient.ClassSessionRead? _session;
    private ApiClient.ClassEnrollmentRead? _enrollment;

    private async Task LoadSession()
    {
        _error = null;
        _session = null;
        _enrollment = null;

        try
        {
            _session = await Api.GetSession(_sessionId);
            if (_session is null)
            {
                _error = "Session not found.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Enroll()
    {
        _loading = true;
        _error = null;

        try
        {
            _enrollment = await Api.EnrollSession(_sessionId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnCheckedIn(int xp)
    {
        _xpMessage = $"Check-in confirmed. You earned +{xp} XP.";
        return Task.CompletedTask;
    }
}

<style>
    .page-wrap { max-width: 860px; margin: 0 auto; padding: 24px; }
    .row { display: flex; gap: 8px; margin-bottom: 12px; }
    input,button { padding: 10px; border-radius: 10px; border: 1px solid var(--glass-border); background: rgba(255,255,255,.06); color: var(--text-primary); }
    button { background: linear-gradient(135deg, var(--accent-teal), var(--accent-magenta)); border: none; color: #fff; font-weight: 700; }
    .card { background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 12px; padding: 12px; margin-top: 10px; }
    .ok { color: #7dff8e; }
    .error { color: #ff9aa2; }
</style>
