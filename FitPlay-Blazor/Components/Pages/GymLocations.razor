
@page "/gym/locations"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "GymAdmin")]
@layout GymAdminLayout

@using Microsoft.AspNetCore.Authorization
@using FitPlay_Blazor.Components.Layout
@using FitPlay.Blazor.Services

@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Locations - FitPlay Gym</PageTitle>

<div class="gym-page">
    <div class="page-header">
        <div>
            <p class="page-eyebrow">Gym Partner</p>
            <h1 class="page-title">Locations</h1>
            <p class="page-sub">Manage your gym branches and their details.</p>
        </div>
        <div class="header-actions">
            @if (_gym != null && !_showForm)
            {
                <button class="btn-gym-primary" @onclick="OpenAddForm">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                    Add Location
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMsg))
    {
        <div class="alert-success">@_successMsg</div>
    }
    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="alert-error">@_errorMsg</div>
    }

    @if (_loading)
    {
        <div class="gym-loading">
            <div class="loading-spinner"></div>
            <p>Loading locations…</p>
        </div>
    }
    else if (_gym == null)
    {
        <div class="empty-state">
            <p>No gym found. <a href="/gym/setup">Register your gym first.</a></p>
        </div>
    }
    else
    {
        <!-- Add/Edit Form -->
        @if (_showForm)
        {
            <div class="form-card" style="margin-bottom: 1.5rem;">
                <h3 class="form-card-title">@(_editId.HasValue ? "Edit Location" : "New Location")</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label>Location Name *</label>
                        <input class="form-input" @bind="_fName" placeholder="e.g. Downtown Branch" />
                    </div>
                    <div class="form-group">
                        <label>Address *</label>
                        <input class="form-input" @bind="_fAddress" placeholder="Street and number" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>City *</label>
                        <input class="form-input" @bind="_fCity" placeholder="e.g. São Paulo" />
                    </div>
                    <div class="form-group">
                        <label>State *</label>
                        <input class="form-input" @bind="_fState" placeholder="e.g. SP" maxlength="2" />
                    </div>
                    <div class="form-group">
                        <label>ZIP Code</label>
                        <input class="form-input" @bind="_fZip" placeholder="00000-000" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Latitude</label>
                        <input class="form-input" type="number" step="any" @bind="_fLat" placeholder="-23.5505" />
                    </div>
                    <div class="form-group">
                        <label>Longitude</label>
                        <input class="form-input" type="number" step="any" @bind="_fLng" placeholder="-46.6333" />
                    </div>
                </div>
                <div class="form-group toggle-group">
                    <label class="toggle-label">
                        <input type="checkbox" class="toggle-input" @bind="_fIsActive" />
                        <span class="toggle-track"></span>
                        <span>Location is active and accepting bookings</span>
                    </label>
                </div>
                <div class="form-actions">
                    <button class="btn-gym-primary" @onclick="SaveLocation" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="btn-spinner"></span><span>Saving…</span>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>@(_editId.HasValue ? "Save Changes" : "Create Location")</span>
                        }
                    </button>
                    <button class="btn-gym-outline" @onclick="CancelForm">Cancel</button>
                </div>
            </div>
        }

        <!-- Locations list -->
        @if (_locations.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <p>No locations yet. Add your first branch to start accepting bookings.</p>
                <button class="btn-gym-primary" @onclick="OpenAddForm">Add First Location</button>
            </div>
        }
        else
        {
            <div class="locations-grid">
                @foreach (var loc in _locations)
                {
                    <div class="location-card @(!loc.IsActive ? "card-inactive" : "")">
                        <div class="location-card-header">
                            <div class="location-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            </div>
                            <span class="location-status @(loc.IsActive ? "status-active" : "status-inactive")">
                                @(loc.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                        <h4 class="location-card-name">@loc.Name</h4>
                        <p class="location-card-address">@loc.Address</p>
                        <p class="location-card-city">@loc.City, @loc.State · @loc.ZipCode</p>
                        <div class="location-card-actions">
                            <a href="/gym/rooms?locationId=@loc.Id" class="btn-gym-ghost btn-sm">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                                Rooms
                            </a>
                            <button class="btn-gym-ghost btn-sm" @onclick="() => OpenEditForm(loc)">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Edit
                            </button>
                            <button class="btn-danger-ghost btn-sm" @onclick="() => ConfirmDelete(loc.Id)">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                Delete
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<!-- Delete confirm modal -->
@if (_deleteConfirmId.HasValue)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-card" @onclick:stopPropagation>
            <h3>Delete Location?</h3>
            <p>This will permanently remove the location and all associated rooms. This cannot be undone.</p>
            <div class="modal-actions">
                <button class="btn-danger" @onclick="ExecuteDelete" disabled="@_saving">
                    @(_saving ? "Deleting…" : "Yes, Delete")
                </button>
                <button class="btn-gym-outline" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _saving = false;
    private bool _showForm = false;
    private string? _successMsg;
    private string? _errorMsg;

    private ApiClient.GymRead? _gym;
    private List<ApiClient.GymLocationRead> _locations = new();
    private int? _editId;
    private int? _deleteConfirmId;

    // Form fields
    private string _fName = "";
    private string _fAddress = "";
    private string _fCity = "";
    private string _fState = "";
    private string _fZip = "";
    private double? _fLat;
    private double? _fLng;
    private bool _fIsActive = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _gym = await Api.GetMyGym();
            if (_gym != null)
                _locations = await Api.GetGymLocations(_gym.Id);
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
        }
        finally { _loading = false; }
    }

    private void OpenAddForm()
    {
        _editId = null;
        _fName = _fAddress = _fCity = _fState = _fZip = "";
        _fLat = _fLng = null;
        _fIsActive = true;
        _showForm = true;
    }

    private void OpenEditForm(ApiClient.GymLocationRead loc)
    {
        _editId = loc.Id;
        _fName = loc.Name;
        _fAddress = loc.Address;
        _fCity = loc.City;
        _fState = loc.State;
        _fZip = loc.ZipCode;
        _fLat = loc.Latitude;
        _fLng = loc.Longitude;
        _fIsActive = loc.IsActive;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _editId = null;
    }

    private async Task SaveLocation()
    {
        if (_gym == null) return;

        if (string.IsNullOrWhiteSpace(_fName) ||
            string.IsNullOrWhiteSpace(_fAddress) ||
            string.IsNullOrWhiteSpace(_fCity) ||
            string.IsNullOrWhiteSpace(_fState) ||
            string.IsNullOrWhiteSpace(_fZip))
        {
            _errorMsg = "Please fill all required fields (Name, Address, City, State and ZIP Code).";
            return;
        }

        _saving = true;
        _successMsg = _errorMsg = null;
        try
        {
            if (_editId.HasValue)
            {
                var updateReq = new ApiClient.UpdateGymLocationRequest(
                    _fName, _fAddress, _fCity, _fState, _fZip, _fLat, _fLng, _fIsActive);
                await Api.UpdateGymLocation(_gym.Id, _editId.Value, updateReq);
            }
            else
            {
                var createReq = new ApiClient.CreateGymLocationRequest(
                    _fName, _fAddress, _fCity, _fState, _fZip, _fLat, _fLng);
                await Api.CreateGymLocation(_gym.Id, createReq);
            }

            _locations = await Api.GetGymLocations(_gym.Id);
            _successMsg = _editId.HasValue ? "Location updated." : "Location created.";
            _showForm = false;
            _editId = null;
        }
        catch (Exception ex) { _errorMsg = ex.Message; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(int id) => _deleteConfirmId = id;
    private void CancelDelete() => _deleteConfirmId = null;

    private async Task ExecuteDelete()
    {
        if (_gym == null || !_deleteConfirmId.HasValue) return;
        _saving = true;
        try
        {
            await Api.DeleteGymLocation(_gym.Id, _deleteConfirmId.Value);
            _locations = await Api.GetGymLocations(_gym.Id);
            _successMsg = "Location deleted.";
        }
        catch (Exception ex) { _errorMsg = ex.Message; }
        finally { _saving = false; _deleteConfirmId = null; }
    }
}

<style>
    .gym-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
        color: var(--text-primary, #f8f9fb);
    }
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; }
    .page-eyebrow { margin: 0 0 4px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.18em; color: #0ef0ff; }
    .page-title   { margin: 0 0 0.25rem; font-size: 2rem; font-weight: 700; }
    .page-sub     { margin: 0; color: var(--text-muted, #9aa0b5); font-size: 0.9rem; }
    .header-actions { display: flex; gap: 0.75rem; align-items: center; }

    /* Alerts */
    .alert-success { background: rgba(14,240,255,0.08); border: 1px solid rgba(14,240,255,0.25); color: #0ef0ff; padding: 0.75rem 1rem; border-radius: 10px; margin-bottom: 1.25rem; font-size: 0.9rem; }
    .alert-error   { background: rgba(255,47,180,0.08); border: 1px solid rgba(255,47,180,0.25); color: #ff2fb4; padding: 0.75rem 1rem; border-radius: 10px; margin-bottom: 1.25rem; font-size: 0.9rem; }

    /* Loading */
    .gym-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 30vh; gap: 1rem; color: var(--text-muted, #9aa0b5); }
    .loading-spinner { width: 36px; height: 36px; border: 3px solid rgba(14,240,255,0.2); border-top-color: #0ef0ff; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Empty state */
    .empty-state { text-align: center; padding: 4rem 2rem; color: var(--text-muted, #9aa0b5); }
    .empty-icon { width: 64px; height: 64px; background: rgba(14,240,255,0.06); border: 1px solid rgba(14,240,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: #0ef0ff; }
    .empty-state p { margin-bottom: 1.25rem; }
    .empty-state a { color: #0ef0ff; }

    /* Form card */
    .form-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(14,240,255,0.14); border-radius: 18px; padding: 1.75rem; }
    .form-card-title { margin: 0 0 1.25rem; font-size: 1rem; font-weight: 700; color: #0ef0ff; }
    .form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.875rem; margin-bottom: 0.875rem; }
    .form-group { display: flex; flex-direction: column; }
    .form-group label { font-size: 0.85rem; font-weight: 500; margin-bottom: 0.4rem; }
    .form-input {
        padding: 0.7rem 0.9rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        color: var(--text-primary, #f8f9fb);
        font-size: 0.92rem;
        font-family: inherit;
        transition: border-color 0.2s, box-shadow 0.2s;
        width: 100%;
        box-sizing: border-box;
    }
    .form-input:focus { outline: none; border-color: #0ef0ff; box-shadow: 0 0 0 3px rgba(14,240,255,0.1); }
    .form-input::placeholder { color: var(--text-muted, #9aa0b5); }
    .toggle-group { margin-top: 0.2rem; }
    .toggle-label { display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-size: 0.9rem; }
    .toggle-input { display: none; }
    .toggle-track {
        width: 42px; height: 24px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 30px;
        position: relative;
        flex-shrink: 0;
        transition: background 0.2s;
    }
    .toggle-track::after {
        content: '';
        position: absolute;
        width: 18px; height: 18px;
        background: #fff;
        border-radius: 50%;
        top: 2px; left: 2px;
        transition: transform 0.2s, background 0.2s;
    }
    .toggle-input:checked + .toggle-track { background: #0ef0ff; border-color: #0ef0ff; }
    .toggle-input:checked + .toggle-track::after { transform: translateX(18px); background: #001e24; }
    .form-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; align-items: center; flex-wrap: wrap; }

    /* Locations grid */
    .locations-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }

    .location-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 1.25rem;
        transition: border-color 0.2s, transform 0.2s;
    }
    .location-card:hover { border-color: rgba(14,240,255,0.25); transform: translateY(-2px); }
    .card-inactive { opacity: 0.65; }
    .location-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
    .location-icon { width: 38px; height: 38px; background: rgba(14,240,255,0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #0ef0ff; }
    .location-status { font-size: 0.72rem; font-weight: 600; padding: 2px 9px; border-radius: 20px; }
    .status-active   { background: rgba(14,240,255,0.12); color: #0ef0ff; border: 1px solid rgba(14,240,255,0.3); }
    .status-inactive { background: rgba(255,255,255,0.06); color: var(--text-muted,#9aa0b5); border: 1px solid rgba(255,255,255,0.1); }
    .location-card-name    { margin: 0 0 0.3rem; font-size: 1rem; font-weight: 700; }
    .location-card-address { margin: 0 0 0.15rem; font-size: 0.85rem; color: var(--text-muted,#9aa0b5); }
    .location-card-city    { margin: 0 0 1rem; font-size: 0.8rem; color: var(--text-muted,#9aa0b5); }
    .location-card-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }

    /* Status chips */
    .status-active   { background: rgba(14,240,255,0.12); color: #0ef0ff; border: 1px solid rgba(14,240,255,0.3); }
    .status-inactive { background: rgba(255,255,255,0.06); color: var(--text-muted,#9aa0b5); border: 1px solid rgba(255,255,255,0.1); }

    /* Buttons */
    .btn-gym-primary {
        display: inline-flex; align-items: center; gap: 6px;
        background: linear-gradient(135deg, #0ef0ff, #09c8d4);
        color: #001e24; border: none; padding: 0.7rem 1.25rem;
        border-radius: 30px; font-weight: 700; font-size: 0.88rem;
        font-family: inherit; cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
        box-shadow: 0 4px 16px rgba(14,240,255,0.35);
        text-decoration: none;
    }
    .btn-gym-primary:hover:not(:disabled) { transform: scale(1.03); }
    .btn-gym-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn-spinner { width: 14px; height: 14px; border: 2px solid rgba(0,30,36,0.3); border-top-color: #001e24; border-radius: 50%; animation: spin 0.8s linear infinite; }

    .btn-gym-outline {
        display: inline-flex; align-items: center; gap: 6px;
        background: transparent; color: #0ef0ff;
        border: 1.5px solid rgba(14,240,255,0.4);
        padding: 0.6rem 1.1rem; border-radius: 30px;
        font-weight: 600; font-size: 0.85rem; font-family: inherit;
        text-decoration: none; cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
    }
    .btn-gym-outline:hover { background: rgba(14,240,255,0.08); }

    .btn-gym-ghost {
        display: inline-flex; align-items: center; gap: 5px;
        background: transparent; color: var(--text-muted,#9aa0b5);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px; font-size: 0.8rem; font-family: inherit;
        text-decoration: none; cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
        padding: 0.35rem 0.75rem;
    }
    .btn-gym-ghost:hover { color: #0ef0ff; border-color: rgba(14,240,255,0.3); }
    .btn-sm { padding: 0.35rem 0.75rem; font-size: 0.78rem; }

    .btn-danger-ghost {
        display: inline-flex; align-items: center; gap: 5px;
        background: transparent; color: rgba(255,47,180,0.65);
        border: 1px solid rgba(255,47,180,0.2);
        border-radius: 20px; font-size: 0.78rem; font-family: inherit;
        cursor: pointer; padding: 0.35rem 0.75rem;
        transition: color 0.2s, border-color 0.2s;
    }
    .btn-danger-ghost:hover { color: #ff2fb4; border-color: rgba(255,47,180,0.5); }
    .btn-danger {
        background: linear-gradient(135deg, #ff2fb4, #c01888);
        color: #fff; border: none; padding: 0.7rem 1.25rem;
        border-radius: 30px; font-weight: 700; font-size: 0.88rem; font-family: inherit; cursor: pointer;
        transition: opacity 0.2s;
    }
    .btn-danger:disabled { opacity: 0.6; cursor: not-allowed; }

    /* Modal */
    .modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.7);
        backdrop-filter: blur(4px); z-index: 8000;
        display: flex; align-items: center; justify-content: center; padding: 1rem;
    }
    .modal-card {
        background: #0d1117; border: 1px solid rgba(255,47,180,0.3);
        border-radius: 18px; padding: 2rem; max-width: 440px; width: 100%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    }
    .modal-card h3 { margin: 0 0 0.75rem; font-size: 1.2rem; }
    .modal-card p  { color: var(--text-muted,#9aa0b5); margin-bottom: 1.5rem; font-size: 0.9rem; }
    .modal-actions { display: flex; gap: 0.75rem; }
</style>
