@page "/user/book-class"
@rendermode InteractiveServer
@layout UserLayout
@using FitPlay.Blazor.Services
@using System.Security.Claims
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "ActiveMembership")]
@inject ApiClient Api
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<PageTitle>Book a Class - FitPlay</PageTitle>

<div class="book-class-page">
    <div class="page-header">
        <h1>Book a Class</h1>
        <p class="subtitle">Find and book classes with our trainers!</p>
    </div>

    @if (_isLoading)
    {
        <div class="loading">Loading available classes...</div>
    }
    else if (!_publicClasses.Any() && !_userClasses.Any())
    {
        <div class="no-classes">
            <p>No classes available at the moment. Check back later!</p>
        </div>
    }
    else
    {
        @if (_publicClasses.Any())
        {
          
            <section class="section classes-section" id="classes">
                <h2 class="section-title">Class's Line-Up</h2>
                <p class="section-sub">From HIIT to Yoga — experience workouts that push limits.</p>
                <div class="classes-grid">
                    @foreach (var classItem in _publicClasses)
                    {
                        var intensity = GetIntensity(classItem.Modality, classItem.Notes);
                        <div class="class-card">
                            <div class="class-header">
                                <span class="class-time">@classItem.ScheduledAt.ToString("HH:mm")</span>
                                <span class="intensity @intensity.CssClass">@intensity.Label</span>
                            </div>
                            <h3 class="class-name">@classItem.Modality</h3>
                            <p class="class-meta">@GetClassMeta(classItem)</p>
                            <div class="class-tags">
                                <span class="slots">@GetSlotsLabel(classItem.Notes)</span>
                                <span class="price-tag">@GetPriceLabel(classItem.Notes)</span>
                            </div>
                            <button class="btn-book" @onclick="() => bookClass(classItem.Id)" disabled="@(isBooking || _isInitiatingPayment)">
                                @(isBooking || _isInitiatingPayment ? "Please wait..." : "Book Now")
                            </button>
                        </div>
                    }
                </div>
            </section>
        }

        @if (_userClasses.Any())
        {
            <section class="section classes-section">
                <h2 class="section-title">My Booked Classes</h2>
       
                <div class="classes-grid">
                    @foreach (var classItem in _userClasses)
                    {
                        var intensity = GetIntensity(classItem.Modality, classItem.Notes);
                        <div class="class-card booked">
                            <div class="class-header">
                                <span class="class-time">@classItem.ScheduledAt.ToString("ddd, MMM dd")</span>
                                <span class="intensity @intensity.CssClass">@intensity.Label</span>
                            </div>
                            <h3 class="class-name">@classItem.Modality</h3>
                            <p class="class-meta">Status: @classItem.Status</p>
                            <div class="class-tags">
                                <span class="slots">@GetSlotsLabel(classItem.Notes)</span>
                                <span class="price-tag">@GetPriceLabel(classItem.Notes)</span>
                            </div>
                            @if (classItem.PaymentStatus == "Completed")
                            {
                                <span class="payment-badge paid">Paid @(classItem.PaidAmount?.ToString("C") ?? "")</span>
                            }
                            <button class="btn-cancel" @onclick="() => PromptCancel(classItem)">Cancel Booking</button>
                        </div>
                    }
                </div>
            </section>
        }
    }
</div>

<style>
    .book-class-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px;
    }

    .page-header {
        margin-bottom: 32px;
    }

