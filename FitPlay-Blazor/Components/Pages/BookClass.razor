@page "/user/book-class"
@rendermode InteractiveServer
@layout UserLayout
@using FitPlay.Blazor.Services
@using System.Security.Claims
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<PageTitle>Book a Class - FitPlay</PageTitle>

<div class="book-class-page">
    <div class="page-header">
        <h1>
            Class's Line-Up
        </h1>
        <p class="subtitle">Find and book classes with our trainers!</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(_paymentError))
    {
        <div class="error-banner">
            <div class="error-header">
                <span>⚠️ Booking Error</span>
                <button @onclick="() => _paymentError = null" class="btn-close-error">×</button>
            </div>
            <p>@_paymentError</p>
        </div>
    }

    @{
        var notifiedClasses = _userQueueEntries
            .Where(e => e.IsNotified && !e.IsSkipped)
            .Select(e => _publicClasses.FirstOrDefault(c => c.Id == e.ClassScheduleId))
            .Where(c => c != null)
            .ToList();
    }
    @if (notifiedClasses.Any())
    {
        <div class="notification-banner">
            <div class="notification-banner-header">
                <span class="notification-icon">🎉</span>
                <span>Classes now available — the trainer has confirmed the Class!</span>
                @if (_monthlySkipCount > 0)
                {
                    <span class="skip-counter @(_monthlySkipCount >= 5 ? "skip-counter-limit" : "")">s
                        @_monthlySkipCount / 5 skips this month
                    </span>
                }
            </div>
            @if (_monthlySkipCount >= 5)
            {
                <div class="skip-limit-warning">
                    You have reached the 5-skip limit for this month. Joining new queues requires a 5% deposit.
                </div>
            }
            @foreach (var c in notifiedClasses)
            {
                <div class="notification-item">
                    <div class="notification-info">
                        <strong>@c!.Modality</strong>
                        <span class="notification-time">@c.ScheduledAt.ToLocalTime().ToString("ddd, MMM dd 'at' HH:mm")</span>
                    </div>
                    <div class="notification-actions">
                        <button class="btn-book-now"
                                @onclick="() => bookClass(c.Id)"
                                disabled="@(isBooking || _isInitiatingPayment)">
                            @(isBooking || _isInitiatingPayment ? "Please wait..." : "Book Now")
                        </button>
                        <button class="btn-not-interested"
                                @onclick="() => OpenSkipConfirm(c.Id)"
                                disabled="@(isBooking || _isInitiatingPayment)">
                            Not interested
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    @* ── Skip confirmation modal ── *@
    @if (_skipConfirmScheduleId.HasValue)
    {
        var skipsLeft = 5 - _monthlySkipCount;
        var isLastFree  = skipsLeft == 1;
        var alreadyOver = skipsLeft <= 0;

        <div class="payment-overlay" @onclick="CancelSkipConfirm">
            <div class="skip-confirm-modal" @onclick:stopPropagation="true">
                <div class="payment-header">
                    <div class="skip-confirm-header-left">
                        <span class="skip-confirm-icon">@(alreadyOver ? "🚫" : isLastFree ? "⚠️" : "ℹ️")</span>
                        <h3 class="skip-confirm-title">
                            @if (alreadyOver)      { <text>Skip limit reached</text> }
                            else if (isLastFree)   { <text>Last free skip this month</text> }
                            else                   { <text>Not interested?</text> }
                        </h3>
                    </div>
                    <button class="btn-close-modal" @onclick="CancelSkipConfirm">&#x2715;</button>
                </div>

                <hr class="payment-divider" />

                @if (alreadyOver)
                {
                    <p class="skip-confirm-body">
                        You have used all <strong>5 free skips</strong> for this month.<br />
                        Skipping again will still remove this notification, but joining future queues will require a <strong>5% deposit</strong>.
                    </p>
                }
                else if (isLastFree)
                {
                    <p class="skip-confirm-body">
                        This is your <strong>last free skip</strong> for @_nowUtc.ToString("MMMM").<br />
                        After this, joining any new queue will require a <strong>5% deposit</strong>.<br /><br />
                        Are you sure you're not interested?
                    </p>
                }
                else
                {
                    <p class="skip-confirm-body">
                        You can skip up to <strong>5 times per month</strong> for free.<br />
                        You have <strong>@skipsLeft skip@(skipsLeft == 1 ? "" : "s")</strong> remaining for @_nowUtc.ToString("MMMM").<br /><br />
                        Are you sure you want to skip this class?
                    </p>
                }

                <div class="skip-confirm-actions">
                    <button class="btn-skip-cancel" @onclick="CancelSkipConfirm">
                        Keep it
                    </button>
                    <button class="btn-skip-confirm" @onclick="DismissQueueNotification">
                        Yes, skip it
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_isLoading)
    {
        <div class="loading">Loading available classes...</div>
    }
    else if (!_publicClasses.Any() && !_userClasses.Any())
    {
        <div class="no-classes">
            <p>No classes available at the moment. Check back later!</p>
        </div>
    }
    else
    {
        @if (_publicClasses.Any())
        {
          
            <section class="section classes-section" id="classes">
               
                <div class="classes-grid">
                    @foreach (var classItem in _publicClasses)
                    {
                        var intensity = GetIntensity(classItem.Modality, classItem.Notes);
                        <div class="class-card">
                            <div class="class-header">
                                <span class="class-time">@classItem.ScheduledAt.ToLocalTime().ToString("HH:mm")</span>
                                <span class="intensity @intensity.CssClass">@intensity.Label</span>
                            </div>
                            <h3 class="class-name">@classItem.Modality</h3>
                            <p class="class-meta">@GetClassMeta(classItem)</p>
                            <div class="class-tags">
                                <span class="slots">@GetSlotsLabel(classItem.Notes)</span>
                                <span class="price-tag">@GetPriceLabel(classItem.Notes)</span>
                                @if (classItem.MaxCapacity.HasValue)
                                {
                                    <span class="capacity-tag">Capacity: @FormatCapacity(classItem.BookedCount, classItem.MaxCapacity)</span>
                                }
                            </div>
                            <button class="class-expand-btn" @onclick="() => ToggleClassDetails(classItem.Id)">
                                @(_expandedClassIds.Contains(classItem.Id) ? "−" : "+")
                            </button>
                            @if (_expandedClassIds.Contains(classItem.Id))
                            {
                                <div class="class-details">
                                    <div class="detail-row">
                                        <span class="detail-label">Day</span>
                                        <span class="detail-value">@classItem.ScheduledAt.ToLocalTime().ToString("dddd, MMMM dd, yyyy")</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Time Start</span>
                                        <span class="detail-value">@classItem.ScheduledAt.ToLocalTime().ToString("HH:mm")</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Time End</span>
                                        <span class="detail-value">@classItem.ScheduledAt.AddMinutes(classItem.DurationMinutes ?? 0).ToLocalTime().ToString("HH:mm")</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Capacity</span>
                                        <span class="detail-value">@FormatCapacity(classItem.BookedCount, classItem.MaxCapacity)</span>
                                    </div>
                                    @if (classItem.MaxCapacity.HasValue)
                                    {
                                        <div class="capacity-bar">
                                            <div class="capacity-fill" style="width: @(GetCapacityPercent(classItem.BookedCount, classItem.MaxCapacity))%"></div>
                                        </div>
                                    }
                                    @{
                                        var expandDuration = FormatDuration(classItem.DurationMinutes);
                                    }
                                    @if (!string.IsNullOrEmpty(expandDuration))
                                    {
                                        <div class="detail-row">
                                            <span class="detail-label">Duration</span>
                                            <span class="detail-value">@expandDuration</span>
                                        </div>
                                    }
                                    <div class="detail-row">
                                        <span class="detail-label">Trainer</span>
                                        <span class="detail-value">@classItem.TrainerName</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Room Status</span>
                                        <span class="detail-value">@(classItem.RoomBookingStatus ?? "N/A")</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Location</span>
                                        <span class="detail-value">@FormatFullLocation(classItem.GymLocationName, classItem.GymLocationAddress, classItem.GymLocationCity, classItem.GymLocationState, classItem.GymLocationZipCode)</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(classItem.RoomName))
                                    {
                                        <div class="detail-row">
                                            <span class="detail-label">Room</span>
                                            <span class="detail-value">@classItem.RoomName</span>
                                        </div>
                                    }
                                    <a href="/user/gym-checkin" class="checkin-link">Check In / Check Out</a>
                                </div>
                            }
                            @if (classItem.RoomBookingStatus == "Pending")
                            {
                                @* Queue flow: trainer hasn't paid for the room yet *@
                                if (_queuedClassIds.Contains(classItem.Id))
                                {
                                    <div class="queue-badge">You're in the queue</div>
                                }
                                else
                                {
                                    <div class="queue-info">
                                        <span class="queue-cost">@GetQueueCostLabel(classItem.Notes)</span>
                                        @if (classItem.QueueCount > 0)
                                        {
                                            <span class="queue-count">@classItem.QueueCount interested</span>
                                        }
                                    </div>
                                    <button class="btn-queue" @onclick="() => JoinQueue(classItem.Id, classItem.Modality, classItem.Notes)" disabled="@(_isJoiningQueue || _isInitiatingPayment)">
                                        @(_isJoiningQueue ? "Joining..." : "Join the Queue")
                                    </button>
                                    @if (_monthlySkipCount >= 5)
                                    {
                                        <p class="queue-skip-warning">Skip limit reached — a 5% deposit is required this month.</p>
                                    }
                                    else if (_monthlySkipCount == 4)
                                    {
                                        <p class="queue-skip-warning queue-skip-caution">1 skip remaining this month before a deposit is required.</p>
                                    }
                                }
                            }
                            else
                            {
                                @if (classItem.IsBooked)
                                {
                                    <button class="btn-fully-booked" disabled>Fully Booked</button>
                                }
                                else
                                {
                                    <button class="btn-book" @onclick="() => bookClass(classItem.Id)" disabled="@(isBooking || _isInitiatingPayment)">
                                        @(isBooking || _isInitiatingPayment ? "Please wait..." : "Book Now")
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            </section>
        }

        @if (_userClasses.Any())
        {
            <section class="section classes-section">
                <h2 class="section-title">My Booked Classes</h2>
       
                <div class="classes-grid">
                    @foreach (var classItem in _userClasses)
                    {
                        var intensity = GetIntensity(classItem.Modality, classItem.Notes);
                        <div class="class-card booked">
                            <div class="class-header">
                                <span class="class-time">@classItem.ScheduledAt.ToLocalTime().ToString("HH:mm")</span>
                                <span class="intensity @intensity.CssClass">@intensity.Label</span>
                            </div>
                            <h3 class="class-name">@classItem.Modality</h3>
                            <p class="class-meta">Status: @classItem.Status</p>
                            <div class="class-tags">
                                <span class="slots">@GetSlotsLabel(classItem.Notes)</span>
                                <span class="price-tag">@GetPriceLabel(classItem.Notes)</span>
                                @if (classItem.MaxCapacity.HasValue)
                                {
                                    <span class="capacity-tag">Capacity: @FormatCapacity(classItem.BookedCount, classItem.MaxCapacity)</span>
                                }
                            </div>
                            <button class="class-expand-btn" @onclick="() => ToggleClassDetails(classItem.Id)">
                                @(_expandedClassIds.Contains(classItem.Id) ? "−" : "+")
                            </button>
                            @if (_expandedClassIds.Contains(classItem.Id))
                            {
                                <div class="class-details">
                                    <div class="detail-row">
                                        <span class="detail-label">Day</span>
                                        <span class="detail-value">@classItem.ScheduledAt.ToLocalTime().ToString("dddd, MMMM dd, yyyy")</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Time Start</span>
                                        <span class="detail-value">@classItem.ScheduledAt.ToLocalTime().ToString("HH:mm")</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Time End</span>
                                        <span class="detail-value">@classItem.ScheduledAt.AddMinutes(classItem.DurationMinutes ?? 0).ToLocalTime().ToString("HH:mm")</span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="detail-label">Capacity</span>
                                        <span class="detail-value">@FormatCapacity(classItem.BookedCount, classItem.MaxCapacity)</span>
                                    </div>
                                    @if (classItem.MaxCapacity.HasValue)
                                    {
                                        <div class="capacity-bar">
                                            <div class="capacity-fill" style="width: @(GetCapacityPercent(classItem.BookedCount, classItem.MaxCapacity))%"></div>
                                        </div>
                                    }
                                    @{
                                        var bookedExpandDuration = FormatDuration(classItem.DurationMinutes);
                                    }
                                    @if (!string.IsNullOrEmpty(bookedExpandDuration))
                                    {
                                        <div class="detail-row">
                                            <span class="detail-label">Duration</span>
                                            <span class="detail-value">@bookedExpandDuration</span>
                                        </div>
                                    }
                                    <div class="detail-row">
                                        <span class="detail-label">Location</span>
                                        <span class="detail-value">@FormatFullLocation(classItem.GymLocationName, classItem.GymLocationAddress, classItem.GymLocationCity, classItem.GymLocationState, classItem.GymLocationZipCode)</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(classItem.RoomName))
                                    {
                                        <div class="detail-row">
                                            <span class="detail-label">Room</span>
                                            <span class="detail-value">@classItem.RoomName</span>
                                        </div>
                                    }
                                    <a href="/user/gym-checkin" class="checkin-link">Check In / Check Out</a>
                                </div>
                            }
                            @if (classItem.PaymentStatus == "Completed")
                            {
                                <span class="payment-badge paid">Paid @(classItem.PaidAmount?.ToString("C") ?? "")</span>
                            }
                            <button class="btn-cancel" @onclick="() => PromptCancel(classItem)">Cancel Booking</button>
                        </div>
                    }
                </div>
            </section>
        }
    }
</div>

<style>
    .book-class-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px;
    }

    .page-header {
        margin-bottom: 32px;
    }

    .page-header h1 {
        margin: 0 0 8px 0;
        font-size: 28px;
        color: var(--text-primary);
    }

    .subtitle {
        margin: 0;
        color: var(--text-muted);
        font-size: 16px;
    }

    .section {
        margin-bottom: 40px;
    }

    .section-title {
        margin: 0 0 8px 0;
        font-size: 22px;
        color: var(--text-primary);
        letter-spacing: 0.4px;
        text-transform: uppercase;
    }

    .section-sub {
        margin: 0 0 20px 0;
        color: var(--text-muted);
        font-size: 14px;
    }

    .classes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 20px;
    }

    .class-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 18px;
        box-shadow: 0 10px 28px rgba(0,0,0,0.24);
        transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .class-card:hover {
        transform: translateY(-4px);
        border-color: rgba(255,255,255,0.2);
        box-shadow: 0 14px 36px rgba(0,0,0,0.3);
    }

    .class-card.booked {
        border-color: rgba(14,240,255,0.5);
        box-shadow: 0 12px 30px rgba(14,240,255,0.12);
    }

    .class-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }

    .class-time {
        font-weight: 700;
        font-size: 16px;
        color: var(--accent-teal);
    }

    .intensity {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.3px;
        text-transform: uppercase;
    }

    .intensity.high {
        background: rgba(255,47,180,0.2);
        color: var(--accent-magenta);
        border: 1px solid rgba(255,47,180,0.4);
    }

    .intensity.medium {
        background: rgba(255,215,0,0.2);
        color: var(--accent-gold);
        border: 1px solid rgba(255,215,0,0.4);
    }

    .intensity.low {
        background: rgba(14,240,255,0.15);
        color: var(--accent-teal);
        border: 1px solid rgba(14,240,255,0.35);
    }

    .class-name {
        margin: 0 0 6px 0;
        font-size: 18px;
        color: var(--text-primary);
    }

    .class-meta {
        margin: 0 0 14px 0;
        font-size: 13px;
        color: var(--text-muted);
    }

    .slots {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-muted);
    }

    .class-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .price-tag {
        display: inline-flex;
        align-items: center;
        font-size: 12px;
        color: var(--accent-teal);
        border: 1px solid rgba(14,240,255,0.35);
        background: rgba(14,240,255,0.08);
        border-radius: 999px;
        padding: 2px 8px;
    }

    .capacity-tag {
        display: inline-flex;
        align-items: center;
        font-size: 12px;
        color: var(--text-muted);
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.05);
        border-radius: 999px;
        padding: 2px 8px;
    }

    .payment-badge {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 999px;
        margin-bottom: 10px;
    }

    .payment-badge.paid {
        background: rgba(14,240,255,0.15);
        color: var(--accent-teal);
        border: 1px solid rgba(14,240,255,0.4);
    }

    .btn-book {
        width: 100%;
        padding: 12px 14px;
        background: linear-gradient(135deg, rgba(14,240,255,0.08), rgba(255,77,250,0.08));
        border: 2px solid rgba(14,240,255,0.4);
        box-shadow: 0 0 20px rgba(14,240,255,0.2);
        color: white;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .btn-book:hover:not(:disabled) {
        transform: translateY(-2px);
        border-color: rgba(14,240,255,0.7);
        box-shadow: 0 0 28px rgba(14,240,255,0.35);
        background: linear-gradient(135deg, rgba(14,240,255,0.14), rgba(255,77,250,0.14));
    }

    .btn-book:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        box-shadow: none;
    }

    .btn-fully-booked {
        width: 100%;
        padding: 12px 14px;
        background: rgba(255,255,255,0.04);
        border: 2px solid rgba(255,255,255,0.12);
        color: var(--text-muted);
        border-radius: 10px;
        font-weight: 600;
        cursor: not-allowed;
        opacity: 0.7;
    }

    /* ── Queue styles ── */
    .queue-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
        font-size: 12px;
    }

    .queue-cost {
        color: var(--accent-gold, #ffd700);
        font-weight: 600;
    }

    .queue-count {
        color: var(--text-muted);
        font-style: italic;
    }

    .queue-badge {
        text-align: center;
        padding: 10px 14px;
        background: rgba(255,215,0,0.12);
        border: 1px solid rgba(255,215,0,0.35);
        border-radius: 10px;
        color: var(--accent-gold, #ffd700);
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.3px;
    }

    .btn-queue {
        width: 100%;
        padding: 12px 14px;
        background: linear-gradient(135deg, rgba(255,215,0,0.08), rgba(255,165,0,0.08));
        border: 2px solid rgba(255,215,0,0.4);
        box-shadow: 0 0 20px rgba(255,215,0,0.15);
        color: white;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .btn-queue:hover:not(:disabled) {
        transform: translateY(-2px);
        border-color: rgba(255,215,0,0.7);
        box-shadow: 0 0 28px rgba(255,215,0,0.3);
        background: linear-gradient(135deg, rgba(255,215,0,0.14), rgba(255,165,0,0.14));
    }

    .btn-queue:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        box-shadow: none;
    }

    /* ── Notification Banner ── */
    .error-banner {
        background: linear-gradient(135deg, rgba(255,107,107,0.12), rgba(255,71,71,0.08));
        border: 1px solid rgba(255,107,107,0.4);
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 20px;
        box-shadow: 0 0 24px rgba(255,107,107,0.15);
        animation: bannerIn 0.4s ease;
    }

    .error-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 14px;
        font-weight: 700;
        color: #ff6b6b;
        margin-bottom: 8px;
        letter-spacing: 0.2px;
    }

    .error-banner p {
        margin: 0;
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.5;
    }

    .btn-close-error {
        background: transparent;
        border: none;
        color: #ff6b6b;
        font-size: 24px;
        line-height: 1;
        cursor: pointer;
        padding: 0;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .btn-close-error:hover {
        opacity: 1;
    }

    .notification-banner {
        background: linear-gradient(135deg, rgba(255,215,0,0.08), rgba(255,165,0,0.06));
        border: 1px solid rgba(255,215,0,0.35);
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 28px;
        box-shadow: 0 0 24px rgba(255,215,0,0.1);
        animation: bannerIn 0.4s ease;
    }

    @@keyframes bannerIn {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .notification-banner-header {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        font-weight: 700;
        color: var(--accent-gold, #ffd700);
        margin-bottom: 14px;
        letter-spacing: 0.2px;
    }

    .notification-icon {
        font-size: 20px;
    }

    .notification-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
