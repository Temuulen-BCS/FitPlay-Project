    private async Task<int?> ResolveCurrentUserIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("Account/Login", true);
            return null;
        }

        var identityId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrWhiteSpace(identityId))
        {
            Navigation.NavigateTo("Account/Login", true);
            return null;
        }

        var domainUser = await Api.GetUserByIdentity(identityId);
        if (domainUser is null)
        {
            Navigation.NavigateTo("Account/Login", true);
            return null;
        }

        return domainUser.Id;
    }

    private static (string Label, string CssClass) GetIntensity(string? modality, string? notes)
    {
        var source = string.Join(' ', modality, notes).ToLowerInvariant();
        if (source.Contains("hiit") || source.Contains("combat") || source.Contains("strength"))
        {
            return ("High Intensity", "high");
        }
        if (source.Contains("yoga") || source.Contains("recovery") || source.Contains("stretch"))
        {
            return ("Recovery", "low");
        }
        return ("Medium", "medium");
    }

    private static string GetSlotsLabel(string? notes)
    {
        if (!string.IsNullOrWhiteSpace(notes) && notes.Contains("slot", StringComparison.OrdinalIgnoreCase))
        {
            return notes;
        }
        return "Limited slots";
    }

    private static string GetPriceLabel(string? notes)
    {
        var price = TryExtractPricePerStudent(notes);
        return price.HasValue
            ? $"{price.Value.ToString("C")}/student"
            : "Free";
    }

    private string GetQueueCostLabel(string? notes)
    {
        if (_hasActiveMembership)
        {
            return "Free for members";
        }
        else
        {
            // Non-members pay 5% of class cost
            var price = TryExtractPricePerStudent(notes);
            if (price.HasValue)
            {
                var queueCost = price.Value * 0.05m;
                return $"{queueCost:C} queue cost (5% of class price)";
            }
            return "5% queue cost";
        }
    }

    private static decimal? TryExtractPricePerStudent(string? notes)
    {
        if (string.IsNullOrWhiteSpace(notes)) return null;

        var parts = notes.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var part in parts)
        {
            const string marker = "PricePerStudent=";
            if (!part.StartsWith(marker, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var raw = part[marker.Length..].Trim();
            if (decimal.TryParse(raw, NumberStyles.Number, CultureInfo.InvariantCulture, out var parsed) && parsed > 0)
            {
                return parsed;
            }
        }

        return null;
    }

