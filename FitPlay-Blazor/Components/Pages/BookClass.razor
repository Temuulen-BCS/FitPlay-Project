        align-items: center;
        justify-content: center;
        min-height: 200px;
        color: var(--text-muted);
        font-size: 14px;
    }

    .payment-actions {
        display: flex;
        gap: 12px;
        margin-top: 4px;
    }

    .btn-pay {
        flex: 1;
        padding: 14px 20px;
        background: linear-gradient(135deg, rgba(14,240,255,0.2), rgba(255,77,250,0.2));
        border: 2px solid rgba(14,240,255,0.5);
        box-shadow: 0 0 24px rgba(14,240,255,0.2);
        border-radius: 12px;
        color: white;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .btn-pay:hover:not(:disabled) {
        transform: translateY(-2px);
        border-color: rgba(14,240,255,0.8);
        box-shadow: 0 0 36px rgba(14,240,255,0.35);
    }

    .btn-pay:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        box-shadow: none;
    }

    .payment-notice {
        margin: 16px 0 0 0;
        font-size: 11px;
        color: var(--text-muted);
        text-align: center;
        line-height: 1.5;
    }
</style>

@if (_showCancelConfirm && _pendingCancel != null)
{
    <div class="confirm-overlay" @onclick="CloseCancelConfirm">
        <div class="confirm-card" @onclick:stopPropagation="true">
            <h3 class="confirm-title">Cancel booking?</h3>
            <p class="confirm-text">
                Are you sure you want to cancel <strong>@_pendingCancel.Modality</strong>
                on @_pendingCancel.ScheduledAt.ToString("ddd, MMM dd 'at' HH:mm")?
                @if (_pendingCancel.PaymentStatus == "Completed" && _pendingCancel.PaidAmount.HasValue)
                {
                    <br /><br />
                    <span>You will receive an <strong>85% refund</strong> of @((_pendingCancel.PaidAmount.Value * 0.85m).ToString("C")) back to your original payment method.</span>
                }
            </p>
            <div class="confirm-actions">
                <button class="btn-secondary" @onclick="CloseCancelConfirm">Keep Booking</button>
                <button class="btn-danger" @onclick="ConfirmCancelBooking" disabled="@_isCanceling">
                    @(_isCanceling ? "Canceling..." : "Cancel Booking")
                </button>
            </div>
        </div>
    </div>
}

@if (_showPaymentModal && _paymentScheduleId.HasValue)
{
    <div class="payment-overlay" @onclick="ClosePaymentModal">
        <div class="payment-card" @onclick:stopPropagation="true">
            <div class="payment-header">
                <h3>Complete Your Booking</h3>
                <button class="btn-close-modal" @onclick="ClosePaymentModal">&#x2715;</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_paymentClassName))
            {
                <p class="payment-class-name">@_paymentClassName</p>
            }

            @if (_paymentAmount.HasValue)
            {
                <p class="payment-amount">@_paymentAmount.Value.ToString("C")</p>
            }

            <hr class="payment-divider" />

            @if (!string.IsNullOrWhiteSpace(_paymentError))
            {
                <div class="payment-error">@_paymentError</div>
            }

            <div class="payment-element-container">
                @if (!_paymentElementMounted)
                {
                    <div class="payment-element-loading">Loading payment form...</div>
                }
                <div id="payment-element-@_paymentScheduleId"></div>
            </div>

            <div class="payment-actions">
                <button class="btn-secondary" @onclick="ClosePaymentModal" style="flex:0 0 auto; width:110px;">Cancel</button>
                <button
                    class="btn-pay"
                    @onclick="ConfirmPayment"
                    disabled="@(!_paymentElementMounted || _isProcessingPayment)">
                    @(_isProcessingPayment ? "Processing..." : $"Pay & Book")
                </button>
            </div>

            <p class="payment-notice">
                Secured by Stripe. By completing payment you agree to our booking policy.<br />
                Cancellations receive an 85% refund.
            </p>
        </div>
    </div>
}

@code {
    private List<ApiClient.ClassScheduleWithTrainer> _publicClasses = new();
    private List<ApiClient.ClassSchedule> _userClasses = new();
    private bool _isLoading = true;
    private bool isBooking;
    private bool _showCancelConfirm;
    private bool _isCanceling;
    private ApiClient.ClassSchedule? _pendingCancel;

    private int? _currentUserId;

    // ── Stripe payment state ──
    private int? _paymentScheduleId;
    private string? _paymentClientSecret;
    private decimal? _paymentAmount;
    private string? _paymentClassName;
    private bool _paymentElementMounted;
    private bool _isMountingPayment;
    private bool _showPaymentModal;
    private string? _paymentError;
    private bool _isProcessingPayment;
    private bool _isInitiatingPayment;

    protected override async Task OnInitializedAsync()
    {
        _currentUserId = await ResolveCurrentUserIdAsync();
        if (_currentUserId is null)
        {
            _isLoading = false;
            return;
        }

        await LoadClasses();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isMountingPayment || _paymentElementMounted
            || !_showPaymentModal
            || string.IsNullOrWhiteSpace(_paymentClientSecret)
            || _paymentScheduleId is null)
            return;

        _isMountingPayment = true;
        _paymentElementMounted = true;

        try
        {
            var error = await JS.InvokeAsync<string?>(
                "fitplayStripe.mount",
                _paymentClientSecret,
                $"#payment-element-{_paymentScheduleId}");

            if (!string.IsNullOrWhiteSpace(error))
            {
                _paymentElementMounted = false;
                _paymentError = error;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            _paymentElementMounted = false;
            _paymentError = $"Failed to load payment form: {ex.Message}";
            StateHasChanged();
        }
        finally
        {
            _isMountingPayment = false;
        }
    }

    private async Task LoadClasses()
    {
        if (_currentUserId is null)
        {
            _isLoading = false;
            return;
        }

        _isLoading = true;
        try
        {
            _publicClasses = await Api.GetPublicClassSchedules();
            _userClasses = await Api.GetUserSchedule(_currentUserId.Value);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading classes: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task bookClass(int scheduleId)
    {
        if (_currentUserId is null) return;

        var classItem = _publicClasses.FirstOrDefault(c => c.Id == scheduleId);
        if (classItem == null) return;

        var price = TryExtractPricePerStudent(classItem.Notes);

        // Free class — book directly without payment
        if (!price.HasValue || price.Value == 0)
        {
            await BookFreeClass(scheduleId);
            return;
        }

        // Paid class — open Stripe payment modal
        await InitiatePayment(scheduleId, classItem.Modality, price.Value);
    }

    private async Task BookFreeClass(int scheduleId)
    {
        isBooking = true;
        try
        {
            await Api.BookClass(scheduleId, _currentUserId!.Value);
            await LoadClasses();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error booking class: {ex.Message}");
        }
        finally
        {
            isBooking = false;
        }
    }

    // ── Stripe Payment Flow ──

    private async Task InitiatePayment(int scheduleId, string className, decimal price)
    {
        _isInitiatingPayment = true;
        _paymentError = null;

        try
        {
            var response = await Api.CreateClassBookingPaymentIntent(scheduleId, _currentUserId!.Value);
            _paymentClientSecret = response?.ClientSecret;

            if (string.IsNullOrWhiteSpace(_paymentClientSecret))
            {
                _paymentError = "Failed to initialize payment.";
                return;
            }

            _paymentScheduleId = scheduleId;
            _paymentAmount = response!.Amount;
            _paymentClassName = className;
            _paymentElementMounted = false;
            _showPaymentModal = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _paymentError = $"Failed to initialize payment: {ex.Message}";
            Console.WriteLine(_paymentError);
        }
        finally
        {
            _isInitiatingPayment = false;
        }
    }

    private async Task ConfirmPayment()
    {
        if (string.IsNullOrWhiteSpace(_paymentClientSecret) || _paymentScheduleId is null || _currentUserId is null)
        {
            _paymentError = "Payment not initialized.";
            return;
        }

        _isProcessingPayment = true;
        _paymentError = null;

        try
        {
            var returnUrl = Navigation.ToAbsoluteUri("/user/book-class").ToString();
            var stripeError = await JS.InvokeAsync<string?>("fitplayStripe.confirm", returnUrl);

            if (!string.IsNullOrWhiteSpace(stripeError))
            {
                _paymentError = stripeError;
                return;
            }

            // Extract PI id from client secret (format: pi_xxx_secret_yyy → pi_xxx)
            var paymentIntentId = _paymentClientSecret.Split("_secret_")[0];

            await Api.ConfirmClassBookingPayment(_paymentScheduleId.Value, _currentUserId.Value, paymentIntentId);

            // Reset payment state and reload
            ClosePaymentModal();
            await LoadClasses();
        }
        catch (Exception ex)
        {
            _paymentError = $"Payment failed: {ex.Message}";
        }
        finally
        {
            _isProcessingPayment = false;
        }
    }

    private void ClosePaymentModal()
    {
        _showPaymentModal = false;
        _paymentScheduleId = null;
        _paymentClientSecret = null;
        _paymentAmount = null;
        _paymentClassName = null;
        _paymentElementMounted = false;
        _isMountingPayment = false;
        _paymentError = null;
        _isProcessingPayment = false;
    }

    // ── Cancel / Unbook ──

    private void PromptCancel(ApiClient.ClassSchedule classItem)
    {
        _pendingCancel = classItem;
        _showCancelConfirm = true;
    }

    private void CloseCancelConfirm()
    {
        _showCancelConfirm = false;
        _pendingCancel = null;
    }

    private async Task ConfirmCancelBooking()
    {
        if (_pendingCancel is null || _currentUserId is null)
        {
            return;
        }

        _isCanceling = true;
        try
        {
            await Api.UnbookClass(_pendingCancel.Id);
            await LoadClasses();
            CloseCancelConfirm();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error canceling booking: {ex.Message}");
        }
        finally
        {
            _isCanceling = false;
        }
    }

    private async Task<int?> ResolveCurrentUserIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("Account/Login", true);
            return null;
        }

        var identityId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrWhiteSpace(identityId))
        {
            Navigation.NavigateTo("Account/Login", true);
            return null;
        }

        var domainUser = await Api.GetUserByIdentity(identityId);
        if (domainUser is null)
        {
            Navigation.NavigateTo("Account/Login", true);
            return null;
        }

        return domainUser.Id;
    }

    private static (string Label, string CssClass) GetIntensity(string? modality, string? notes)
    {
        var source = string.Join(' ', modality, notes).ToLowerInvariant();
        if (source.Contains("hiit") || source.Contains("combat") || source.Contains("strength"))
        {
            return ("High Intensity", "high");
        }
        if (source.Contains("yoga") || source.Contains("recovery") || source.Contains("stretch"))
        {
            return ("Recovery", "low");
        }
        return ("Medium", "medium");
    }

    private static string GetSlotsLabel(string? notes)
    {
        if (!string.IsNullOrWhiteSpace(notes) && notes.Contains("slot", StringComparison.OrdinalIgnoreCase))
        {
            return notes;
        }
        return "Limited slots";
    }

    private static string GetPriceLabel(string? notes)
    {
        var price = TryExtractPricePerStudent(notes);
        return price.HasValue
            ? $"{price.Value.ToString("C")}/student"
            : "Free";
    }

    private static decimal? TryExtractPricePerStudent(string? notes)
    {
        if (string.IsNullOrWhiteSpace(notes)) return null;

        var parts = notes.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var part in parts)
        {
            const string marker = "PricePerStudent=";
            if (!part.StartsWith(marker, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var raw = part[marker.Length..].Trim();
            if (decimal.TryParse(raw, NumberStyles.Number, CultureInfo.InvariantCulture, out var parsed) && parsed > 0)
            {
                return parsed;
            }
        }

        return null;
    }

    private static string GetClassMeta(ApiClient.ClassScheduleWithTrainer classItem)
    {
        if (!string.IsNullOrWhiteSpace(classItem.TrainerName))
        {
            return $"Coach: {classItem.TrainerName}";
        }
        return "Coach: TBA";
    }
