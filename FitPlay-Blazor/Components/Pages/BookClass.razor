@if (_showCancelConfirm && _pendingCancel != null)
{
    <div class="confirm-overlay" @onclick="CloseCancelConfirm">
        <div class="confirm-card" @onclick:stopPropagation="true">
            <h3 class="confirm-title">Cancel booking?</h3>
            <p class="confirm-text">
                Are you sure you want to cancel <strong>@_pendingCancel.Modality</strong>
                on @_pendingCancel.ScheduledAt.ToLocalTime().ToString("ddd, MMM dd 'at' HH:mm")?
                @if (_pendingCancel.PaymentStatus == "Completed" && _pendingCancel.PaidAmount.HasValue)
                {
                    <br /><br />
                    <span>You will receive an <strong>85% refund</strong> of @((_pendingCancel.PaidAmount.Value * 0.85m).ToString("C")) back to your original payment method.</span>
                }
            </p>
            <div class="confirm-actions">
                <button class="btn-secondary" @onclick="CloseCancelConfirm">Keep Booking</button>
                <button class="btn-danger" @onclick="ConfirmCancelBooking" disabled="@_isCanceling">
                    @(_isCanceling ? "Canceling..." : "Cancel Booking")
                </button>
            </div>
        </div>
    </div>
}

@if (_showPaymentModal && _paymentScheduleId.HasValue)
{
    <div class="payment-overlay" @onclick="ClosePaymentModal">
        <div class="payment-card" @onclick:stopPropagation="true">
            <div class="payment-header">
                <h3>Complete Your Booking</h3>
                <button class="btn-close-modal" @onclick="ClosePaymentModal">&#x2715;</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_paymentClassName))
            {
                <p class="payment-class-name">@_paymentClassName</p>
            }

            @if (_paymentAmount.HasValue)
            {
                <p class="payment-amount">@_paymentAmount.Value.ToString("C")</p>
            }

            <hr class="payment-divider" />

            @if (!string.IsNullOrWhiteSpace(_paymentError))
            {
                <div class="payment-error">@_paymentError</div>
            }

            <div class="payment-element-container">
                @if (!_paymentElementMounted)
                {
                    <div class="payment-element-loading">Loading payment form...</div>
                }
                <div id="payment-element-@_paymentScheduleId"></div>
            </div>

            <div class="payment-actions">
                <button class="btn-secondary" @onclick="ClosePaymentModal" style="flex:0 0 auto; width:110px;">Cancel</button>
                <button
                    class="btn-pay"
                    @onclick="ConfirmPayment"
                    disabled="@(!_paymentElementMounted || _isProcessingPayment)">
                    @(_isProcessingPayment ? "Processing..." : $"Pay & Book")
                </button>
            </div>

            <p class="payment-notice">
                Secured by Stripe. By completing payment you agree to our booking policy.<br />
                Cancellations receive an 85% refund.
            </p>
        </div>
    </div>
}

@* ── Queue Deposit Payment Modal ── *@
@if (_showQueuePaymentModal && _queuePaymentScheduleId.HasValue)
{
    <div class="payment-overlay" @onclick="CloseQueuePaymentModal">
        <div class="payment-card" @onclick:stopPropagation="true">
            <div class="payment-header">
                <h3>Queue Deposit</h3>
                <button class="btn-close-modal" @onclick="CloseQueuePaymentModal">&#x2715;</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_queuePaymentClassName))
            {
                <p class="payment-class-name">@_queuePaymentClassName</p>
            }

            @if (_queuePaymentAmount.HasValue)
            {
                <p class="payment-amount">@_queuePaymentAmount.Value.ToString("C")</p>
            }

            <p class="payment-class-name" style="margin-top: -14px;">
                5% deposit to reserve your spot. The remainder is due after the trainer confirms the room.
            </p>

            <hr class="payment-divider" />

            @if (!string.IsNullOrWhiteSpace(_queuePaymentError))
            {
                <div class="payment-error">@_queuePaymentError</div>
            }

            <div class="payment-element-container">
                @if (!_queuePaymentElementMounted)
                {
                    <div class="payment-element-loading">Loading payment form...</div>
                }
                <div id="queue-payment-element-@_queuePaymentScheduleId"></div>
            </div>

            <div class="payment-actions">
                <button class="btn-secondary" @onclick="CloseQueuePaymentModal" style="flex:0 0 auto; width:110px;">Cancel</button>
                <button
                    class="btn-pay"
                    @onclick="ConfirmQueuePayment"
                    disabled="@(!_queuePaymentElementMounted || _isProcessingQueuePayment)">
                    @(_isProcessingQueuePayment ? "Processing..." : "Pay Deposit & Join Queue")
                </button>
            </div>

            <p class="payment-notice">
                Secured by Stripe. This 5% deposit reserves your spot in the queue.
            </p>
        </div>
    </div>
}

@code {
    private List<ApiClient.ClassScheduleWithTrainer> _publicClasses = new();
    private List<ApiClient.ClassSchedule> _userClasses = new();
    private bool _isLoading = true;
    private bool isBooking;
    private bool _showCancelConfirm;
    private bool _isCanceling;
    private ApiClient.ClassSchedule? _pendingCancel;

    private int? _currentUserId;

    // ── Queue state ──
    private List<ApiClient.UserQueueEntry> _userQueueEntries = new();
    private HashSet<int> _queuedClassIds = new();
    private HashSet<int> _enrolledScheduleIds = new();
    private bool _isJoiningQueue;
    private int _monthlySkipCount = 0;
    private int? _skipConfirmScheduleId;

    // ── Expand details state ──
    private HashSet<int> _expandedClassIds = new();

    // ── Queue payment state ──
    private int? _queuePaymentScheduleId;
    private string? _queuePaymentClientSecret;
    private decimal? _queuePaymentAmount;
    private string? _queuePaymentClassName;
    private bool _queuePaymentElementMounted;
    private bool _isMountingQueuePayment;
    private bool _showQueuePaymentModal;
    private string? _queuePaymentError;
    private bool _isProcessingQueuePayment;

    // ── User membership state ──
    private bool _hasActiveMembership;

    // ── Stripe payment state ──
    private int? _paymentScheduleId;
    private string? _paymentClientSecret;
    private decimal? _paymentAmount;
    private string? _paymentClassName;
    private bool _paymentElementMounted;
    private bool _isMountingPayment;
    private bool _showPaymentModal;
    private string? _paymentError;
    private bool _isProcessingPayment;
    private bool _isInitiatingPayment;
    private DateTime _nowUtc = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        await RefreshNowAsync();

        _currentUserId = await ResolveCurrentUserIdAsync();
        if (_currentUserId is null)
        {
            _isLoading = false;
            return;
        }

        // Check user membership status
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _hasActiveMembership = user.HasClaim("membership", "active");

        await LoadClasses();
    }

    private async Task RefreshNowAsync()
    {
        try
        {
            var serverTime = await Api.GetDevTime();
            _nowUtc = serverTime?.CurrentTime ?? DateTime.UtcNow;
        }
        catch
        {
            _nowUtc = DateTime.UtcNow;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Mount Stripe for class booking payment
        if (!_isMountingPayment && !_paymentElementMounted
            && _showPaymentModal
            && !string.IsNullOrWhiteSpace(_paymentClientSecret)
            && _paymentScheduleId is not null)
        {
            _isMountingPayment = true;
            _paymentElementMounted = true;

            try
            {
                var error = await JS.InvokeAsync<string?>(
                    "fitplayStripe.mount",
                    _paymentClientSecret,
                    $"#payment-element-{_paymentScheduleId}");

                if (!string.IsNullOrWhiteSpace(error))
                {
                    _paymentElementMounted = false;
                    _paymentError = error;
                }

                StateHasChanged();
            }
            catch (Exception ex)
            {
                _paymentElementMounted = false;
                _paymentError = $"Failed to load payment form: {ex.Message}";
                StateHasChanged();
            }
            finally
            {
                _isMountingPayment = false;
            }
        }

        // Mount Stripe for queue deposit payment
        if (!_isMountingQueuePayment && !_queuePaymentElementMounted
            && _showQueuePaymentModal
            && !string.IsNullOrWhiteSpace(_queuePaymentClientSecret)
            && _queuePaymentScheduleId is not null)
        {
            _isMountingQueuePayment = true;
            _queuePaymentElementMounted = true;

            try
            {
                var error = await JS.InvokeAsync<string?>(
                    "fitplayStripe.mount",
                    _queuePaymentClientSecret,
                    $"#queue-payment-element-{_queuePaymentScheduleId}");

                if (!string.IsNullOrWhiteSpace(error))
                {
                    _queuePaymentElementMounted = false;
                    _queuePaymentError = error;
                }

                StateHasChanged();
            }
            catch (Exception ex)
            {
                _queuePaymentElementMounted = false;
                _queuePaymentError = $"Failed to load payment form: {ex.Message}";
                StateHasChanged();
            }
            finally
            {
                _isMountingQueuePayment = false;
            }
        }
    }

    private async Task LoadClasses()
    {
        if (_currentUserId is null)
        {
            _isLoading = false;
            return;
        }

        _isLoading = true;
        try
        {
            _publicClasses = await Api.GetPublicClassSchedules();
            Console.WriteLine($"[BookClass] Loaded {_publicClasses.Count} public classes");
            
            var allUserClasses = await Api.GetUserSchedule(_currentUserId.Value);
            _userClasses = allUserClasses
                .Where(c => string.Equals(c.Status, "Scheduled", StringComparison.OrdinalIgnoreCase)
                    && (c.DurationMinutes.HasValue
                        ? c.ScheduledAt.AddMinutes(c.DurationMinutes.Value)
                        : c.ScheduledAt) > DateTime.UtcNow)
                .ToList();
            Console.WriteLine($"[BookClass] User has {_userClasses.Count} booked classes");

            // Build HashSet of enrolled schedule IDs
            _enrolledScheduleIds = new HashSet<int>(_userClasses.Select(c => c.Id));
            Console.WriteLine($"[BookClass] Enrolled IDs: {string.Join(", ", _enrolledScheduleIds)}");

            // Filter out already-booked classes from public list
            var beforeFilterCount = _publicClasses.Count;
            _publicClasses = _publicClasses
                .Where(c => !_enrolledScheduleIds.Contains(c.Id))
                .ToList();
            Console.WriteLine($"[BookClass] Filtered public classes: {beforeFilterCount} -> {_publicClasses.Count} (removed {beforeFilterCount - _publicClasses.Count})");

            // Fetch which classes the user is already queued for (includes IsNotified)
            _userQueueEntries = await Api.GetUserQueueEntries(_currentUserId.Value);
            _queuedClassIds = new HashSet<int>(_userQueueEntries.Select(e => e.ClassScheduleId));
            _monthlySkipCount = await Api.GetMonthlySkipCount(_currentUserId.Value);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading classes: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task bookClass(int scheduleId)
    {
        Console.WriteLine($"bookClass called for scheduleId: {scheduleId}");
        
        if (_currentUserId is null)
        {
            Console.WriteLine("ERROR: _currentUserId is null");
            return;
        }

        Console.WriteLine($"_currentUserId: {_currentUserId}");

        var classItem = _publicClasses.FirstOrDefault(c => c.Id == scheduleId);
        if (classItem == null)
        {
            Console.WriteLine($"ERROR: No class found with scheduleId: {scheduleId}");
            return;
        }

        Console.WriteLine($"Found class: {classItem.Modality}, Notes: {classItem.Notes}");

        var price = TryExtractPricePerStudent(classItem.Notes);
        Console.WriteLine($"Extracted price: {price}");

        // Free class — book directly without payment
        if (!price.HasValue || price.Value == 0)
        {
            Console.WriteLine("Booking as free class");
            await BookFreeClass(scheduleId);
            return;
        }

        // Paid class — open Stripe payment modal
        Console.WriteLine($"Initiating payment for ${price.Value}");
        await InitiatePayment(scheduleId, classItem.Modality, price.Value);
    }

