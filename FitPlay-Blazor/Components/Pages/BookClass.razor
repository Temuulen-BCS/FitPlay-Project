    }

    private static string? FormatDuration(double? durationMinutes)
    {
        if (!durationMinutes.HasValue || durationMinutes.Value <= 0)
        {
            return null;
        }

        var minutes = (int)Math.Round(durationMinutes.Value);
        var hours = minutes / 60;
        var remainingMinutes = minutes % 60;

        if (hours > 0 && remainingMinutes > 0)
        {
            return $"{hours}h {remainingMinutes}min";
        }
        else if (hours > 0)
        {
            return $"{hours}h";
        }
        else
        {
            return $"{remainingMinutes}min";
        }
    }

    private static string FormatFullLocation(string? name, string? address, string? city, string? state, string? zipCode)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(name))
        {
            parts.Add(name);
        }
        if (!string.IsNullOrWhiteSpace(address))
        {
            parts.Add(address);
        }

        var cityStateZipParts = new List<string>();
        if (!string.IsNullOrWhiteSpace(city))
        {
            cityStateZipParts.Add(city);
        }
        if (!string.IsNullOrWhiteSpace(state))
        {
            cityStateZipParts.Add(state);
        }

        var cityStatePart = string.Join(", ", cityStateZipParts);
        if (!string.IsNullOrWhiteSpace(zipCode))
        {
            cityStatePart = string.IsNullOrWhiteSpace(cityStatePart)
                ? zipCode
                : $"{cityStatePart} {zipCode}";
        }
        if (!string.IsNullOrWhiteSpace(cityStatePart))
        {
            parts.Add(cityStatePart);
        }

        return parts.Count > 0 ? string.Join(",", parts) : "N/A";
    }

