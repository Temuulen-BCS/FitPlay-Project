    // ── Stripe Payment Flow ──

    private async Task InitiatePayment(int scheduleId, string className, decimal price)
    {
        Console.WriteLine($"InitiatePayment called: scheduleId={scheduleId}, className={className}, price={price}");
        
        _isInitiatingPayment = true;
        _paymentError = null;

        try
        {
            Console.WriteLine($"Calling CreateClassBookingPaymentIntent for user {_currentUserId}");
            var response = await Api.CreateClassBookingPaymentIntent(scheduleId, _currentUserId!.Value);
            _paymentClientSecret = response?.ClientSecret;

            Console.WriteLine($"Payment intent response: ClientSecret={(response?.ClientSecret != null ? "exists" : "null")}, Amount={response?.Amount}");

            if (string.IsNullOrWhiteSpace(_paymentClientSecret))
            {
                _paymentError = "Failed to initialize payment.";
                Console.WriteLine("ERROR: Payment client secret is null or empty");
                return;
            }

            _paymentScheduleId = scheduleId;
            _paymentAmount = response!.Amount;
            _paymentClassName = className;
            _paymentElementMounted = false;
            _showPaymentModal = true;
            
            Console.WriteLine($"Payment modal state set: _showPaymentModal={_showPaymentModal}");
            
            await InvokeAsync(StateHasChanged);
            Console.WriteLine("StateHasChanged invoked");
        }
        catch (Exception ex)
        {
            _paymentError = $"Failed to initialize payment: {ex.Message}";
            Console.WriteLine($"ERROR in InitiatePayment: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
        finally
        {
            _isInitiatingPayment = false;
        }
    }

    private async Task ConfirmPayment()
    {
        if (string.IsNullOrWhiteSpace(_paymentClientSecret) || _paymentScheduleId is null || _currentUserId is null)
        {
            _paymentError = "Payment not initialized.";
            return;
        }

        _isProcessingPayment = true;
        _paymentError = null;

        try
        {
            var returnUrl = Navigation.ToAbsoluteUri("/user/book-class").ToString();
            var stripeError = await JS.InvokeAsync<string?>("fitplayStripe.confirm", returnUrl);

            if (!string.IsNullOrWhiteSpace(stripeError))
            {
                _paymentError = stripeError;
                return;
            }

            // Extract PI id from client secret (format: pi_xxx_secret_yyy → pi_xxx)
            var paymentIntentId = _paymentClientSecret.Split("_secret_")[0];

            await Api.ConfirmClassBookingPayment(_paymentScheduleId.Value, _currentUserId.Value, paymentIntentId);

            // Reset payment state and reload
            ClosePaymentModal();
            await LoadClasses();
        }
        catch (Exception ex)
        {
            _paymentError = $"Payment failed: {ex.Message}";
        }
        finally
        {
            _isProcessingPayment = false;
        }
    }

    private void ClosePaymentModal()
    {
        _showPaymentModal = false;
        _paymentScheduleId = null;
        _paymentClientSecret = null;
        _paymentAmount = null;
        _paymentClassName = null;
        _paymentElementMounted = false;
        _isMountingPayment = false;
        _paymentError = null;
        _isProcessingPayment = false;
    }

    // ── Queue Flow ──

    private async Task JoinQueue(int scheduleId, string className, string? notes)
    {
        if (_currentUserId is null) return;

        _isJoiningQueue = true;
        try
        {
            var response = await Api.JoinClassQueue(scheduleId, _currentUserId.Value);

            if (response is null)
            {
                Console.WriteLine("Failed to join queue.");
                return;
            }

            if (response.HasMembership && response.QueueCost == 0)
            {
                // Member within skip limit — joins for free
                _queuedClassIds.Add(scheduleId);
                _monthlySkipCount = response.MonthlySkipCount;
                await LoadClasses();
            }
            else if (!string.IsNullOrWhiteSpace(response.ClientSecret))
            {
                // Payment required: non-member OR member who exceeded skip limit (5% deposit)
                _queuePaymentScheduleId = scheduleId;
                _queuePaymentClientSecret = response.ClientSecret;
                _queuePaymentAmount = response.QueueCost;
                _queuePaymentClassName = className;
                _queuePaymentElementMounted = false;
                _showQueuePaymentModal = true;
                _monthlySkipCount = response.MonthlySkipCount;
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                // No payment needed (free class), mark queued
                _queuedClassIds.Add(scheduleId);
                _monthlySkipCount = response.MonthlySkipCount;
                await LoadClasses();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error joining queue: {ex.Message}");
        }
        finally
        {
            _isJoiningQueue = false;
        }
    }

