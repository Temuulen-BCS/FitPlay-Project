            radial-gradient(40% 45% at 80% 25%, rgba(255, 94, 220, 0.45), transparent 68%),
            radial-gradient(40% 45% at 30% 80%, rgba(120, 245, 110, 0.42), transparent 70%),
            radial-gradient(45% 50% at 85% 85%, rgba(255, 214, 96, 0.35), transparent 72%);
