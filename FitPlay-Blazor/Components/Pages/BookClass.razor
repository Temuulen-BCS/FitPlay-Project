    }

    .payment-amount {
        font-size: 32px;
        font-weight: 800;
        color: var(--accent-teal);
        margin: 0 0 20px 0;
        letter-spacing: -0.5px;
    }

    .payment-divider {
        border: none;
        border-top: 1px solid var(--glass-border);
        margin: 0 0 20px 0;
    }

    .payment-error {
        background: rgba(255,47,180,0.12);
        border: 1px solid rgba(255,47,180,0.4);
