    private static int GetCapacityPercent(int? booked, int? max)
    {
        if (!max.HasValue || max.Value <= 0 || !booked.HasValue) return 0;
        return (int)Math.Round((double)booked.Value / max.Value * 100);
    }

    private static string FormatCapacity(int? booked, int? max)
    {
        if (!max.HasValue) return "N/A";
        return $"{booked ?? 0}/{max.Value} clients";
    }
