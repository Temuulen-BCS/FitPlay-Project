@page "/trainer/dashboard"
@attribute [Authorize(Roles = "Trainer")]
@layout TrainerLayout
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using FitPlay.Blazor.Services
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ApiClient Api

<PageTitle>Trainer Dashboard - FitPlay</PageTitle>

<div class="dashboard-wrap">
    <h1>Trainer Dashboard</h1>

    @if (_loading)
    {
        <p>Loading dashboard...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="error">@_error</p>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card">
                <span class="label">Sessions (next 7 days)</span>
                <span class="value">@_upcomingSessions.Count</span>
            </div>
            <div class="stat-card">
                <span class="label">Total earnings</span>
                <span class="value">@(_earnings?.TotalAmount.ToString("C") ?? "--")</span>
            </div>
            <div class="stat-card">
                <span class="label">Processed payouts</span>
                <span class="value">@(_earnings?.Items.Count ?? 0)</span>
            </div>
        </div>

        <section class="panel">
            <h2>Upcoming agenda</h2>
            @if (!_upcomingSessions.Any())
            {
                <p>No upcoming sessions.</p>
            }
            else
            {
                <ul>
                    @foreach (var s in _upcomingSessions)
                    {
                        <li>
                            <strong>@s.Title</strong> -
                            @s.StartTime.ToLocalTime().ToString("dd MMM HH:mm")
                            (@s.EnrolledStudents/@s.MaxStudents)
                        </li>
                    }
                </ul>
            }
        </section>

        <section class="panel">
            <h2>Latest earnings</h2>
            @if (_earnings is null || !_earnings.Items.Any())
            {
                <p>No payouts processed yet.</p>
            }
            else
            {
                <ul>
                    @foreach (var item in _earnings.Items.Take(10))
                    {
                        <li>
                            <strong>@item.SessionTitle</strong> - @item.Amount.ToString("C")
                            on @item.ProcessedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        </li>
                    }
                </ul>
            }
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private List<ApiClient.ClassSessionRead> _upcomingSessions = new();
    private ApiClient.TrainerEarningsSummary? _earnings;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var identityId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (string.IsNullOrWhiteSpace(identityId))
            {
                _error = "Trainer identity not found.";
                return;
            }

            var from = DateTime.UtcNow;
            var to = DateTime.UtcNow.AddDays(7);

            _upcomingSessions = await Api.GetTrainerSessionsV3(identityId, from, to);
            _earnings = await Api.GetTrainerEarningsV3(identityId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}

<style>
    .dashboard-wrap { max-width: 1100px; margin: 0 auto; padding: 24px; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 16px; }
    .stat-card { background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px; padding: 12px; }
    .label { display: block; font-size: .78rem; color: var(--text-muted); }
    .value { display: block; font-size: 1.4rem; font-weight: 700; color: var(--text-primary); }
    .panel { background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px; padding: 14px; margin-bottom: 12px; }
    .error { color: #ff9aa2; }
</style>
