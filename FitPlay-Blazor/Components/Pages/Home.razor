        transition: flex-basis 0.45s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s ease;
        border-right: 1px solid rgba(255,255,255,0.15);
        overflow: hidden;
        position: relative;
    }

    .gn-seg:last-child {
        border-right: none;
    }

    /* Green top bar */
    .gn-seg::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--gn-accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s ease;
        z-index: 5;
    }

    /* When a sibling is hovered: shrink idle segs */
    .gn-segments.has-hover .gn-seg {
        flex-basis: var(--seg-shrink);
    }

    /* Active/hovered segment: expand */
    .gn-segments.has-hover .gn-seg.is-active,
