@code {
    private bool _hasInitializedJs;
    private bool _jsInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_jsInitialized)
            return;

        await Task.Delay(50);
        await JS.InvokeVoidAsync("initHeroVideo");
        _hasInitializedJs = true;
        _jsInitialized = true;

        if (firstRender)
            await JS.InvokeVoidAsync("initGymPanel");
    }

    public async ValueTask DisposeAsync()
    {
        if (!_hasInitializedJs)
            return;

        try
        {
            await JS.InvokeVoidAsync("disposeHeroVideo");
        }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException ex) when (ex.Message.Contains("statically rendered", StringComparison.OrdinalIgnoreCase)) { }
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name[0].ToString().ToUpperInvariant();
    }

}

