@page "/"
@attribute [AllowAnonymous]
@layout EmptyLayout
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable

<!-- TOP NAV BAR -->
<header class="top-nav">
    <div class="nav-inner">
        <a href="/" class="logo">FIT<span>PLAY</span></a>
        <nav class="nav-links-top">
            <a href="#hero">Home</a>
            <a href="#classes">Classes</a>
            <a href="#trainers">Trainers</a>
            <a href="#perks">Membership</a>
            <a href="#contact">Contact</a>
        </nav>

        <AuthorizeView>
            <Authorized>
                @{
                    var displayName = context.User.FindFirst("full_name")?.Value
                    ?? context.User.Identity?.Name
                    ?? "User";
                }
                <div class="profile-dropdown">
                    <button class="profile-trigger" type="button">
                        <span class="profile-avatar">@GetInitials(displayName)</span>
                        <span class="profile-name">@displayName</span>
                        <svg class="dropdown-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <div class="dropdown-menu">
                        <div class="dropdown-menu-inner">
                            <div class="dropdown-section">
                                <a class="dropdown-item" href="Account/Manage" data-enhanced-nav="false">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
                                    Profile
                                </a>
                                
                                <AuthorizeView Roles="User" Context="userAuth">
                                    <a class="dropdown-item" href="user/dashboard">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                                        Dashboard
                                    </a>
                                    <a class="dropdown-item" href="user/progress">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
                                        My Progress
                                    </a>
                                    <a class="dropdown-item" href="user/achievements">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6" /><path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12" /></svg>
                                        Achievements
                                    </a>
                                    <a class="dropdown-item" href="membership">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                                        Membership
                                    </a>
                                </AuthorizeView>
                                
                                <AuthorizeView Roles="Trainer" Context="trainerAuth">
                                    <a class="dropdown-item" href="trainer/dashboard">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                                        Dashboard
                                    </a>
                                    <a class="dropdown-item" href="trainer/validations">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                                        Validations
                                    </a>
                                    <a class="dropdown-item" href="trainer/rooms">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="9" y1="3" x2="9" y2="21" /></svg>
                                        Rooms
                                    </a>
                                    <a class="dropdown-item" href="trainer/exercises">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5l11 11" /><path d="M17.5 6.5l-11 11" /><circle cx="12" cy="12" r="2" /></svg>
                                        Exercises
                                    </a>
                                </AuthorizeView>
                                
                                <AuthorizeView Roles="GymAdmin" Context="gymAuth">
                                    <a class="dropdown-item" href="gym/dashboard">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                                        Dashboard
                                    </a>
                                    <a class="dropdown-item" href="gym/setup">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M12 1v6m0 6v6m5.66-17.66l-4.24 4.24m0 8.48l4.24 4.24M23 12h-6m-6 0H1m17.66 5.66l-4.24-4.24m0-8.48l4.24-4.24" /></svg>
                                        My Gym
                                    </a>
                                    <a class="dropdown-item" href="gym/locations">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                                        Locations
                                    </a>
                                    <a class="dropdown-item" href="gym/rooms">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="9" y1="3" x2="9" y2="21" /></svg>
                                        Rooms
                                    </a>
                                    <a class="dropdown-item" href="gym/trainers">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                                        Trainers
                                    </a>
                                    <a class="dropdown-item" href="gym/sessions">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                                        Sessions
                                    </a>
                                </AuthorizeView>
                            </div>
                            <div class="dropdown-divider"></div>
                            <div class="dropdown-section dropdown-logout-section">
                                <form action="Account/Logout" method="post">
                                    <AntiforgeryToken />
                                    <input type="hidden" name="ReturnUrl" value="/" />
                                    <button type="submit" class="btn-logout-green">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                                        Log out
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <a href="Account/Register" class="btn-primary" data-enhanced-nav="false">Join Now</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>

<!-- HERO SECTION -->
<section class="hero" id="hero">
    <div class="hero-bg">
        <div class="hero-video-wrap" id="heroVideoWrap">
            <video class="hero-video active" id="heroVid0" src="/videos/hero/hero-1.mp4" autoplay muted playsinline preload="auto"></video>
            <video class="hero-video" id="heroVid1" muted playsinline preload="none"></video>
            <video class="hero-video" id="heroVid2" muted playsinline preload="none"></video>
            <video class="hero-video" id="heroVid3" muted playsinline preload="none"></video>
            <video class="hero-video" id="heroVid4" muted playsinline preload="none"></video>
        </div>
        <div class="hero-video-overlay"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
    </div>
    <div class="hero-content">
        <div class="badges">
            <span class="badge">Open Late</span>
            <span class="badge badge-alt">Live DJ</span>
        </div>
        <h1>Train Like It's<br /><span class="highlight">Friday Night</span></h1>
        <p class="hero-sub">Where fitness meets nightlife. Push your limits with beats that move you.</p>
        <div class="hero-ctas">
            <a href="#classes" class="btn-primary">Book a Class</a>
            <a href="#classes" class="btn-secondary">View Schedule</a>
        </div>
    </div>
</section>

<!-- STATS STRIP -->
<section class="stats-strip">
    <div class="stat-card">
        <span class="stat-value">2,500+</span>
        <span class="stat-label">Active Members</span>
    </div>
    <div class="stat-card">
        <span class="stat-value">45</span>
        <span class="stat-label">Classes / Week</span>
    </div>
    <div class="stat-card">
        <span class="stat-value">18</span>
        <span class="stat-label">Expert Trainers</span>
    </div>
    <div class="stat-card">
        <span class="stat-value">650</span>
        <span class="stat-label">Avg. Calories / Session</span>
    </div>
</section>

<!-- TONIGHT'S LINE-UP (CLASSES) -->
<section class="section classes-section" id="classes">
    <h2 class="section-title">Tonight's Line-Up</h2>
    <p class="section-sub">From HIIT to Yoga — experience workouts that push limits.</p>
    <div class="classes-grid">
        <div class="class-card">
            <div class="class-header">
                <span class="class-time">19:00</span>
                <span class="class-duration">1h</span>
                <span class="intensity high">High Intensity</span>
            </div>
            <h3 class="class-name">HIIT Inferno</h3>
            <p class="class-meta">Coach: Marcus | DJ: Pulse</p>
            <span class="slots">8 slots left</span>
        </div>
        <div class="class-card">
            <div class="class-header">
                <span class="class-time">20:30</span>
                <span class="class-duration">45min</span>
                <span class="intensity medium">Medium</span>
            </div>
            <h3 class="class-name">Box & Flow</h3>
            <p class="class-meta">Coach: Leila | DJ: Neon</p>
            <span class="slots">12 slots left</span>
        </div>
        <div class="class-card">
            <div class="class-header">
                <span class="class-time">21:45</span>
                <span class="class-duration">1h 15min</span>
                <span class="intensity low">Recovery</span>
            </div>
            <h3 class="class-name">Night Yoga</h3>
            <p class="class-meta">Coach: Sana | Ambient Mix</p>
            <span class="slots">5 slots left</span>
        </div>
        <div class="class-card">
            <div class="class-header">
                <span class="class-time">22:30</span>
                <span class="intensity high">High Intensity</span>
            </div>
            <h3 class="class-name">Combat Zone</h3>
            <p class="class-meta">Coach: Dex | DJ: Bass Drop</p>
            <span class="slots">3 slots left</span>
        </div>
    </div>
</section>

<!-- COACHES ON DECK -->
<!-- COACHES ON DECK -->
<section class="section trainers-section" id="trainers">
    <h2 class="section-title">Coaches on Deck</h2>
    <p class="section-sub">Meet the pros who'll push you past your limits.</p>
    <div class="trainers-grid">
        <div class="trainer-card">
            <div class="trainer-avatar">M</div>
            <h3>Marcus Reed</h3>
            <p class="trainer-specialty">HIIT, Functional Training</p>
            <span class="trainer-avail">Next: Tonight 19:00</span>
        </div>
        <div class="trainer-card">
            <div class="trainer-avatar">L</div>
            <h3>Leila Costa</h3>
            <p class="trainer-specialty">Boxing, Cardio Kickbox</p>
            <span class="trainer-avail">Next: Tonight 20:30</span>
        </div>
        <div class="trainer-card">
            <div class="trainer-avatar">S</div>
            <h3>Sana Park</h3>
            <p class="trainer-specialty">Yoga, Mobility</p>
            <span class="trainer-avail">Next: Tonight 21:45</span>
        </div>
        <div class="trainer-card">
            <div class="trainer-avatar">D</div>
            <h3>Dex Monroe</h3>
            <p class="trainer-specialty">MMA, Combat Training</p>
            <span class="trainer-avail">Next: Tonight 22:30</span>
        </div>
    </div>
</section>

<!-- GYM PARTNER CTA -->
<section class="gym-network-section" id="academy-partner">

    <div class="gym-network-inner">
        <div class="gym-network-header">
            <span class="gym-network-kicker">FitPlay Affiliate Program</span>
            <h2 class="gym-network-title">Your Space. <span>Our Network.</span></h2>
        </div>

        <div class="gn-panel" id="gnPanel">

            <!-- Images layer -->
            <div class="gn-images">
                <img class="gn-img gn-img-1"
                     src="https://images.pexels.com/photos/1552242/pexels-photo-1552242.jpeg?auto=compress&cs=tinysrgb&w=1600"
                     alt="Get Discovered" />
                <img class="gn-img gn-img-2 is-active"
                     src="images/manage-everything-hero.jpg"
                     alt="Manage Everything" />
                <img class="gn-img gn-img-3"
                     src="https://images.pexels.com/photos/2261477/pexels-photo-2261477.jpeg?auto=compress&cs=tinysrgb&w=1600"
                     alt="Earn Automatically" />
            </div>

            <!-- Segments layer -->
            <div class="gn-segments" id="gnSegments">

                <div class="gn-seg" data-idx="0">
                    <div class="gn-seg-body">
                        <span class="gn-seg-title">Get Discovered</span>
                        <a href="#" class="gn-seg-btn">Visibility &amp; Reach</a>
                    </div>
                </div>

                <div class="gn-seg is-active" data-idx="1">
                    <div class="gn-seg-body">
                        <span class="gn-seg-title">Manage Everything</span>
                        <a href="#" class="gn-seg-btn">Smart Management</a>
                    </div>
                </div>

                <div class="gn-seg" data-idx="2">
                    <div class="gn-seg-body">
                        <span class="gn-seg-title">Earn Automatically</span>
                        <a href="#" class="gn-seg-btn">Become a Gym Partner</a>
                    </div>
                </div>

            </div>
        </div>

        <div class="gym-network-footer">
            <span class="gym-network-footer-tagline">You provide the space. We connect the right coaches.</span>
            <div>
                <AuthorizeView Roles="GymAdmin">
                    <Authorized>
                        <a href="/gym/dashboard" class="gym-network-btn">
                            Go to my dashboard
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/academy/register" class="gym-network-btn">
                            Become a Gym Partner
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </a>
                        <a href="/academy/login" class="gym-network-link">Already have an account? Log in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>

</section>

<!-- MEMBERSHIP PERKS -->
<section class="section perks-section" id="perks">
    <div class="perks-header">
        <div>
            <h2 class="section-title">Membership Perks</h2>
            <p class="section-sub">Everything you need to train, recover, and level up.</p>
        </div>
        <div class="plan-info">
            <span class="plan-price">€10 / month</span>
            <span class="plan-note">Cancel anytime</span>
            <span class="plan-note">Unlock trainings, progress, achievements</span>
        </div>
    </div>
    <div class="perks-grid">
        <div class="perk-item">
            <div class="perk-icon">24/7</div>
            <h4>Always Open</h4>
            <p>Train on your schedule — we never close.</p>
        </div>
        <div class="perk-item">
            <div class="perk-icon">DJ</div>
            <h4>Live DJs</h4>
            <p>Every night, our DJs spin the best beats.</p>
        </div>
        <div class="perk-item">
            <div class="perk-icon">SPA</div>
            <h4>Recovery Lounge</h4>
            <p>Sauna, ice baths, and massage chairs.</p>
        </div>
        <div class="perk-item">
            <div class="perk-icon">XP</div>
            <h4>Gamified Progress</h4>
            <p>Earn XP, level up, unlock achievements.</p>
        </div>
    </div>
</section>

<!-- TESTIMONIALS -->
<section class="section testimonials-section">
    <h2 class="section-title">What Members Say</h2>
    <div class="testimonials-grid">
        <div class="testimonial-card">
            <p class="quote">"Best gym experience ever. The vibe is unmatched — it's like a club but you leave healthier."</p>
            <span class="author">— Alex T.</span>
        </div>
        <div class="testimonial-card">
            <p class="quote">"I've never been motivated to work out at 10pm until FitPlay. The energy is insane."</p>
            <span class="author">— Jordan K.</span>
        </div>
        <div class="testimonial-card">
            <p class="quote">"The gamification keeps me coming back. Leveling up feels so rewarding!"</p>
            <span class="author">— Sam R.</span>
        </div>
    </div>
</section>

<!-- CTA FOOTER -->
<section class="cta-footer" id="contact">
    <h2>Ready to Train Like It's Friday Night?</h2>
    <p>Join FitPlay today and transform your fitness journey.</p>
    <a href="Account/Register" class="btn-primary btn-large" data-enhanced-nav="false">Get Started</a>
</section>

<!-- FOOTER -->
<footer class="site-footer">
    <p>© 2026 FitPlay. Where Fitness Meets Nightlife. All rights reserved.</p>
</footer>

<style>


/* ── Profile Dropdown ── */
    .profile-dropdown {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 232, 122, 0.08);
        border: 1px solid rgba(0, 232, 122, 0.3);
        border-radius: 40px;
        padding: 6px 14px 6px 6px;
        cursor: pointer;
        color: #fff;
        font-size: 0.9rem;
        font-weight: 500;
        transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
        box-shadow: 0 0 12px rgba(0, 232, 122, 0.15);
    }

        .profile-trigger:hover,
        .profile-dropdown:hover .profile-trigger,
        .profile-dropdown:focus-within .profile-trigger {
            background: rgba(0, 232, 122, 0.15);
            border-color: rgba(0, 232, 122, 0.6);
            box-shadow: 0 0 20px rgba(0, 232, 122, 0.35);
        }

    .profile-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00e87a, #00a854);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        color: #021a0d;
        flex-shrink: 0;
        box-shadow: 0 0 10px rgba(0, 232, 122, 0.5);
    }

    .profile-name {
        max-width: 130px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #e0ffe8;
    }

    .dropdown-caret {
        transition: transform 0.2s;
        color: #00e87a;
        flex-shrink: 0;
    }

    .profile-dropdown:hover .dropdown-caret,
    .profile-dropdown:focus-within .dropdown-caret {
        transform: rotate(180deg);
    }

    .dropdown-menu {
        display: block;
        position: absolute;
        top: calc(100% + 4px);
        right: 0;
        min-width: 230px;
        padding-top: 6px;
        background: transparent;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transform: translateY(-8px);
        transition: opacity 0.18s ease, transform 0.18s ease;
    }

    .profile-dropdown:hover .dropdown-menu,
    .profile-dropdown:focus-within .dropdown-menu {
        opacity: 1;
        pointer-events: all;
        transform: translateY(0);
    }

    .dropdown-menu-inner {
        background: rgba(2, 18, 10, 0.97);
        border: 1px solid rgba(0, 232, 122, 0.25);
        border-radius: 14px;
        box-shadow: 0 0 0 1px rgba(0, 232, 122, 0.08), 0 0 30px rgba(0, 232, 122, 0.18), 0 20px 50px rgba(0, 0, 0, 0.7);
        padding: 8px;
    }

    .dropdown-section {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .dropdown-divider {
        height: 1px;
        background: rgba(0, 232, 122, 0.15);
        margin: 6px 4px;
    }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: 8px;
        color: rgba(200, 255, 220, 0.75);
        font-size: 0.875rem;
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        cursor: pointer;
    }

        .dropdown-item:hover {
            background: rgba(0, 232, 122, 0.12);
            color: #00e87a;
        }

        .dropdown-item svg {
            color: #00e87a;
            opacity: 0.5;
            flex-shrink: 0;
            transition: opacity 0.15s;
        }

        .dropdown-item:hover svg {
            opacity: 1;
        }

    @@media (max-width: 600px) {
        .profile-name {
            display: none;
        }
    }

    .dropdown-logout-section {
        padding: 4px 2px 2px;
    }

    .btn-logout-green {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        background: linear-gradient(135deg, #00e87a, #00c45f);
