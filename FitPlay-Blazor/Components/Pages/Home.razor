    /* ── Segments layer ── */
    .gn-segments {
        position: absolute;
        inset: 0;
        display: flex;
        z-index: 3;
    }

    .gn-seg {
        flex: 0 0 var(--seg-default);
        width: var(--seg-default);
        display: flex;
