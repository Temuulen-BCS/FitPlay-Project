@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Use JS to force a full navigation — NavigationManager.NavigateTo with forceLoad
            // can fail silently when the interactive circuit isn't fully established yet.
            await JS.InvokeVoidAsync("location.replace", "/membership");
        }
    }
}
