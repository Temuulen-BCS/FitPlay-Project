@page "/Account/AccessDenied"
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Access denied</PageTitle>

<header>
    <h1 class="text-danger">Access denied</h1>
    <p class="text-danger">You do not have access to this resource.</p>
</header>

@code {
    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    private string? ReturnUrl { get; set; }

    private bool _shouldRedirect;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
        {
            var decoded = Uri.UnescapeDataString(ReturnUrl);

            if (decoded.StartsWith("/user/trainings", StringComparison.OrdinalIgnoreCase) ||
                decoded.Equals("/user/book-class", StringComparison.OrdinalIgnoreCase) ||
                decoded.Equals("/user/progress", StringComparison.OrdinalIgnoreCase) ||
                decoded.Equals("/user/achievements", StringComparison.OrdinalIgnoreCase))
            {
                _shouldRedirect = true;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _shouldRedirect)
        {
            await JS.InvokeVoidAsync("location.replace", "/membership");
        }
    }
}
