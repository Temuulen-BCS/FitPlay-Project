@inherits LayoutComponentBase
@implements IDisposable

@inject NavigationManager NavigationManager

<header class="top-nav">
    <div class="nav-inner">
        <a href="/trainer/dashboard" class="logo">FIT<span>PLAY</span></a>
        <nav class="nav-links-top">
            <NavLink href="/trainer/validations">Validations</NavLink>
            <NavLink href="/trainer/rooms">Rooms</NavLink>
            <NavLink href="/trainer/gyms">Gyms</NavLink>
            <NavLink href="/trainer/exercises">Exercises</NavLink>
            <NavLink href="/trainer/rooms/booked">Booked rooms</NavLink>
        </nav>
        <AuthorizeView>
            <Authorized>
                @{
                    var displayName = context.User.FindFirst("full_name")?.Value
                                      ?? context.User.Identity?.Name
                                      ?? "Trainer";
                }
                <div class="profile-dropdown">
                    <button class="profile-trigger" type="button">
                        <span class="profile-avatar">@GetInitials(displayName)</span>
                        <span class="profile-name">@displayName</span>
                        <svg class="dropdown-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="dropdown-menu">
                        <div class="dropdown-menu-inner">
                            <div class="dropdown-section">
                            <a class="dropdown-item" href="Account/Manage" data-enhanced-nav="false">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                                Profile
                            </a>
                            <a class="dropdown-item" href="trainer/dashboard">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                Dashboard
                            </a>
                            <a class="dropdown-item" href="trainer/validations">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                Validations
                            </a>
                            <a class="dropdown-item" href="trainer/rooms">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                Rooms
                            </a>
                            <a class="dropdown-item" href="trainer/gyms">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                Gyms
                            </a>
                            <a class="dropdown-item" href="trainer/exercises">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                Exercises
                            </a>
                            <a class="dropdown-item" href="trainer/users">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                Manage Users
                            </a>
                        </div>
                        <div class="dropdown-divider"></div>
                        <div class="dropdown-section dropdown-logout-section">
                            <form action="Account/Logout" method="post">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="/" />
                                <button type="submit" class="btn-logout-green">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                    Log out
                                </button>
                            </form>
                        </div>
                        </div>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</header>

<main class="trainer-content">
    @Body
</main>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name[0].ToString().ToUpperInvariant();
    }
}

