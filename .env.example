# =============================================================================
# FitPlay Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# .env is gitignored and should NEVER be committed to version control

# Database Connection
# Use Railway's DATABASE_URL format: postgresql://user:password@host:port/database
# For local development: postgresql://postgres:postgres@localhost:5432/FitPlayDB
DATABASE_URL=postgresql://user:password@host:port/database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=FitPlayDB;Username=postgres;Password=postgres

# Stripe Configuration
# Get these from https://dashboard.stripe.com/test/apikeys
Stripe__SecretKey=sk_test_your_stripe_secret_key_here
Stripe__PublishableKey=pk_test_your_stripe_publishable_key_here
Stripe__WebhookSecret=whsec_your_webhook_secret_here
Stripe__PriceId=price_your_stripe_price_id_here

# JWT Configuration (for API authentication)
# IMPORTANT: Generate a secure random key for production (at least 32 characters)
# You can generate one with: openssl rand -base64 32
Jwt__Key=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARS
Jwt__Issuer=FitPlay.Api
Jwt__Audience=FitPlay.Api

# Builder.io Configuration
# Get your API key from https://builder.io/account/space
Builder__ApiKey=your_builder_io_api_key_here
Builder__Model=page

# API Base URL
# URL where the FitPlay.Api is running (for Blazor frontend to call backend)
# Local development: http://localhost:5179
# Production: your Railway API URL
API_BASE_URL=http://localhost:5179

# Logging Configuration
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft__AspNetCore=Warning

# Allowed Hosts (use * for all, or specify specific domains)
AllowedHosts=*

# =============================================================================
# Optional Configuration (Railway deployments)
# =============================================================================

# Data Protection Keys Path (Railway/Docker deployments)
# DATA_PROTECTION_KEYS_PATH=/app/keys

# Port (Railway sets this automatically, no need to set manually)
# PORT=8080

# Railway PostgreSQL (alternative to DATABASE_URL)
# If using Railway's PostgreSQL plugin, these are set automatically
# PGHOST=your-pg-host.railway.app
# PGPORT=5432
# PGDATABASE=railway
# PGUSER=postgres
# PGPASSWORD=your-password
